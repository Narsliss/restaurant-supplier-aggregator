#!/bin/bash
set -e

# Demo mode: auto-seed on first boot if database is empty
if [ "$DEMO_MODE" = "true" ] && [ "${PROCESS_TYPE:-web}" = "web" ]; then
  echo "Demo mode: checking if seed is needed..."
  USERS=$(./bin/rails runner "puts User.count" 2>/dev/null || echo "0")
  if [ "$USERS" = "0" ]; then
    echo "No users found — running demo seed..."
    ./bin/rails runner "load Rails.root.join('db/seeds/demo.rb')"
    echo "Demo seed complete."
  else
    echo "Database already seeded ($USERS users found)."
  fi
fi

# Determine which process to start based on PROCESS_TYPE
case "${PROCESS_TYPE:-web}" in
  web)
    echo "Starting web server (Puma)..."
    echo "WEB_CONCURRENCY=${WEB_CONCURRENCY:-0} workers, RAILS_MAX_THREADS=${RAILS_MAX_THREADS:-5} threads"
    exec ./bin/rails server -b 0.0.0.0 -p ${PORT:-8080}
    ;;
  worker)
    echo "Starting Solid Queue worker..."
    exec bundle exec rake solid_queue:start
    ;;
  *)
    echo "Unknown PROCESS_TYPE: $PROCESS_TYPE"
    echo "Valid options: web, worker"
    exit 1
    ;;
esac
