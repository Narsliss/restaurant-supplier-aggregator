<div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Reports</h1>
      <p class="text-gray-600 mt-1">Spending and order analytics</p>
    </div>
  </div>

  <%= render 'filter_bar', url: reports_path, show_location_filter: true %>
  <%= render 'summary_cards', summary: @summary %>

  <!-- Savings insight links -->
  <div class="flex flex-wrap gap-3 mb-8">
    <%= link_to savings_reports_path(**filter_params),
        class: "inline-flex items-center gap-2 px-4 py-2.5 bg-green-50 border border-green-200 rounded-lg hover:bg-green-100 transition-colors" do %>
      <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span class="text-sm font-medium text-green-700">Product Savings</span>
      <span class="text-xs text-green-500">&rarr;</span>
    <% end %>
    <%= link_to missed_savings_reports_path(**filter_params),
        class: "inline-flex items-center gap-2 px-4 py-2.5 bg-amber-50 border border-amber-200 rounded-lg hover:bg-amber-100 transition-colors" do %>
      <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
      </svg>
      <span class="text-sm font-medium text-amber-700">Missed Savings</span>
      <span class="text-xs text-amber-500">&rarr;</span>
    <% end %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- By Restaurant -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">By Restaurant</h2>
      </div>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Restaurant</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Spent</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Orders</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Savings</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @by_restaurant.each do |row| %>
            <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='<%= location_reports_path(location_id: row[:location].id, **filter_params) %>'">
              <td class="px-6 py-4 text-sm font-medium text-brand-orange"><%= row[:location].name %> <span class="text-gray-400 text-xs ml-1">&rarr;</span></td>
              <td class="px-6 py-4 text-sm text-gray-900 text-right"><%= number_to_currency(row[:total_spent]) %></td>
              <td class="px-6 py-4 text-sm text-gray-500 text-right"><%= row[:order_count] %></td>
              <td class="px-6 py-4 text-sm text-green-600 text-right"><%= number_to_currency(row[:savings]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- By Supplier -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">By Supplier</h2>
      </div>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Supplier</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Spent</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Orders</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Savings</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @by_supplier.each do |row| %>
            <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='<%= supplier_reports_path(supplier_id: row[:supplier].id, **filter_params) %>'">
              <td class="px-6 py-4 text-sm font-medium text-brand-orange"><%= row[:supplier]&.name || "Unknown" %> <span class="text-gray-400 text-xs ml-1">&rarr;</span></td>
              <td class="px-6 py-4 text-sm text-gray-900 text-right"><%= number_to_currency(row[:total_spent]) %></td>
              <td class="px-6 py-4 text-sm text-gray-500 text-right"><%= row[:order_count] %></td>
              <td class="px-6 py-4 text-sm text-green-600 text-right"><%= number_to_currency(row[:savings]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- By Team Member -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">By Team Member</h2>
      </div>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Spent</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Orders</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @by_member.each do |row| %>
            <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='<%= member_reports_path(user_id: row[:user].id, **filter_params) %>'">
              <td class="px-6 py-4 text-sm font-medium text-brand-orange"><%= row[:user].full_name %> <span class="text-gray-400 text-xs ml-1">&rarr;</span></td>
              <td class="px-6 py-4 text-sm text-gray-900 text-right"><%= number_to_currency(row[:total_spent]) %></td>
              <td class="px-6 py-4 text-sm text-gray-500 text-right"><%= row[:order_count] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Weekly Trend -->
    <%= render 'weekly_trend', weekly_trend: @weekly_trend %>
  </div>
</div>
