<div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
  <%= render 'breadcrumb', title: 'Product Savings' %>

  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Product Savings</h1>
      <p class="text-gray-600 mt-1">What you saved by choosing the best-priced supplier for each product</p>
    </div>
  </div>

  <%= render 'filter_bar', url: savings_reports_path, show_location_filter: true %>

  <!-- Total savings highlight -->
  <div class="bg-green-50 border border-green-200 rounded-xl p-6 mb-8">
    <div class="flex items-center gap-4">
      <div class="bg-green-100 rounded-full p-3">
        <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-green-800">Total Realized Savings</p>
        <p class="text-3xl font-bold text-green-700"><%= number_to_currency(@total_realized_savings) %></p>
        <p class="text-xs text-green-600 mt-1">Saved vs. the most expensive supplier option for each product</p>
      </div>
    </div>
  </div>

  <!-- Savings table -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Savings by Product</h2>
      <p class="text-sm text-gray-500 mt-0.5">Products where you chose a lower-priced supplier vs the most expensive option</p>
    </div>
    <% if @product_savings.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Product</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">You Paid</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Most Expensive</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Savings</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Qty</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @product_savings.each do |product_name, actual, worst_case, savings, qty| %>
              <tr>
                <td class="px-6 py-4 text-sm font-medium text-gray-900 max-w-xs truncate"><%= product_name %></td>
                <td class="px-6 py-4 text-sm text-gray-900 text-right"><%= number_to_currency(actual) %></td>
                <td class="px-6 py-4 text-sm text-gray-500 text-right"><%= number_to_currency(worst_case) %></td>
                <td class="px-6 py-4 text-sm font-semibold text-green-600 text-right"><%= number_to_currency(savings) %></td>
                <td class="px-6 py-4 text-sm text-gray-500 text-right"><%= qty.round(1) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-sm text-gray-500">No savings data for this period.</p>
        <p class="text-xs text-gray-400 mt-1">Savings are calculated when you order a product that's also available from a more expensive supplier.</p>
      </div>
    <% end %>
  </div>
</div>
