<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden"
     <%= "data-controller=spending-trend" if defined?(monthly_trend) && monthly_trend %>>
  <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
    <h2 class="text-lg font-semibold text-gray-900">Spending Trend</h2>
    <% if defined?(monthly_trend) && monthly_trend %>
      <div class="flex rounded-lg overflow-hidden border border-gray-200">
        <button type="button"
                data-spending-trend-target="weeklyBtn"
                data-action="spending-trend#showWeekly"
                class="px-3 py-1.5 text-xs font-medium transition-colors bg-brand-orange text-white">
          Weekly
        </button>
        <button type="button"
                data-spending-trend-target="monthlyBtn"
                data-action="spending-trend#showMonthly"
                class="px-3 py-1.5 text-xs font-medium transition-colors text-gray-500 hover:text-gray-700">
          Monthly
        </button>
      </div>
    <% end %>
  </div>
  <div class="p-6">
    <%# Weekly chart %>
    <div <%= "data-spending-trend-target=weeklyChart" if defined?(monthly_trend) && monthly_trend %>>
      <% max_total = [weekly_trend.map { |w| w[:total] }.max.to_f, 1].max %>
      <% if weekly_trend.any? { |w| w[:total] > 0 } %>
        <div class="flex items-stretch justify-between h-48 gap-2">
          <% weekly_trend.each do |week| %>
            <div class="flex flex-col items-center justify-end flex-1">
              <% if week[:total] > 0 %>
                <span class="text-xs text-gray-500 mb-1 whitespace-nowrap"><%= number_to_currency(week[:total], precision: 0) %></span>
              <% end %>
              <div class="w-full bg-brand-orange rounded-t transition-all"
                   style="height: <%= week[:total] > 0 ? [(week[:total] / max_total * 100).round, 4].max : 2 %>%">
              </div>
              <p class="text-xs text-gray-500 mt-2"><%= week[:label] %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="flex items-center justify-center h-48 text-sm text-gray-400">No spending data yet</div>
      <% end %>
    </div>

    <% if defined?(monthly_trend) && monthly_trend %>
      <%# Monthly chart %>
      <div data-spending-trend-target="monthlyChart" class="hidden">
        <% max_monthly = [monthly_trend.map { |m| m[:total] }.max.to_f, 1].max %>
        <% if monthly_trend.any? { |m| m[:total] > 0 } %>
          <div class="flex items-stretch justify-between h-48 gap-2">
            <% monthly_trend.each do |month| %>
              <div class="flex flex-col items-center justify-end flex-1">
                <% if month[:total] > 0 %>
                  <span class="text-xs text-gray-500 mb-1 whitespace-nowrap"><%= number_to_currency(month[:total], precision: 0) %></span>
                <% end %>
                <div class="w-full bg-brand-green rounded-t transition-all"
                     style="height: <%= month[:total] > 0 ? [(month[:total] / max_monthly * 100).round, 4].max : 2 %>%">
                </div>
                <p class="text-xs text-gray-500 mt-2"><%= month[:label] %></p>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="flex items-center justify-center h-48 text-sm text-gray-400">No spending data yet</div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
