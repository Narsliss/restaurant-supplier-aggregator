<% content_for :title, "Reports" %>

<%# Wired from mockups/mobile/reports.html %>

<!-- Header -->
<header class="bg-white border-b border-gray-200 -mx-4 -mt-2" style="position: sticky; top: 0; z-index: 40;">
  <div class="px-4 py-3 flex items-center justify-between">
    <h1 class="font-heading text-lg font-semibold text-brand-navy tracking-wide">Reports</h1>
  </div>
  <div class="px-4 pb-3">
    <%= render 'filter_bar', url: reports_path, show_location_filter: true %>
  </div>
</header>

<!-- Summary KPIs -->
<div class="mt-4 grid grid-cols-2 gap-2">
  <div class="bg-white rounded-xl p-3 border border-gray-100 shadow-sm">
    <p class="text-[10px] text-gray-400 uppercase tracking-wider font-semibold">Total Spent</p>
    <p class="text-xl font-heading font-bold text-brand-navy mt-0.5"><%= number_to_currency(@summary[:total_spent], precision: 0) %></p>
  </div>
  <div class="bg-white rounded-xl p-3 border border-gray-100 shadow-sm">
    <p class="text-[10px] text-gray-400 uppercase tracking-wider font-semibold">Total Savings</p>
    <p class="text-xl font-heading font-bold text-brand-green mt-0.5"><%= number_to_currency(@summary[:total_savings], precision: 0) %></p>
  </div>
  <div class="bg-white rounded-xl p-3 border border-gray-100 shadow-sm">
    <p class="text-[10px] text-gray-400 uppercase tracking-wider font-semibold">Orders</p>
    <p class="text-xl font-heading font-bold text-brand-navy mt-0.5"><%= @summary[:total_orders] %></p>
  </div>
  <% if @summary[:avg_order_value] %>
    <div class="bg-white rounded-xl p-3 border border-gray-100 shadow-sm">
      <p class="text-[10px] text-gray-400 uppercase tracking-wider font-semibold">Avg Order</p>
      <p class="text-xl font-heading font-bold text-brand-navy mt-0.5"><%= number_to_currency(@summary[:avg_order_value], precision: 0) %></p>
    </div>
  <% end %>
</div>

<!-- Quick Links -->
<div class="mt-3 flex gap-2">
  <%= link_to savings_reports_path(**filter_params), class: "flex-1 bg-green-50 border border-green-200 rounded-xl p-3 text-left" do %>
    <div class="flex items-center gap-2">
      <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <div>
        <p class="text-xs font-semibold text-green-800">Product Savings</p>
        <p class="text-[10px] text-green-600"><%= number_to_currency(@summary[:total_savings], precision: 0) %> realized</p>
      </div>
    </div>
  <% end %>
  <%= link_to missed_savings_reports_path(**filter_params), class: "flex-1 bg-amber-50 border border-amber-200 rounded-xl p-3 text-left" do %>
    <div class="flex items-center gap-2">
      <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
      <div>
        <p class="text-xs font-semibold text-amber-800">Missed Savings</p>
        <p class="text-[10px] text-amber-600">View potential</p>
      </div>
    </div>
  <% end %>
</div>

<!-- By Restaurant -->
<section class="mt-5">
  <h2 class="font-heading text-sm font-semibold text-brand-navy uppercase tracking-wider mb-3">By Restaurant</h2>
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden divide-y divide-gray-50">
    <% @by_restaurant.each do |row| %>
      <%= link_to location_reports_path(location_id: row[:location].id, **filter_params), class: "p-3 flex items-center justify-between block" do %>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-gray-900"><%= row[:location].name %></p>
          <div class="flex items-center gap-3 mt-0.5">
            <span class="text-[10px] text-gray-400"><%= row[:order_count] %> orders</span>
            <% if row[:savings].to_f > 0 %>
              <span class="text-[10px] text-green-600 font-medium">Saved <%= number_to_currency(row[:savings]) %></span>
            <% end %>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <p class="text-sm font-bold text-brand-navy"><%= number_to_currency(row[:total_spent]) %></p>
          <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
      <% end %>
    <% end %>
  </div>
</section>

<!-- By Supplier -->
<section class="mt-5">
  <h2 class="font-heading text-sm font-semibold text-brand-navy uppercase tracking-wider mb-3">By Supplier</h2>
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden divide-y divide-gray-50">
    <% @by_supplier.each do |row| %>
      <%= link_to supplier_reports_path(supplier_id: row[:supplier].id, **filter_params), class: "p-3 flex items-center justify-between block" do %>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-gray-900"><%= row[:supplier]&.name || "Unknown" %></p>
          <div class="flex items-center gap-3 mt-0.5">
            <span class="text-[10px] text-gray-400"><%= row[:order_count] %> orders</span>
            <% if row[:savings].to_f > 0 %>
              <span class="text-[10px] text-green-600 font-medium">Saved <%= number_to_currency(row[:savings]) %></span>
            <% end %>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <p class="text-sm font-bold text-brand-navy"><%= number_to_currency(row[:total_spent]) %></p>
          <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
      <% end %>
    <% end %>
  </div>
</section>

<!-- By Team Member -->
<% if @by_member.present? && @by_member.any? %>
  <section class="mt-5 mb-6">
    <h2 class="font-heading text-sm font-semibold text-brand-navy uppercase tracking-wider mb-3">By Team Member</h2>
    <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden divide-y divide-gray-50">
      <% @by_member.each do |row| %>
        <%= link_to member_reports_path(user_id: row[:user].id, **filter_params), class: "p-3 flex items-center justify-between block" do %>
          <div class="flex items-center gap-3 flex-1 min-w-0">
            <div class="w-8 h-8 bg-brand-orange rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
              <%= row[:user].full_name.split.map(&:first).join.first(2).upcase %>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-900"><%= row[:user].full_name %></p>
              <span class="text-[10px] text-gray-400"><%= row[:order_count] %> orders</span>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <p class="text-sm font-bold text-brand-navy"><%= number_to_currency(row[:total_spent]) %></p>
            <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </div>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>
