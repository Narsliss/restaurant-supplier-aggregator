<% if @broken_credentials&.any? %>
  <div class="mb-6 rounded-lg border-2 border-red-300 bg-red-50 p-4 sm:p-5" role="alert">
    <div class="flex items-start gap-3">
      <svg class="h-6 w-6 flex-shrink-0 text-red-600 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
      </svg>
      <div class="flex-1 min-w-0">
        <h3 class="text-base font-heading font-bold text-red-900">
          Action required: <%= pluralize(@broken_credentials.size, "supplier connection") %>
          <%= @broken_credentials.size == 1 ? "needs" : "need" %> attention
        </h3>
        <p class="mt-1 text-sm text-red-800">
          <%= @broken_credentials.size == 1 ? "We can't connect to this supplier." : "We can't connect to these suppliers." %>
          Pricing won't update and orders can't be placed until you re-validate.
        </p>

        <ul class="mt-3 space-y-2">
          <% @broken_credentials.each do |cred| %>
            <li class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 bg-white rounded-md border border-red-200 px-3 py-2.5">
              <div class="min-w-0">
                <p class="text-sm font-semibold text-gray-900">
                  <%= cred.supplier.name %>
                  <% if cred.user_id != current_user.id && cred.user.present? %>
                    <span class="ml-1 text-xs font-normal text-gray-500">(<%= cred.user.first_name.presence || cred.user.email %>)</span>
                  <% end %>
                </p>
                <p class="text-xs text-red-700 mt-0.5"><%= cred.health_message %></p>
              </div>
              <%= link_to "Re-validate →", supplier_credentials_path,
                  class: "flex-shrink-0 inline-flex items-center justify-center rounded-md bg-red-600 px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-red-700 transition-colors" %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
<% end %>
