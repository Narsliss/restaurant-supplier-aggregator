<%# ============================================================= %>
<%# CHEF DASHBOARD — "My Kitchen"                                %>
<%# Focus: orders placed, delivery status, weekly activity        %>
<%# ============================================================= %>

<!-- Hero Banner -->
<div class="-mx-4 sm:-mx-6 lg:-mx-8 -mt-10 mb-8">
  <div class="relative overflow-hidden" style="background: linear-gradient(135deg, #3A6147 0%, #4A7C59 100%);">
    <img src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=1920&q=80"
         alt="Restaurant kitchen"
         loading="lazy" decoding="async"
         class="absolute inset-0 h-full w-full object-cover opacity-15"
         onerror="this.style.display='none'">
    <div class="relative px-6 py-10 sm:px-12 sm:py-14">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
        <div>
          <h1 class="text-3xl sm:text-4xl font-heading font-bold text-white tracking-wide">
            Welcome back, <%= current_user.first_name || current_user.email.split('@').first %>
          </h1>
          <p class="mt-2 text-lg text-gray-300 font-body">Your kitchen at a glance<%= " — #{current_location.name}" if current_location %>.</p>
          <div class="mt-5">
            <%= link_to select_list_orders_path, class: "inline-flex items-center rounded-md bg-brand-orange px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-orange-light transition-colors" do %>
              <svg class="-ml-0.5 mr-1.5 h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
              </svg>
              New Order
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%= render "dashboard/credential_health_alert" %>

<!-- 2FA Alerts -->
<% if @pending_2fa_requests.any? %>
  <div class="mb-6 rounded-md bg-brand-orange-50 border border-brand-orange/20 p-4">
    <div class="flex">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-brand-orange" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3">
        <h3 class="text-sm font-medium text-brand-orange-dark">Verification Required</h3>
        <div class="mt-2 text-sm text-brand-orange-dark/80">
          <ul class="list-disc list-inside">
            <% @pending_2fa_requests.each do |request| %>
              <li><%= request.supplier.name %> — expires in <%= distance_of_time_in_words(Time.current, request.expires_at) %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  </div>
<% end %>

<!-- Getting Started (if applicable) -->
<% if @getting_started.present? %>
  <div class="mb-6 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100" style="background: linear-gradient(135deg, #3A6147 0%, #4A7C59 100%);">
      <h3 class="text-base font-heading font-semibold text-white">Get Started</h3>
      <p class="mt-0.5 text-sm text-white/70">Complete these steps to start ordering.</p>
    </div>
    <ol class="divide-y divide-gray-100">
      <% @getting_started.each_with_index do |step, i| %>
        <li class="flex items-center gap-4 px-6 py-4 <%= step[:done] ? 'bg-gray-50/50' : '' %>">
          <div class="flex-shrink-0">
            <% if step[:done] %>
              <div class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-green">
                <svg class="h-4 w-4 text-white" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                </svg>
              </div>
            <% else %>
              <div class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-brand-orange text-xs font-semibold text-brand-orange"><%= i + 1 %></div>
            <% end %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-semibold <%= step[:done] ? 'text-gray-400 line-through' : 'text-gray-900' %>"><%= step[:title] %></p>
            <p class="mt-0.5 text-xs text-gray-500"><%= step[:description] %></p>
          </div>
          <% if !step[:done] && step[:cta] %>
            <%= link_to step[:cta], step[:path], class: "flex-shrink-0 inline-flex items-center rounded-md bg-brand-orange px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-orange-light transition-colors" %>
          <% end %>
        </li>
      <% end %>
    </ol>
  </div>
<% end %>

<!-- Stat Cards -->
<dl class="grid grid-cols-1 gap-5 sm:grid-cols-3 mb-8">
  <%# Orders This Week %>
  <div class="relative overflow-hidden rounded-lg bg-white px-4 pb-4 pt-5 shadow sm:px-6 sm:pt-6">
    <dt>
      <div class="absolute rounded-md bg-brand-green p-3">
        <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" />
        </svg>
      </div>
      <p class="ml-16 text-sm font-medium text-gray-500">Orders This Week</p>
    </dt>
    <dd class="ml-16 flex items-baseline">
      <p class="text-2xl font-semibold text-gray-900"><%= @stats[:orders_this_week] %></p>
    </dd>
  </div>

  <%# Next Delivery %>
  <div class="relative overflow-hidden rounded-lg bg-white px-4 pb-4 pt-5 shadow sm:px-6 sm:pt-6">
    <dt>
      <div class="absolute rounded-md bg-brand-orange p-3">
        <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
        </svg>
      </div>
      <p class="ml-16 text-sm font-medium text-gray-500">Next Delivery</p>
    </dt>
    <dd class="ml-16 flex items-baseline">
      <% if @stats[:next_delivery] %>
        <p class="text-2xl font-semibold text-gray-900"><%= @stats[:next_delivery].delivery_date.strftime("%a, %b %-d") %></p>
        <p class="ml-2 text-sm text-gray-500"><%= @stats[:next_delivery].supplier.name %></p>
      <% else %>
        <p class="text-lg font-medium text-gray-400">None scheduled</p>
      <% end %>
    </dd>
  </div>

  <%# Needs Price Review %>
  <div class="relative overflow-hidden rounded-lg bg-white px-4 pb-4 pt-5 shadow sm:px-6 sm:pt-6">
    <dt>
      <div class="absolute rounded-md <%= @stats[:pending_verifications] > 0 ? 'bg-yellow-500' : 'bg-brand-green' %> p-3">
        <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
        </svg>
      </div>
      <p class="ml-16 text-sm font-medium text-gray-500">Needs Price Review</p>
    </dt>
    <dd class="ml-16 flex items-baseline">
      <p class="text-2xl font-semibold <%= @stats[:pending_verifications] > 0 ? 'text-yellow-600' : 'text-gray-900' %>"><%= @stats[:pending_verifications] %></p>
    </dd>
  </div>
</dl>

<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
  <!-- Upcoming Deliveries -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-100">
      <h3 class="text-lg font-heading font-medium leading-6 text-gray-900">Upcoming Deliveries</h3>
    </div>
    <% if @upcoming_deliveries.any? %>
      <div class="divide-y divide-gray-200">
        <% @upcoming_deliveries.each do |date, orders| %>
          <div class="px-4 py-3 sm:px-6">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
              <%= date == Date.current ? "Today" : date == Date.tomorrow ? "Tomorrow" : date.strftime("%A, %B %-d") %>
            </p>
            <% orders.each do |order| %>
              <%= link_to order, class: "block rounded-md px-3 py-2 -mx-1 hover:bg-brand-green-50 transition-colors" do %>
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-sm font-medium text-gray-900"><%= order.display_supplier_name %></p>
                    <p class="text-xs text-gray-500"><%= pluralize(order.item_count, "item") %></p>
                  </div>
                  <div class="text-right">
                    <p class="text-sm font-semibold text-gray-900"><%= number_to_currency(order.total_amount) %></p>
                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                      <%= case order.status
                          when 'submitted', 'confirmed' then 'bg-green-100 text-green-800'
                          when 'processing', 'verifying' then 'bg-blue-100 text-blue-800'
                          when 'price_changed' then 'bg-yellow-100 text-yellow-800'
                          else 'bg-gray-100 text-gray-800'
                          end %>">
                      <%= order.status.titleize %>
                    </span>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="px-4 py-8 text-center text-gray-500">
        <p class="text-sm">No upcoming deliveries.</p>
        <p class="mt-1 text-sm"><%= link_to "Place an order", select_list_orders_path, class: "text-brand-orange hover:text-brand-orange-dark font-medium" %></p>
      </div>
    <% end %>
  </div>

  <!-- This Week's Orders (Bar Chart) -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-100">
      <h3 class="text-lg font-heading font-medium leading-6 text-gray-900">Order Spend This Week</h3>
      <p class="mt-1 text-sm text-gray-500">Submitted orders at your location</p>
    </div>
    <div class="p-6">
      <% max_total = [@daily_orders.map { |d| d[:total] }.max.to_f, 1].max %>
      <% if @daily_orders.any? { |d| d[:total] > 0 } %>
        <div class="flex items-stretch justify-between h-48 gap-2">
          <% @daily_orders.each do |day| %>
            <div class="flex flex-col items-center justify-end flex-1">
              <% if day[:total] > 0 %>
                <span class="text-xs text-gray-500 mb-1 whitespace-nowrap"><%= number_to_currency(day[:total], precision: 0) %></span>
              <% end %>
              <div class="w-full rounded-t transition-all <%= day[:date] == Date.current ? 'bg-brand-orange' : 'bg-brand-green' %>"
                   style="height: <%= day[:total] > 0 ? [(day[:total] / max_total * 100).round, 4].max : 2 %>%">
              </div>
              <p class="text-xs font-medium mt-2 <%= day[:date] == Date.current ? 'text-brand-orange' : 'text-gray-500' %>"><%= day[:label] %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="flex items-center justify-center h-48 text-sm text-gray-400">No orders this week yet</div>
      <% end %>
    </div>
  </div>
</div>

<!-- Recent Orders -->
<div class="mt-6 bg-white shadow rounded-lg">
  <div class="px-4 py-5 sm:px-6 flex justify-between items-center border-b border-gray-100">
    <h3 class="text-lg font-heading font-medium leading-6 text-gray-900">Recent Orders</h3>
    <%= link_to orders_path, class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md border border-brand-orange text-brand-orange hover:bg-brand-orange hover:text-white transition-colors" do %>
      View All
    <% end %>
  </div>
  <ul role="list" class="divide-y divide-gray-200">
    <% @recent_orders.each do |order| %>
      <li>
        <%= link_to order, class: "block hover:bg-brand-green-50 transition-colors" do %>
          <div class="px-4 py-4 sm:px-6">
            <div class="flex items-center justify-between">
              <p class="truncate text-sm font-medium text-brand-green-dark"><%= order.display_supplier_name %></p>
              <div class="ml-2 flex flex-shrink-0 items-center gap-2">
                <span class="text-sm font-semibold text-gray-900"><%= number_to_currency(order.total_amount) %></span>
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                  <%= case order.status
                      when 'submitted', 'confirmed' then 'bg-green-100 text-green-800'
                      when 'processing', 'verifying' then 'bg-blue-100 text-blue-800'
                      when 'failed' then 'bg-red-100 text-red-800'
                      when 'price_changed' then 'bg-yellow-100 text-yellow-800'
                      else 'bg-gray-100 text-gray-800'
                      end %>">
                  <%= order.status.titleize %>
                </span>
              </div>
            </div>
            <p class="mt-1 text-xs text-gray-500"><%= time_ago_in_words(order.created_at) %> ago</p>
          </div>
        <% end %>
      </li>
    <% end %>
    <% if @recent_orders.empty? %>
      <li class="px-4 py-8 text-center text-gray-500">
        No orders yet. <%= link_to "Create your first order", select_list_orders_path, class: "text-brand-orange hover:text-brand-orange-dark font-medium" %>
      </li>
    <% end %>
  </ul>
</div>
