<% content_for :title, "Accept Invitation — Supplier Portal" %>

<div class="flex min-h-screen">
  <%# Left panel %>
  <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden" style="background-color: #3A6147;">
    <div class="absolute -bottom-24 -left-24 w-80 h-80 rounded-full blur-3xl" style="background-color: rgba(212,148,58,0.08);"></div>
    <div class="absolute -top-24 -right-24 w-80 h-80 rounded-full blur-3xl" style="background-color: rgba(74,124,89,0.1);"></div>
    <div class="relative z-10 flex flex-col justify-between p-12 w-full">
      <div>
        <%= render "shared/logo", variant: :login %>
        <p class="mt-3 text-lg" style="color: #9ca3af;">Supplier Portal</p>
      </div>
      <div class="space-y-6">
        <h2 class="text-2xl text-white font-heading leading-relaxed">You've been invited!</h2>
        <p style="color: #9ca3af;" class="leading-relaxed">
          Set up your account to access the <%= @invitation.supplier.name %> Supplier Portal on SupplierHub.
        </p>
        <div class="rounded-lg p-4" style="background-color: rgba(74,124,89,0.2);">
          <p class="text-sm" style="color: #d1d5db;">
            <strong class="text-white"><%= @invitation.supplier.name %></strong><br>
            Role: <span class="text-white capitalize"><%= @invitation.role %></span>
          </p>
        </div>
      </div>
      <p class="text-xs" style="color: #6b7280;">&copy; <%= Date.current.year %> SupplierHub</p>
    </div>
  </div>

  <%# Right: Accept form %>
  <div class="flex flex-1 flex-col justify-center px-6 py-12 lg:flex-none lg:w-1/2 lg:px-20 xl:px-24">
    <div class="mx-auto w-full max-w-sm lg:w-96">
      <div class="lg:hidden mb-10 text-center">
        <%= render "shared/logo", variant: :login_mobile %>
      </div>

      <%# Mobile invitation context %>
      <div class="lg:hidden mb-6 rounded-lg bg-blue-50 border border-blue-200 p-4">
        <p class="text-sm text-blue-800">
          You've been invited to join <strong><%= @invitation.supplier.name %></strong> on the SupplierHub Supplier Portal
          as <strong class="capitalize"><%= @invitation.role %></strong>.
        </p>
      </div>

      <div>
        <h2 class="text-3xl font-heading font-bold tracking-tight text-gray-900">
          Create your account
        </h2>
        <p class="mt-2 text-sm text-gray-500">
          Set up your credentials to access the Supplier Portal.
        </p>
      </div>

      <% if defined?(@errors) && @errors.any? %>
        <div class="mt-4 rounded-md bg-red-50 border border-red-200 p-4">
          <div class="flex">
            <svg class="h-5 w-5 text-red-400 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
            </svg>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800">Please fix the following:</h3>
              <ul class="mt-2 list-disc pl-5 text-sm text-red-700 space-y-1">
                <% @errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      <% end %>

      <div class="mt-8">
        <%= form_tag(accept_supplier_portal_invitation_path(token: @invitation.token), method: :post, class: "space-y-5") do %>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="first_name" class="block text-sm font-medium text-gray-700">First name</label>
              <div class="mt-1.5">
                <input type="text" name="first_name" id="first_name" required autofocus
                       value="<%= params[:first_name] %>"
                       class="block w-full rounded-lg border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm py-2.5 px-3">
              </div>
            </div>
            <div>
              <label for="last_name" class="block text-sm font-medium text-gray-700">Last name</label>
              <div class="mt-1.5">
                <input type="text" name="last_name" id="last_name" required
                       value="<%= params[:last_name] %>"
                       class="block w-full rounded-lg border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm py-2.5 px-3">
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700">Email</label>
            <div class="mt-1.5">
              <input type="email" value="<%= @invitation.email %>" disabled
                     class="block w-full rounded-lg border-gray-200 bg-gray-50 shadow-sm text-sm py-2.5 px-3 text-gray-500">
            </div>
          </div>

          <div>
            <label for="password" class="block text-sm font-medium text-gray-700">Password</label>
            <p class="text-xs text-gray-400 mt-0.5">Minimum 8 characters</p>
            <div class="mt-1.5 relative" data-controller="password-toggle">
              <input type="password" name="password" id="password" required minlength="8"
                     autocomplete="new-password"
                     data-password-toggle-target="input"
                     class="block w-full rounded-lg border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm py-2.5 px-3 pr-10">
              <button type="button" data-action="password-toggle#toggle"
                      class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 focus:outline-none">
                <svg data-password-toggle-target="showIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <svg data-password-toggle-target="hideIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 hidden">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
                </svg>
              </button>
            </div>
          </div>

          <div>
            <label for="password_confirmation" class="block text-sm font-medium text-gray-700">Confirm password</label>
            <div class="mt-1.5">
              <input type="password" name="password_confirmation" id="password_confirmation" required
                     autocomplete="new-password"
                     class="block w-full rounded-lg border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm py-2.5 px-3">
            </div>
          </div>

          <div class="pt-1">
            <button type="submit"
                    class="flex w-full justify-center rounded-lg bg-brand-orange px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-orange-dark transition-colors cursor-pointer">
              Create account &amp; sign in
            </button>
          </div>
        <% end %>

        <p class="mt-8 text-center text-sm text-gray-500">
          Already have an account?
          <%= link_to "Sign in", new_supplier_user_session_path,
              class: "font-semibold text-brand-orange hover:text-brand-orange-dark transition-colors" %>
        </p>
      </div>
    </div>
  </div>
</div>
