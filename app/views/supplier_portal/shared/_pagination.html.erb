<%# Simple prev/next pagination. Locals: page (Integer), per_page (Integer), total_count (Integer), base_path (String) %>
<% total_pages = (total_count.to_f / per_page).ceil %>
<% return if total_pages <= 1 %>

<nav class="flex items-center justify-between border-t border-gray-200 px-4 py-3 sm:px-6 mt-4">
  <div class="text-sm text-gray-700">
    Showing <span class="font-medium"><%= ((page - 1) * per_page) + 1 %></span>
    to <span class="font-medium"><%= [page * per_page, total_count].min %></span>
    of <span class="font-medium"><%= total_count %></span> results
  </div>
  <div class="flex gap-2">
    <% if page > 1 %>
      <%= link_to "Previous", "#{base_path}#{base_path.include?('?') ? '&' : '?'}page=#{page - 1}",
          class: "relative inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    <% end %>
    <% if page < total_pages %>
      <%= link_to "Next", "#{base_path}#{base_path.include?('?') ? '&' : '?'}page=#{page + 1}",
          class: "relative inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    <% end %>
  </div>
</nav>
