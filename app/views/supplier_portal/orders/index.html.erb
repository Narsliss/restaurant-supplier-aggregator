<% content_for(:title) { "Orders — #{current_supplier.name} Supplier Portal" } %>

<div class="space-y-6">
  <%# Page header %>
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Orders</h1>
    <p class="text-gray-500 mt-1"><%= number_with_delimiter(@total_count) %> total orders</p>
  </div>

  <%# Stat cards %>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
    <%= render "supplier_portal/shared/stat_card",
        label: "Total Orders",
        value: number_with_delimiter(@order_stats[:count]) %>

    <%= render "supplier_portal/shared/stat_card",
        label: "Total Revenue",
        value: number_to_currency(@order_stats[:revenue]) %>

    <%= render "supplier_portal/shared/stat_card",
        label: "Avg Order Value",
        value: number_to_currency(@order_stats[:avg_value]) %>

    <%= render "supplier_portal/shared/stat_card",
        label: "Total Items Ordered",
        value: number_with_delimiter(@order_stats[:items]) %>
  </div>

  <%# Filter bar %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
    <%= form_tag(supplier_portal_orders_path, method: :get, class: "space-y-3") do %>
      <div class="flex flex-col sm:flex-row gap-3">
        <input type="text" name="q" value="<%= params[:q] %>"
               placeholder="Search by customer or confirmation #..."
               class="flex-1 rounded-lg border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm py-2.5 px-3">

        <select name="status"
                class="rounded-lg border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm py-2.5 px-3">
          <option value="">All Statuses</option>
          <option value="submitted" <%= 'selected' if params[:status] == 'submitted' %>>Submitted</option>
          <option value="confirmed" <%= 'selected' if params[:status] == 'confirmed' %>>Confirmed</option>
        </select>

        <select name="date_range"
                data-controller="date-range"
                data-action="change->date-range#toggle"
                class="rounded-lg border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm py-2.5 px-3">
          <option value="">All Time</option>
          <option value="7d" <%= 'selected' if params[:date_range] == '7d' %>>Last 7 Days</option>
          <option value="30d" <%= 'selected' if params[:date_range] == '30d' %>>Last 30 Days</option>
          <option value="90d" <%= 'selected' if params[:date_range] == '90d' %>>Last 90 Days</option>
          <option value="ytd" <%= 'selected' if params[:date_range] == 'ytd' %>>Year to Date</option>
          <option value="custom" <%= 'selected' if params[:date_range] == 'custom' %>>Custom</option>
        </select>

        <button type="submit" class="inline-flex items-center rounded-lg bg-brand-green px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-brand-green-dark transition-colors cursor-pointer">
          Filter
        </button>

        <%= link_to "Export CSV", export_supplier_portal_orders_path(request.query_parameters),
            class: "inline-flex items-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 transition-colors" %>
      </div>

      <%# Custom date fields (hidden by default, shown when "custom" selected) %>
      <div data-date-range-target="customFields"
           class="flex flex-col sm:flex-row gap-3 <%= 'hidden' unless params[:date_range] == 'custom' %>">
        <div class="flex items-center gap-2">
          <label class="text-sm text-gray-500">From</label>
          <input type="date" name="start_date" value="<%= params[:start_date] || @start_date&.strftime('%Y-%m-%d') %>"
                 class="rounded-lg border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm py-2 px-3">
        </div>
        <div class="flex items-center gap-2">
          <label class="text-sm text-gray-500">To</label>
          <input type="date" name="end_date" value="<%= params[:end_date] || @end_date&.strftime('%Y-%m-%d') %>"
                 class="rounded-lg border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm py-2 px-3">
        </div>
      </div>
    <% end %>
  </div>

  <%# Orders table / cards %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <%# Desktop table %>
    <div class="hidden sm:block overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Customer</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Items</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Total</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Confirmation #</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @orders.each do |order| %>
            <%= link_to supplier_portal_order_path(order), class: "contents" do %>
              <tr class="hover:bg-gray-50 cursor-pointer">
                <td class="px-6 py-4 text-sm text-gray-500"><%= order.submitted_at&.strftime("%-m/%-d/%y") || "—" %></td>
                <td class="px-6 py-4 text-sm font-medium text-gray-900">
                  <%= order.organization&.name || "—" %>
                  <% if order.location %>
                    <span class="block text-xs text-gray-400"><%= order.location.name %></span>
                  <% end %>
                </td>
                <td class="px-6 py-4 text-sm text-gray-900 text-right"><%= order.order_items.size %></td>
                <td class="px-6 py-4 text-sm text-gray-900 text-right"><%= number_to_currency(order.total_amount) %></td>
                <td class="px-6 py-4 text-center">
                  <% if order.confirmed? %>
                    <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium" style="background-color: #dcfce7; color: #166534;">Confirmed</span>
                  <% else %>
                    <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium" style="background-color: #dbeafe; color: #1e40af;">Submitted</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 text-sm text-gray-500 text-right font-mono"><%= order.confirmation_number || "—" %></td>
              </tr>
            <% end %>
          <% end %>
          <% if @orders.empty? %>
            <tr><td colspan="6" class="px-6 py-8 text-center text-sm text-gray-400">No orders found</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# Mobile cards %>
    <div class="sm:hidden divide-y divide-gray-200">
      <% @orders.each do |order| %>
        <%= link_to supplier_portal_order_path(order), class: "block p-4 hover:bg-gray-50" do %>
          <div class="flex justify-between items-start">
            <div>
              <p class="text-sm font-medium text-gray-900"><%= order.organization&.name || "—" %></p>
              <p class="text-xs text-gray-400 mt-0.5"><%= order.submitted_at&.strftime("%-m/%-d/%y") %></p>
            </div>
            <div class="text-right">
              <p class="text-sm font-semibold text-gray-900"><%= number_to_currency(order.total_amount) %></p>
              <% if order.confirmed? %>
                <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium mt-1" style="background-color: #dcfce7; color: #166534;">Confirmed</span>
              <% else %>
                <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium mt-1" style="background-color: #dbeafe; color: #1e40af;">Submitted</span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
      <% if @orders.empty? %>
        <div class="p-8 text-center text-sm text-gray-400">No orders found</div>
      <% end %>
    </div>
  </div>

  <%# Pagination %>
  <%= render "supplier_portal/shared/pagination", page: @page, per_page: @per_page, total_count: @total_count, base_path: supplier_portal_orders_path(q: params[:q], status: params[:status], date_range: params[:date_range], start_date: params[:start_date], end_date: params[:end_date]) %>
</div>
