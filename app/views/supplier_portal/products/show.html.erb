<% content_for(:title) { "#{@product.supplier_name} — Supplier Portal" } %>

<div class="space-y-8">
  <%# Breadcrumb %>
  <div>
    <%= link_to "← Products", supplier_portal_products_path, class: "text-sm text-brand-green-dark hover:underline" %>
  </div>

  <%# Product Details Card %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-200">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <h1 class="text-2xl font-bold text-gray-900"><%= @product.supplier_name %></h1>
          <p class="text-sm text-gray-500 font-mono mt-1">SKU: <%= @product.supplier_sku %></p>
        </div>
        <div>
          <% if @product.discontinued? %>
            <span class="inline-flex px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800">Discontinued</span>
          <% elsif @product.out_of_stock? %>
            <span class="inline-flex px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800">Out of Stock</span>
          <% else %>
            <span class="inline-flex px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">In Stock</span>
          <% end %>
        </div>
      </div>
    </div>

    <div class="px-6 py-5">
      <dl class="grid grid-cols-2 sm:grid-cols-4 gap-6">
        <div>
          <dt class="text-sm font-medium text-gray-500">Current Price</dt>
          <dd class="mt-1 text-lg font-bold text-gray-900"><%= @product.current_price ? number_to_currency(@product.current_price) : "—" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Previous Price</dt>
          <dd class="mt-1 text-lg font-bold text-gray-900">
            <% if @product.previous_price %>
              <%= number_to_currency(@product.previous_price) %>
              <% if @product.price_changed? %>
                <span class="text-sm font-normal <%= @product.price_increased? ? 'text-red-600' : 'text-green-600' %>">
                  (<%= @product.price_increased? ? '↑' : '↓' %> <%= @product.price_change_percent.abs.round(1) %>%)
                </span>
              <% end %>
            <% else %>
              <span class="text-gray-400">—</span>
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Pack Size</dt>
          <dd class="mt-1 text-lg font-bold text-gray-900"><%= @product.pack_size || "—" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Per-Unit Price</dt>
          <dd class="mt-1 text-lg font-bold text-gray-900"><%= @product.formatted_per_unit_price || "—" %></dd>
        </div>
      </dl>

      <dl class="grid grid-cols-2 sm:grid-cols-4 gap-6 mt-6 pt-6 border-t border-gray-200">
        <div>
          <dt class="text-sm font-medium text-gray-500">Min Order Qty</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @product.minimum_quantity || 1 %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Max Order Qty</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @product.maximum_quantity || "No limit" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Last Updated</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @product.last_scraped_at ? @product.last_scraped_at.strftime("%b %-d, %Y %l:%M %p") : "—" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Price Updated</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @product.price_updated_at ? @product.price_updated_at.strftime("%b %-d, %Y") : "—" %></dd>
        </div>
      </dl>
    </div>
  </div>

  <%# Order Stats %>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
    <%= render "supplier_portal/shared/stat_card", label: "Total Orders", value: number_with_delimiter(@product_stats[:total_orders]) %>
    <%= render "supplier_portal/shared/stat_card", label: "Total Qty Ordered", value: number_with_delimiter(@product_stats[:total_quantity].to_i) %>
    <%= render "supplier_portal/shared/stat_card", label: "Total Revenue", value: number_to_currency(@product_stats[:total_revenue]) %>
    <%= render "supplier_portal/shared/stat_card", label: "Unique Customers", value: number_with_delimiter(@product_stats[:unique_customers]) %>
  </div>

  <%# Order History (last 90 days) %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Order History</h2>
      <p class="text-sm text-gray-500">Weekly volume and revenue — last 90 days</p>
    </div>

    <% if @order_history.any? %>
      <%# Mini bar chart — weekly quantity %>
      <div class="px-6 pt-5 pb-2">
        <% max_qty = [@order_history.map { |r| r[:quantity].to_i }.max, 1].max %>
        <div class="flex justify-between gap-1" style="height: 96px;">
          <% @order_history.each do |row| %>
            <div class="flex flex-col items-center justify-end flex-1 min-w-0" style="height: 100%;">
              <div class="w-full bg-brand-green rounded-t transition-all" style="height: <%= [(row[:quantity].to_i.to_f / max_qty * 72).round, 3].max %>px; opacity: 0.7;"></div>
              <p class="text-xs text-gray-400 mt-1 truncate w-full text-center" style="font-size: 0.6rem;"><%= row[:week].strftime('%-m/%-d') %></p>
            </div>
          <% end %>
        </div>
        <p class="text-xs text-gray-400 text-center mt-1">Weekly quantity ordered</p>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Week Of</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Quantity</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Revenue</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @order_history.each do |row| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-3 text-sm text-gray-900"><%= row[:week].strftime("%b %-d, %Y") %></td>
                <td class="px-6 py-3 text-sm text-gray-900 text-right"><%= number_with_delimiter(row[:quantity].to_i) %></td>
                <td class="px-6 py-3 text-sm text-gray-900 text-right"><%= number_to_currency(row[:revenue]) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-8 text-center text-sm text-gray-400">No order history for this product yet.</div>
    <% end %>
  </div>
</div>
