<div class="space-y-6">
  <%# Page header %>
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Analytics</h1>
    <p class="mt-1 text-sm text-gray-500">Revenue breakdown for <%= current_supplier.name %></p>
  </div>

  <%# Tabs %>
  <%= render "supplier_portal/analytics/tabs", active_tab: "revenue" %>

  <%# Date range filter %>
  <%= render "supplier_portal/analytics/date_range_filter", form_path: revenue_supplier_portal_analytics_path %>

  <%# Revenue by Day of Week %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
    <h3 class="text-sm font-medium text-gray-700 mb-4">Revenue by Day of Week</h3>
    <% if @day_of_week_data.present? && @day_of_week_data.any? { |d| d[:avg_revenue].to_f > 0 } %>
      <% max = @day_of_week_data.map { |d| d[:avg_revenue].to_f }.max %>
      <div class="flex items-end gap-1 h-48">
        <% @day_of_week_data.each do |day| %>
          <div class="flex flex-col items-center justify-end flex-1 min-w-0 h-full">
            <span class="text-xs text-gray-500 mb-1 truncate w-full text-center"><%= number_to_currency(day[:avg_revenue], precision: 0) %></span>
            <div class="w-full bg-brand-orange rounded-t transition-all"
                 style="height: <%= [(day[:avg_revenue].to_f / max * 140).round, 4].max %>px"></div>
            <span class="text-xs text-gray-400 mt-1 truncate w-full text-center"><%= day[:short_label] %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="flex items-center justify-center h-48 text-sm text-gray-400">
        No data for this period
      </div>
    <% end %>
  </div>

  <%# Revenue by Customer (Top 15) %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
    <h3 class="text-sm font-medium text-gray-700 mb-4">Revenue by Customer</h3>
    <% if @revenue_by_customer.present? && @revenue_by_customer.any? %>
      <% max_customer_revenue = @revenue_by_customer.map { |c| c.total_revenue.to_f }.max %>
      <div class="space-y-4">
        <% @revenue_by_customer.each_with_index do |customer, index| %>
          <div class="flex items-center gap-3">
            <span class="text-sm font-medium text-gray-400 w-6 text-right shrink-0"><%= index + 1 %></span>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between mb-1">
                <%= link_to customer.customer_name,
                    supplier_portal_customer_path(customer.organization_id),
                    class: "text-sm font-medium text-brand-green-dark hover:text-brand-green truncate" %>
                <div class="text-right shrink-0 ml-3">
                  <span class="text-sm font-semibold text-gray-900"><%= number_to_currency(customer.total_revenue) %></span>
                  <span class="text-xs text-gray-500 ml-1">(<%= number_with_delimiter(customer.order_count) %> orders)</span>
                </div>
              </div>
              <div class="bg-gray-100 rounded-full h-2">
                <div class="bg-brand-green h-2 rounded-full transition-all"
                     style="width: <%= (customer.total_revenue.to_f / max_customer_revenue * 100).round(1) %>%"></div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="flex items-center justify-center h-48 text-sm text-gray-400">
        No data for this period
      </div>
    <% end %>
  </div>

  <%# Revenue by Location (Top 15) %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
    <h3 class="text-sm font-medium text-gray-700 mb-4">Revenue by Location</h3>
    <% if @revenue_by_location.present? && @revenue_by_location.any? %>
      <% max_location_revenue = @revenue_by_location.map { |l| l.total_revenue.to_f }.max %>
      <div class="space-y-4">
        <% @revenue_by_location.each_with_index do |location, index| %>
          <div class="flex items-center gap-3">
            <span class="text-sm font-medium text-gray-400 w-6 text-right shrink-0"><%= index + 1 %></span>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between mb-1">
                <div class="truncate">
                  <span class="text-sm font-medium text-gray-900"><%= location.location_name %></span>
                  <span class="text-xs text-gray-500 ml-1"><%= [location.city, location.state].compact.join(", ") %></span>
                </div>
                <div class="text-right shrink-0 ml-3">
                  <span class="text-sm font-semibold text-gray-900"><%= number_to_currency(location.total_revenue) %></span>
                  <span class="text-xs text-gray-500 ml-1">(<%= number_with_delimiter(location.order_count) %> orders)</span>
                </div>
              </div>
              <div class="bg-gray-100 rounded-full h-2">
                <div class="bg-brand-green h-2 rounded-full transition-all"
                     style="width: <%= (location.total_revenue.to_f / max_location_revenue * 100).round(1) %>%"></div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="flex items-center justify-center h-48 text-sm text-gray-400">
        No data for this period
      </div>
    <% end %>
  </div>
</div>
