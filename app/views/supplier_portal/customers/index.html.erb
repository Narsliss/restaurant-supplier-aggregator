<% content_for(:title) { "Customers — #{current_supplier.name} Supplier Portal" } %>

<div class="space-y-6">
  <%# Page header %>
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Customers</h1>
    <p class="text-gray-500 mt-1"><%= number_with_delimiter(@total_customers) %> total customers</p>
  </div>

  <%# Stat cards %>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
    <%= render "supplier_portal/shared/stat_card",
        label: "Total Customers",
        value: number_with_delimiter(@total_customers) %>

    <%= render "supplier_portal/shared/stat_card",
        label: "Total Revenue",
        value: number_to_currency(@total_revenue) %>

    <%= render "supplier_portal/shared/stat_card",
        label: "Active (30d)",
        value: number_with_delimiter(@active_customers) %>

    <%= render "supplier_portal/shared/stat_card",
        label: "At Risk",
        value: number_with_delimiter(@at_risk_count) %>
  </div>

  <%# Filter bar %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
    <%= form_tag(supplier_portal_customers_path, method: :get, class: "flex flex-col sm:flex-row gap-3") do %>
      <input type="text" name="q" value="<%= params[:q] %>"
             placeholder="Search by customer name..."
             class="flex-1 rounded-lg border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm py-2.5 px-3">

      <select name="churn"
              class="rounded-lg border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm py-2.5 px-3">
        <option value="">All Customers</option>
        <option value="active" <%= 'selected' if params[:churn] == 'active' %>>Active</option>
        <option value="at_risk" <%= 'selected' if params[:churn] == 'at_risk' %>>At Risk</option>
        <option value="churned" <%= 'selected' if params[:churn] == 'churned' %>>Churned</option>
      </select>

      <button type="submit" class="inline-flex items-center rounded-lg bg-brand-green px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-brand-green-dark transition-colors cursor-pointer">
        Search
      </button>

      <% if params[:q].present? || params[:churn].present? %>
        <%= link_to "Clear", supplier_portal_customers_path,
            class: "inline-flex items-center rounded-lg border border-gray-300 px-4 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors" %>
      <% end %>
    <% end %>
  </div>

  <%# Customers table / cards %>
  <% if @customers.any? %>
    <% max_revenue = @customers.map(&:total_revenue).max.to_f %>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <%# Desktop table %>
      <div class="hidden sm:block overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">#</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Customer</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Revenue</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Orders</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Avg Value</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Last Order</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Locations</th>
              <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @customers.each_with_index do |c, i| %>
              <%= link_to supplier_portal_customer_path(c.organization), class: "contents" do %>
                <tr class="hover:bg-gray-50 cursor-pointer">
                  <td class="px-6 py-4 text-sm text-gray-400 font-medium"><%= ((@page - 1) * @per_page) + i + 1 %></td>
                  <td class="px-6 py-4 text-sm font-medium text-brand-green-dark"><%= c.organization.name %></td>
                  <td class="px-6 py-4 text-right">
                    <span class="text-sm font-medium text-gray-900"><%= number_to_currency(c.total_revenue) %></span>
                    <div class="mt-1" style="width: 100%; background-color: #e5e7eb; height: 8px; border-radius: 9999px;">
                      <div style="width: <%= max_revenue > 0 ? (c.total_revenue / max_revenue * 100).round : 0 %>%; background-color: #22c55e; height: 8px; border-radius: 9999px;"></div>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-900 text-right"><%= number_with_delimiter(c.order_count) %></td>
                  <td class="px-6 py-4 text-sm text-gray-900 text-right"><%= number_to_currency(c.avg_order_value) %></td>
                  <td class="px-6 py-4 text-sm text-gray-500 text-right">
                    <%= c.last_order_at ? time_ago_in_words(c.last_order_at) + " ago" : "—" %>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-900 text-right"><%= c.location_count %></td>
                  <td class="px-6 py-4 text-center">
                    <div class="flex items-center justify-center gap-1.5">
                      <% case c.churn_status
                         when "active" %>
                        <span style="width: 8px; height: 8px; border-radius: 9999px; background-color: #22c55e; display: inline-block;"></span>
                        <span class="text-xs text-gray-600">Active</span>
                      <% when "at_risk" %>
                        <span style="width: 8px; height: 8px; border-radius: 9999px; background-color: #facc15; display: inline-block;"></span>
                        <span class="text-xs text-gray-600">At Risk</span>
                      <% when "churned" %>
                        <span style="width: 8px; height: 8px; border-radius: 9999px; background-color: #ef4444; display: inline-block;"></span>
                        <span class="text-xs text-gray-600">Churned</span>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>

      <%# Mobile cards %>
      <div class="sm:hidden divide-y divide-gray-200">
        <% @customers.each do |c| %>
          <%= link_to supplier_portal_customer_path(c.organization), class: "block p-4 hover:bg-gray-50" do %>
            <div class="flex justify-between items-start">
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-brand-green-dark truncate"><%= c.organization.name %></p>
                <p class="text-xs text-gray-400 mt-0.5">
                  <%= c.last_order_at ? time_ago_in_words(c.last_order_at) + " ago" : "No orders" %>
                </p>
              </div>
              <div class="text-right ml-3">
                <p class="text-sm font-semibold text-gray-900"><%= number_to_currency(c.total_revenue) %></p>
                <div class="flex items-center justify-end gap-1 mt-1">
                  <% case c.churn_status
                     when "active" %>
                    <span style="width: 6px; height: 6px; border-radius: 9999px; background-color: #22c55e; display: inline-block;"></span>
                    <span class="text-xs text-gray-500">Active</span>
                  <% when "at_risk" %>
                    <span style="width: 6px; height: 6px; border-radius: 9999px; background-color: #facc15; display: inline-block;"></span>
                    <span class="text-xs text-gray-500">At Risk</span>
                  <% when "churned" %>
                    <span style="width: 6px; height: 6px; border-radius: 9999px; background-color: #ef4444; display: inline-block;"></span>
                    <span class="text-xs text-gray-500">Churned</span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# Pagination %>
    <%= render "supplier_portal/shared/pagination", page: @page, per_page: @per_page, total_count: @total_count, base_path: supplier_portal_customers_path(q: params[:q], churn: params[:churn]) %>
  <% else %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 text-center">
      <p class="text-sm text-gray-400">No customers found</p>
    </div>
  <% end %>
</div>
