<% content_for(:title) { "#{@organization.name} — Supplier Portal" } %>

<div class="space-y-8">
  <%# Breadcrumb %>
  <div>
    <%= link_to "← Customers", supplier_portal_customers_path, class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-full border border-brand-green/30 text-brand-green-dark bg-brand-green/5 hover:bg-brand-green/10 transition-colors" %>
  </div>

  <%# Header card %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-200">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <h1 class="text-2xl font-bold text-gray-900"><%= @organization.name %></h1>
          <p class="text-sm text-gray-500 mt-1">Customer since <%= @stats[:first_order_at]&.strftime("%B %Y") || "—" %></p>
        </div>
        <div>
          <% churn = if @stats[:last_order_at].nil? || @stats[:last_order_at] < 60.days.ago
                       "churned"
                     elsif @stats[:last_order_at] < 30.days.ago
                       "at_risk"
                     else
                       "active"
                     end %>
          <% case churn
             when "active" %>
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium" style="background-color: #dcfce7; color: #166534;">
              <span style="width: 8px; height: 8px; border-radius: 9999px; background-color: #22c55e; display: inline-block;"></span>
              Active
            </span>
          <% when "at_risk" %>
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium" style="background-color: #fef9c3; color: #854d0e;">
              <span style="width: 8px; height: 8px; border-radius: 9999px; background-color: #facc15; display: inline-block;"></span>
              At Risk
            </span>
          <% when "churned" %>
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium" style="background-color: #fee2e2; color: #991b1b;">
              <span style="width: 8px; height: 8px; border-radius: 9999px; background-color: #ef4444; display: inline-block;"></span>
              Churned
            </span>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# Stat cards %>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6">
    <%= render "supplier_portal/shared/stat_card",
        label: "Total Revenue",
        value: number_to_currency(@stats[:total_revenue]) %>

    <%= render "supplier_portal/shared/stat_card",
        label: "Orders",
        value: number_with_delimiter(@stats[:order_count]) %>

    <%= render "supplier_portal/shared/stat_card",
        label: "Avg Order Value",
        value: number_to_currency(@stats[:avg_order_value]) %>

    <%= render "supplier_portal/shared/stat_card",
        label: "Last Order",
        value: @stats[:last_order_at] ? time_ago_in_words(@stats[:last_order_at]) + " ago" : "—" %>

    <%= render "supplier_portal/shared/stat_card",
        label: "Locations",
        value: number_with_delimiter(@stats[:location_count]) %>
  </div>

  <%# Weekly Charts %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <%# Weekly Order Volume %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Weekly Orders</h2>
        <p class="text-sm text-gray-400">Last 90 days</p>
      </div>
      <div class="p-6">
        <% if @weekly_orders.any? %>
          <% max_orders = [@weekly_orders.values.max.to_i, 1].max %>
          <div class="flex justify-between h-48 gap-1 sm:gap-2">
            <% @weekly_orders.each do |date, count| %>
              <div class="flex flex-col items-center justify-end flex-1 min-w-0 h-full">
                <div class="w-full flex flex-col items-center">
                  <span class="text-xs text-gray-600 whitespace-nowrap font-medium mb-1"><%= count %></span>
                  <div class="w-full bg-brand-green rounded-t transition-all" style="height: <%= [(count.to_f / max_orders * 140).round, 4].max %>px"></div>
                </div>
                <p class="text-xs text-gray-400 mt-2 truncate w-full text-center"><%= date.strftime('%-m/%-d') %></p>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="h-48 flex items-center justify-center text-sm text-gray-400">No order data yet</div>
        <% end %>
      </div>
    </div>

    <%# Weekly Revenue %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Weekly Revenue</h2>
        <p class="text-sm text-gray-400">Last 90 days</p>
      </div>
      <div class="p-6">
        <% if @weekly_revenue.any? %>
          <% max_rev = [@weekly_revenue.values.max.to_f, 1].max %>
          <div class="flex justify-between h-48 gap-1 sm:gap-2">
            <% @weekly_revenue.each do |date, amount| %>
              <div class="flex flex-col items-center justify-end flex-1 min-w-0 h-full">
                <div class="w-full flex flex-col items-center">
                  <span class="text-xs text-gray-600 whitespace-nowrap font-medium mb-1"><%= number_to_currency(amount, precision: 0) %></span>
                  <div class="w-full bg-brand-orange rounded-t transition-all" style="height: <%= [(amount.to_f / max_rev * 140).round, 4].max %>px"></div>
                </div>
                <p class="text-xs text-gray-400 mt-2 truncate w-full text-center"><%= date.strftime('%-m/%-d') %></p>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="h-48 flex items-center justify-center text-sm text-gray-400">No revenue data yet</div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Top Products %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
      <h2 class="text-lg font-semibold text-gray-900">Top Products</h2>
      <span class="text-xs text-gray-400">Last 90 days</span>
    </div>

    <% if @top_products.any? %>
      <% max_product_rev = @top_products.map { |p| p.total_revenue.to_f }.max %>
      <div class="divide-y divide-gray-200">
        <% @top_products.each do |product| %>
          <div class="px-6 py-4">
            <div class="flex justify-between items-start mb-2">
              <div class="min-w-0 flex-1">
                <%= link_to product.product_name, supplier_portal_product_path(product.product_id),
                    class: "text-sm font-medium text-brand-green-dark hover:underline block truncate" %>
                <span class="text-xs text-gray-400 font-mono"><%= product.sku %></span>
              </div>
              <div class="text-right ml-4 flex-shrink-0">
                <p class="text-sm font-semibold text-gray-900"><%= number_to_currency(product.total_revenue) %></p>
                <p class="text-xs text-gray-400"><%= number_with_delimiter(product.total_qty.to_i) %> sold &middot; <%= product.order_count %> orders</p>
              </div>
            </div>
            <%# Revenue bar %>
            <div class="w-full bg-gray-100 rounded-full h-2">
              <div class="bg-brand-green h-2 rounded-full transition-all"
                   style="width: <%= max_product_rev > 0 ? (product.total_revenue.to_f / max_product_rev * 100).round : 0 %>%"></div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-8 text-center text-sm text-gray-400">No product data for this customer yet</div>
    <% end %>
  </div>

  <%# Location Breakdown %>
  <% if @locations.any? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Locations</h2>
      </div>

      <% max_loc_rev = @locations.map { |l| l.total_revenue.to_f }.max %>

      <%# Desktop table %>
      <div class="hidden sm:block overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Location</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">City / State</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Revenue</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Orders</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Last Order</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @locations.each do |loc| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= loc.location_name %></td>
                <td class="px-6 py-4 text-sm text-gray-500"><%= [loc.city, loc.state].compact.join(", ") %></td>
                <td class="px-6 py-4 text-right">
                  <span class="text-sm font-medium text-gray-900"><%= number_to_currency(loc.total_revenue) %></span>
                  <div class="mt-1" style="width: 100%; background-color: #e5e7eb; height: 6px; border-radius: 9999px;">
                    <div style="width: <%= max_loc_rev > 0 ? (loc.total_revenue.to_f / max_loc_rev * 100).round : 0 %>%; background-color: #22c55e; height: 6px; border-radius: 9999px;"></div>
                  </div>
                </td>
                <td class="px-6 py-4 text-sm text-gray-900 text-right"><%= number_with_delimiter(loc.order_count) %></td>
                <td class="px-6 py-4 text-sm text-gray-500 text-right">
                  <%= loc.last_order_at ? time_ago_in_words(loc.last_order_at) + " ago" : "—" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <%# Mobile cards %>
      <div class="sm:hidden divide-y divide-gray-200">
        <% @locations.each do |loc| %>
          <div class="p-4">
            <div class="flex justify-between items-start">
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-gray-900 truncate"><%= loc.location_name %></p>
                <p class="text-xs text-gray-400 mt-0.5"><%= [loc.city, loc.state].compact.join(", ") %></p>
              </div>
              <div class="text-right ml-3">
                <p class="text-sm font-semibold text-gray-900"><%= number_to_currency(loc.total_revenue) %></p>
                <p class="text-xs text-gray-400"><%= loc.order_count %> orders</p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Recent Orders %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Recent Orders</h2>
    </div>

    <% if @recent_orders.any? %>
      <%# Desktop table %>
      <div class="hidden sm:block overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Location</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Total</th>
              <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @recent_orders.each do |order| %>
              <%= link_to supplier_portal_order_path(order), class: "contents" do %>
                <tr class="hover:bg-gray-50 cursor-pointer">
                  <td class="px-6 py-3 text-sm text-gray-500"><%= order.submitted_at&.strftime("%-m/%-d/%y") || "—" %></td>
                  <td class="px-6 py-3 text-sm text-gray-900"><%= order.location&.name || "—" %></td>
                  <td class="px-6 py-3 text-sm font-medium text-gray-900 text-right"><%= number_to_currency(order.total_amount) %></td>
                  <td class="px-6 py-3 text-center">
                    <% if order.confirmed? %>
                      <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium" style="background-color: #dcfce7; color: #166534;">Confirmed</span>
                    <% else %>
                      <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium" style="background-color: #dbeafe; color: #1e40af;">Submitted</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>

      <%# Mobile cards %>
      <div class="sm:hidden divide-y divide-gray-200">
        <% @recent_orders.each do |order| %>
          <%= link_to supplier_portal_order_path(order), class: "block p-4 hover:bg-gray-50" do %>
            <div class="flex justify-between items-start">
              <div>
                <p class="text-sm font-medium text-gray-900"><%= order.location&.name || "—" %></p>
                <p class="text-xs text-gray-400 mt-0.5"><%= order.submitted_at&.strftime("%-m/%-d/%y") %></p>
              </div>
              <div class="text-right">
                <p class="text-sm font-semibold text-gray-900"><%= number_to_currency(order.total_amount) %></p>
                <% if order.confirmed? %>
                  <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium mt-1" style="background-color: #dcfce7; color: #166534;">Confirmed</span>
                <% else %>
                  <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium mt-1" style="background-color: #dbeafe; color: #1e40af;">Submitted</span>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-8 text-center text-sm text-gray-400">No orders yet</div>
    <% end %>
  </div>
</div>
