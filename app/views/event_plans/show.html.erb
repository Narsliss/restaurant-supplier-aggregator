<div class="py-6" data-controller="chat" data-chat-event-plan-id-value="<%= @event_plan.id %>">
  <%# Header %>
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center space-x-3">
      <%= link_to event_plans_path, class: "text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" do %>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
      <% end %>
      <h1 class="text-xl font-heading font-bold text-gray-900 dark:text-white">
        <%= @event_plan.title || "New Event Plan" %>
      </h1>
      <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
        <%= case @event_plan.status
            when 'drafting' then 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400'
            when 'finalized' then 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400'
            when 'ordered' then 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400'
            end %>">
        <%= @event_plan.status.titleize %>
      </span>
    </div>
    <div class="flex items-center space-x-2">
      <% if @event_plan.has_menu? && !@event_plan.ordered? %>
        <% unless @event_plan.finalized? %>
          <%= button_to "Finalize Menu", finalize_event_plan_path(@event_plan), method: :post, class: "inline-flex items-center px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-200 dark:border-gray-600 dark:hover:bg-gray-600" %>
        <% end %>
        <%= button_to "Build Order", build_order_event_plan_path(@event_plan), method: :post, class: "inline-flex items-center px-3 py-1.5 text-sm font-semibold text-white bg-brand-green rounded-md hover:bg-brand-green-dark transition-colors", data: { turbo_confirm: "This will create purchase orders from the menu ingredients. Continue?" } %>
      <% end %>
      <%= button_to event_plan_path(@event_plan), method: :delete, data: { turbo_confirm: "Delete this event plan and all its messages?" }, class: "inline-flex items-center px-2 py-1.5 text-sm text-gray-400 hover:text-red-500 dark:text-gray-500 dark:hover:text-red-400 transition-colors", title: "Delete plan" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
        </svg>
      <% end %>
    </div>
  </div>

  <%# Event details bar %>
  <% if @event_plan.covers || @event_plan.budget_per_cover || @event_plan.event_details["cuisine_style"] %>
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mb-4 px-4 py-2 bg-gray-50 dark:bg-gray-800 rounded-lg text-sm text-gray-600 dark:text-gray-400">
      <% if @event_plan.event_details["cuisine_style"] %>
        <span class="inline-flex items-center rounded-full bg-brand-orange/10 text-brand-orange px-2 py-0.5 text-xs font-medium"><%= @event_plan.event_details["cuisine_style"] %></span>
      <% end %>
      <% if @event_plan.covers %>
        <span><strong><%= @event_plan.covers %></strong> covers</span>
      <% end %>
      <% if @event_plan.budget_per_cover %>
        <span>&middot; <strong>$<%= number_with_precision(@event_plan.budget_per_cover, precision: 2) %></strong>/cover budget</span>
      <% end %>
      <% if @event_plan.cost_per_cover %>
        <span>&middot; <strong>$<%= number_with_precision(@event_plan.cost_per_cover, precision: 2) %></strong>/cover actual</span>
      <% end %>
      <% if @event_plan.wines.any? %>
        <span>&middot; <strong><%= @event_plan.wines.size %></strong> wines</span>
      <% end %>
    </div>
  <% end %>

  <%# Chat messages area %>
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 flex flex-col" style="height: calc(100vh - 280px); min-height: 400px;">
    <div id="message-list" class="flex-1 overflow-y-auto p-4 space-y-4" data-chat-target="messageList">
      <% if @messages.empty? %>
        <div id="welcome-message" class="text-center py-12 text-gray-500 dark:text-gray-400" data-chat-target="welcome">
          <svg class="mx-auto h-10 w-10 text-gray-400 mb-3" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
          <p class="font-medium text-gray-700 dark:text-gray-300">Describe your event</p>
          <p class="mt-2 text-sm max-w-md mx-auto">
            Tell me about your upcoming event — the wines you're serving, how many guests, your budget, and any preferences. I'll create a menu paired to your wines with real pricing from your suppliers.
          </p>
          <div class="mt-4 text-xs text-gray-400 dark:text-gray-500">
            Example: "Wine dinner next Saturday, 50 covers, $100/cover. Wines: 2020 Chablis, Sancerre Rosé, Barolo, Châteauneuf-du-Pape, Sauternes."
          </div>
        </div>
      <% end %>

      <%= turbo_stream_from @event_plan %>

      <% @messages.each do |message| %>
        <%= render "event_plan_messages/message", message: message %>
      <% end %>
    </div>

    <%# Input area %>
    <div class="border-t border-gray-200 dark:border-gray-700 p-4">
      <form data-chat-target="form" data-action="submit->chat#submit" class="flex items-end space-x-3">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <div class="flex-1">
          <textarea
            data-chat-target="input"
            data-action="keydown->chat#keydown"
            name="content"
            rows="2"
            placeholder="Describe your event, ask for changes, or refine the menu..."
            class="block w-full rounded-lg border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-brand-green focus:ring-brand-green text-sm resize-none"
          ></textarea>
        </div>
        <button type="submit" data-chat-target="submitBtn" class="inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-brand-orange rounded-lg hover:bg-brand-orange-dark transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
          </svg>
        </button>
      </form>
    </div>
  </div>
</div>
