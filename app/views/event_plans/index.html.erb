<div class="py-8">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-heading font-bold text-gray-900 dark:text-white">Menu Planner</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">AI-powered event menu planning with real supplier pricing</p>
    </div>
    <%= link_to event_plans_path, data: { turbo_method: :post }, class: "inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-brand-orange rounded-md hover:bg-brand-orange-dark transition-colors" do %>
      <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      New Event Plan
    <% end %>
  </div>

  <%# Monthly usage indicator %>
  <div class="mb-6 flex items-center justify-between px-4 py-2.5 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
    <div class="flex items-center text-sm text-gray-600 dark:text-gray-400">
      <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
      </svg>
      <span>
        <strong><%= @org.menu_plans_this_month %></strong> / <%= @org.menu_plan_monthly_limit %> plans used this month
      </span>
    </div>
    <% if @org.menu_plans_remaining <= 3 && @org.menu_plans_remaining > 0 %>
      <span class="text-xs text-amber-600 dark:text-amber-400 font-medium"><%= @org.menu_plans_remaining %> remaining</span>
    <% elsif @org.menu_plans_remaining == 0 %>
      <span class="text-xs text-red-600 dark:text-red-400 font-medium">Limit reached — resets <%= distance_of_time_in_words_to_now(Time.current.end_of_month) %> from now</span>
    <% end %>
  </div>

  <% if @event_plans.any? %>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% @event_plans.each do |plan| %>
        <div class="relative bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 hover:shadow-md transition-shadow">
          <%= link_to event_plan_path(plan), class: "block" do %>
            <div class="flex items-start justify-between">
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold text-gray-900 dark:text-white truncate">
                  <%= plan.title || "Untitled Plan" %>
                </h3>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                  <% if plan.covers %>
                    <%= plan.covers %> covers
                    <% if plan.budget_per_cover %>
                      &middot; $<%= plan.budget_per_cover %>/cover budget
                    <% end %>
                  <% else %>
                    No details yet
                  <% end %>
                </p>
              </div>
              <span class="ml-2 inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                <%= case plan.status
                    when 'drafting' then 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400'
                    when 'finalized' then 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400'
                    when 'ordered' then 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400'
                    end %>">
                <%= plan.status.titleize %>
              </span>
            </div>
            <% if plan.has_menu? %>
              <div class="mt-3 flex items-center text-sm text-gray-500 dark:text-gray-400">
                <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
                <%= plan.courses.size %> courses
                <% if plan.cost_per_cover %>
                  &middot; $<%= number_with_precision(plan.cost_per_cover, precision: 2) %>/cover
                <% end %>
              </div>
            <% end %>
            <p class="mt-2 text-xs text-gray-400 dark:text-gray-500">
              Updated <%= time_ago_in_words(plan.updated_at) %> ago
            </p>
          <% end %>
          <%= button_to event_plan_path(plan), method: :delete, data: { turbo_confirm: "Delete this event plan?" }, class: "absolute top-3 right-3 p-1.5 text-gray-300 hover:text-red-500 dark:text-gray-600 dark:hover:text-red-400 transition-colors", title: "Delete plan" do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
            </svg>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
      </svg>
      <h3 class="mt-4 text-sm font-semibold text-gray-900 dark:text-white">No event plans yet</h3>
      <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
        Describe your event and wines, and we'll generate a menu with real supplier pricing.
      </p>
      <div class="mt-6">
        <%= link_to event_plans_path, data: { turbo_method: :post }, class: "inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-brand-orange rounded-md hover:bg-brand-orange-dark transition-colors" do %>
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          Start Planning
        <% end %>
      </div>
    </div>
  <% end %>
</div>
