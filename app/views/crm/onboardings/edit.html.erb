<div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-8">
  <!-- Breadcrumb -->
  <nav class="mb-6">
    <%= link_to "Onboarding Tracker", crm_onboardings_path, class: "text-sm text-brand-green hover:text-brand-green-dark" %>
    <span class="text-sm text-gray-400 mx-1">/</span>
    <%= link_to @onboarding.lead.restaurant_name, crm_onboarding_path(@onboarding), class: "text-sm text-brand-green hover:text-brand-green-dark" %>
    <span class="text-sm text-gray-400 mx-1">/</span>
    <span class="text-sm text-gray-500">Edit</span>
  </nav>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Edit Onboarding</h1>

    <%= form_with model: @onboarding, url: crm_onboarding_path(@onboarding), class: "space-y-6" do |f| %>
      <!-- Stage -->
      <div>
        <%= f.label :stage, "Stage", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :stage,
              Crm::Onboarding::STAGES.map { |s| [Crm::Onboarding::STAGE_LABELS[s], s] },
              {},
              class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm" %>
      </div>

      <!-- Health Score -->
      <div>
        <%= f.label :health_score, "Health Score", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :health_score,
              [["Green", "green"], ["Yellow", "yellow"], ["Red", "red"]],
              {},
              class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm" %>
      </div>

      <!-- Milestone Timestamps -->
      <fieldset>
        <legend class="text-sm font-medium text-gray-700 mb-3">Milestone Timestamps</legend>
        <div class="space-y-4">
          <% Crm::Onboarding::STAGES.each do |stage| %>
            <% ts_field = "#{stage}_at" %>
            <% if @onboarding.respond_to?(ts_field) %>
              <div>
                <%= f.label ts_field, Crm::Onboarding::STAGE_LABELS[stage], class: "block text-sm font-medium text-gray-600 mb-1" %>
                <%= f.datetime_local_field ts_field,
                      class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm" %>
              </div>
            <% end %>
          <% end %>
        </div>
      </fieldset>

      <!-- Notes -->
      <div>
        <%= f.label :notes, "Notes", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :notes, rows: 6, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm", placeholder: "Add notes about this onboarding..." %>
      </div>

      <!-- Actions -->
      <div class="flex items-center justify-end space-x-3 pt-4 border-t border-gray-200">
        <%= link_to "Cancel", crm_onboarding_path(@onboarding), class: "inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 transition-colors duration-150" %>
        <%= f.submit "Save Changes", class: "inline-flex items-center rounded-md bg-brand-orange px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-orange-600 transition-colors duration-150 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
