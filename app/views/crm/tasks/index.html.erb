<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-gray-900">My Tasks</h1>
  </div>

  <!-- Overdue Tasks -->
  <div class="mb-8">
    <div class="flex items-center space-x-2 mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Overdue</h2>
      <% if @overdue.any? %>
        <span class="inline-flex items-center rounded-full bg-red-600 px-2.5 py-0.5 text-xs font-medium text-white">
          <%= @overdue.size %>
        </span>
      <% end %>
    </div>

    <% if @overdue.any? %>
      <div class="space-y-3">
        <% @overdue.each do |task| %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 flex items-center justify-between">
            <div class="min-w-0 flex-1">
              <%= link_to task.title, crm_lead_path(task.lead), class: "text-sm font-semibold text-gray-900 hover:text-brand-green truncate block" %>
              <p class="text-xs text-gray-500 mt-0.5"><%= task.lead.restaurant_name %></p>
            </div>
            <div class="flex items-center space-x-3 ml-4 flex-shrink-0">
              <span class="text-xs font-medium text-red-600"><%= task.due_date.strftime("%b %-d, %Y") %></span>
              <% case task.priority %>
              <% when "high" %>
                <span class="inline-flex items-center rounded-full bg-red-100 text-red-800 px-2 py-0.5 text-xs font-medium">High</span>
              <% when "low" %>
                <span class="inline-flex items-center rounded-full bg-blue-100 text-blue-800 px-2 py-0.5 text-xs font-medium">Low</span>
              <% else %>
                <span class="inline-flex items-center rounded-full bg-gray-100 text-gray-800 px-2 py-0.5 text-xs font-medium">Normal</span>
              <% end %>
              <%= button_to "Complete", complete_crm_lead_task_path(task.lead, task), method: :post, class: "inline-flex items-center rounded-md bg-brand-green px-3 py-1.5 text-xs font-medium text-white hover:bg-brand-green-dark transition-colors duration-150" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500">No overdue tasks.</p>
    <% end %>
  </div>

  <!-- Upcoming Tasks -->
  <div class="mb-8">
    <div class="flex items-center space-x-2 mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Upcoming</h2>
      <% if @upcoming.any? %>
        <span class="inline-flex items-center rounded-full bg-blue-600 px-2.5 py-0.5 text-xs font-medium text-white">
          <%= @upcoming.size %>
        </span>
      <% end %>
    </div>

    <% if @upcoming.any? %>
      <div class="space-y-3">
        <% @upcoming.each do |task| %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 flex items-center justify-between">
            <div class="min-w-0 flex-1">
              <%= link_to task.title, crm_lead_path(task.lead), class: "text-sm font-semibold text-gray-900 hover:text-brand-green truncate block" %>
              <p class="text-xs text-gray-500 mt-0.5"><%= task.lead.restaurant_name %></p>
            </div>
            <div class="flex items-center space-x-3 ml-4 flex-shrink-0">
              <span class="text-xs font-medium text-gray-600"><%= task.due_date.strftime("%b %-d, %Y") %></span>
              <% case task.priority %>
              <% when "high" %>
                <span class="inline-flex items-center rounded-full bg-red-100 text-red-800 px-2 py-0.5 text-xs font-medium">High</span>
              <% when "low" %>
                <span class="inline-flex items-center rounded-full bg-blue-100 text-blue-800 px-2 py-0.5 text-xs font-medium">Low</span>
              <% else %>
                <span class="inline-flex items-center rounded-full bg-gray-100 text-gray-800 px-2 py-0.5 text-xs font-medium">Normal</span>
              <% end %>
              <%= button_to "Complete", complete_crm_lead_task_path(task.lead, task), method: :post, class: "inline-flex items-center rounded-md bg-brand-green px-3 py-1.5 text-xs font-medium text-white hover:bg-brand-green-dark transition-colors duration-150" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500">No upcoming tasks.</p>
    <% end %>
  </div>

  <!-- Recently Completed Tasks -->
  <details class="mb-8">
    <summary class="flex items-center space-x-2 mb-4 cursor-pointer">
      <h2 class="text-lg font-semibold text-gray-500">Recently Completed</h2>
      <% if @completed.any? %>
        <span class="inline-flex items-center rounded-full bg-gray-400 px-2.5 py-0.5 text-xs font-medium text-white">
          <%= @completed.size %>
        </span>
      <% end %>
    </summary>

    <% if @completed.any? %>
      <div class="space-y-3">
        <% @completed.each do |task| %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 flex items-center justify-between opacity-60">
            <div class="min-w-0 flex-1">
              <span class="text-sm font-semibold text-gray-500 line-through"><%= task.title %></span>
              <p class="text-xs text-gray-400 mt-0.5"><%= task.lead.restaurant_name %></p>
            </div>
            <div class="flex items-center space-x-3 ml-4 flex-shrink-0">
              <span class="text-xs text-gray-400">Completed <%= task.completed_at.strftime("%b %-d") %></span>
              <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500">No completed tasks yet.</p>
    <% end %>
  </details>
</div>
