<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
  <!-- Breadcrumb -->
  <nav class="mb-6">
    <%= link_to "Customer Accounts", crm_customers_path, class: "text-sm text-brand-green hover:text-brand-green-dark" %>
    <span class="text-sm text-gray-400 mx-1">/</span>
    <span class="text-sm text-gray-500"><%= @lead.restaurant_name %></span>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- LEFT COLUMN -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Header -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-start justify-between flex-wrap gap-3">
          <div>
            <h1 class="text-2xl font-bold text-gray-900"><%= @lead.restaurant_name %></h1>
            <% if @lead.tags.any? %>
              <div class="flex flex-wrap gap-1 mt-2">
                <% @lead.tags.each do |tag| %>
                  <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-<%= tag.color %>-100 text-<%= tag.color %>-800">
                    <%= tag.name %>
                  </span>
                <% end %>
              </div>
            <% end %>
          </div>
          <% if @lead.onboarding.present? %>
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= @lead.onboarding.health_color %>">
              <%= @lead.onboarding.health_score.capitalize %>
            </span>
          <% end %>
        </div>
      </div>

      <!-- Why They Bought -->
      <% if @lead.pain_point.present? %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-3">Why They Bought</h2>
          <p class="text-sm text-gray-700"><%= @lead.pain_point %></p>
        </div>
      <% end %>

      <!-- Onboarding Progress -->
      <% if @lead.onboarding.present? %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-lg font-semibold text-gray-900">Onboarding Progress</h2>
            <%= link_to "View Details", crm_onboarding_path(@lead.onboarding), class: "text-sm text-brand-green hover:text-brand-green-dark font-medium" %>
          </div>

          <div class="space-y-0">
            <% current_stage_index = Crm::Onboarding::STAGES.index(@lead.onboarding.stage) %>
            <% @lead.onboarding.milestone_timestamps.each_with_index do |(stage, timestamp), index| %>
              <div class="relative flex items-start pb-5">
                <% if index < Crm::Onboarding::STAGES.size - 1 %>
                  <div class="absolute left-4 top-8 w-0.5 h-full -ml-px <%= timestamp.present? ? 'bg-green-300' : 'bg-gray-200' %>"></div>
                <% end %>

                <div class="relative flex-shrink-0">
                  <% if timestamp.present? %>
                    <div class="flex h-8 w-8 items-center justify-center rounded-full bg-green-500">
                      <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                      </svg>
                    </div>
                  <% elsif index == current_stage_index %>
                    <div class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-green ring-4 ring-brand-green/20">
                      <div class="h-2.5 w-2.5 rounded-full bg-white"></div>
                    </div>
                  <% else %>
                    <div class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-gray-300 bg-white">
                      <div class="h-2.5 w-2.5 rounded-full bg-gray-300"></div>
                    </div>
                  <% end %>
                </div>

                <div class="ml-4 min-w-0 flex-1 pt-0.5">
                  <p class="text-sm font-medium <%= index == current_stage_index ? 'text-brand-green' : (timestamp.present? ? 'text-gray-900' : 'text-gray-500') %>">
                    <%= Crm::Onboarding::STAGE_LABELS[stage] %>
                  </p>
                  <% if timestamp.present? %>
                    <p class="mt-0.5 text-xs text-gray-500"><%= timestamp.strftime("%b %-d, %Y") %></p>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Communication History -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Communication History</h2>

        <% if @activities.any? %>
          <div class="flow-root">
            <ul class="-mb-8">
              <% @activities.each_with_index do |activity, index| %>
                <li>
                  <div class="relative pb-8">
                    <% if index < @activities.size - 1 %>
                      <span class="absolute left-4 top-8 -ml-px h-full w-0.5 bg-gray-200"></span>
                    <% end %>
                    <div class="relative flex space-x-3">
                      <div>
                        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-gray-100">
                          <% case activity.activity_type %>
                          <% when "call" %>
                            <svg class="w-4 h-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                            </svg>
                          <% when "email" %>
                            <svg class="w-4 h-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                            </svg>
                          <% when "meeting" %>
                            <svg class="w-4 h-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                            </svg>
                          <% else %>
                            <svg class="w-4 h-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                            </svg>
                          <% end %>
                        </span>
                      </div>
                      <div class="flex min-w-0 flex-1 justify-between space-x-4 pt-1.5">
                        <div>
                          <p class="text-sm text-gray-900">
                            <span class="font-medium"><%= activity.type_label %></span>
                            <% if activity.description.present? %>
                              &mdash; <%= activity.description %>
                            <% end %>
                          </p>
                          <% if activity.user.present? %>
                            <p class="text-xs text-gray-500 mt-0.5">by <%= activity.user.full_name %></p>
                          <% end %>
                        </div>
                        <div class="whitespace-nowrap text-right text-xs text-gray-500">
                          <%= activity.occurred_at.strftime("%b %-d, %Y") %>
                        </div>
                      </div>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>
        <% else %>
          <p class="text-sm text-gray-500">No activities recorded yet.</p>
        <% end %>
      </div>

      <!-- Recent Orders -->
      <% if @orders.present? && @orders.any? %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Recent Orders</h2>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead>
                <tr>
                  <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                  <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
                  <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <% @orders.each do |order| %>
                  <tr>
                    <td class="px-3 py-2 text-sm text-gray-900"><%= order.created_at.strftime("%b %-d, %Y") %></td>
                    <td class="px-3 py-2 text-sm text-gray-900"><%= number_to_currency(order.respond_to?(:total_cents) ? order.total_cents / 100.0 : order.total) %></td>
                    <td class="px-3 py-2">
                      <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-800">
                        <%= order.respond_to?(:status) ? order.status.capitalize : "Placed" %>
                      </span>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>
    </div>

    <!-- RIGHT COLUMN -->
    <div class="lg:col-span-1 space-y-6">
      <!-- Contact Card -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h3 class="text-sm font-semibold text-gray-900 mb-4">Contact</h3>
        <dl class="space-y-3">
          <div>
            <dt class="text-xs text-gray-500">Name</dt>
            <dd class="text-sm text-gray-900"><%= @lead.contact_name %></dd>
          </div>
          <% if @lead.contact_role.present? %>
            <div>
              <dt class="text-xs text-gray-500">Role</dt>
              <dd class="text-sm text-gray-900"><%= @lead.contact_role %></dd>
            </div>
          <% end %>
          <% if @lead.contact_phone.present? %>
            <div>
              <dt class="text-xs text-gray-500">Phone</dt>
              <dd class="text-sm text-gray-900"><%= @lead.contact_phone %></dd>
            </div>
          <% end %>
          <% if @lead.contact_email.present? %>
            <div>
              <dt class="text-xs text-gray-500">Email</dt>
              <dd class="text-sm text-gray-900"><%= mail_to @lead.contact_email, @lead.contact_email, class: "text-brand-green hover:text-brand-green-dark" %></dd>
            </div>
          <% end %>
        </dl>
      </div>

      <!-- Suppliers -->
      <% if @lead.current_suppliers.present? %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
          <h3 class="text-sm font-semibold text-gray-900 mb-4">Current Suppliers</h3>
          <p class="text-sm text-gray-700"><%= @lead.current_suppliers %></p>
        </div>
      <% end %>

      <!-- Deal Info -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h3 class="text-sm font-semibold text-gray-900 mb-4">Deal Info</h3>
        <dl class="space-y-3">
          <% if @lead.deal_value_cents.to_i > 0 %>
            <div>
              <dt class="text-xs text-gray-500">Deal Value</dt>
              <dd class="text-sm font-medium text-gray-900"><%= number_to_currency(@lead.deal_value_dollars) %></dd>
            </div>
          <% end %>
          <% if @lead.respond_to?(:closed_at) && @lead.closed_at.present? %>
            <div>
              <dt class="text-xs text-gray-500">Closed Date</dt>
              <dd class="text-sm text-gray-900"><%= @lead.closed_at.strftime("%b %-d, %Y") %></dd>
            </div>
          <% end %>
          <div>
            <dt class="text-xs text-gray-500">Stage</dt>
            <dd>
              <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= @lead.stage_color %>">
                <%= @lead.stage_label %>
              </span>
            </dd>
          </div>
        </dl>
      </div>

      <!-- Quick Actions -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h3 class="text-sm font-semibold text-gray-900 mb-4">Quick Actions</h3>
        <div class="space-y-2">
          <% if @lead.organization.present? %>
            <%= link_to organization_path(@lead.organization), class: "flex w-full items-center justify-center rounded-md bg-brand-orange px-4 py-2 text-sm font-medium text-white hover:bg-orange-600 transition-colors duration-150" do %>
              <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819" />
              </svg>
              View Organization
            <% end %>
          <% end %>
          <%= link_to crm_lead_path(@lead), class: "flex w-full items-center justify-center rounded-md bg-brand-green px-4 py-2 text-sm font-medium text-white hover:bg-brand-green-dark transition-colors duration-150" do %>
            <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
            View Lead
          <% end %>
          <%= link_to edit_crm_lead_path(@lead), class: "flex w-full items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors duration-150" do %>
            <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
            </svg>
            Edit Lead
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
