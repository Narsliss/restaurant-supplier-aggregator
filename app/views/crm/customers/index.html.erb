<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Customer Accounts</h1>
  </div>

  <% if @leads.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @leads.each do |lead| %>
        <%= link_to crm_customer_path(lead), class: "block bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow duration-150" do %>
          <div class="flex items-start justify-between mb-3">
            <h3 class="text-sm font-semibold text-gray-900 truncate"><%= lead.restaurant_name %></h3>
            <% if lead.onboarding.present? %>
              <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= lead.onboarding.health_color %> ml-2 flex-shrink-0">
                <%= lead.onboarding.health_score.capitalize %>
              </span>
            <% end %>
          </div>

          <% if lead.contact_name.present? %>
            <p class="text-sm text-gray-600">
              <%= lead.contact_name %>
              <% if lead.contact_role.present? %>
                <span class="text-gray-400">&middot; <%= lead.contact_role %></span>
              <% end %>
            </p>
          <% end %>

          <!-- Tags -->
          <% if lead.tags.any? %>
            <div class="flex flex-wrap gap-1 mt-3">
              <% lead.tags.each do |tag| %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-<%= tag.color %>-100 text-<%= tag.color %>-800">
                  <%= tag.name %>
                </span>
              <% end %>
            </div>
          <% end %>

          <!-- Organization Status -->
          <% if lead.organization.present? %>
            <div class="mt-3 flex items-center text-xs text-gray-500">
              <svg class="w-3.5 h-3.5 mr-1 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
              </svg>
              Organization linked
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
      </svg>
      <h3 class="mt-2 text-sm font-semibold text-gray-900">No customers yet</h3>
      <p class="mt-1 text-sm text-gray-500">Customers appear here when leads are converted and linked to an organization.</p>
    </div>
  <% end %>
</div>
