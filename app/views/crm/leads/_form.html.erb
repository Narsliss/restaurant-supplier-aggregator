<%= form_with model: @lead, url: (@lead.persisted? ? crm_lead_path(@lead) : crm_leads_path) do |f| %>
  <% if @lead.errors.any? %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4 mb-6">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            Please fix <%= pluralize(@lead.errors.count, "error") %> below:
          </h3>
          <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
            <% @lead.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <%# Contact Information %>
  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Contact Information</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="sm:col-span-2">
        <%= f.label :restaurant_name, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :restaurant_name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm" %>
      </div>
      <div>
        <%= f.label :contact_name, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :contact_name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm" %>
      </div>
      <div>
        <%= f.label :contact_role, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :contact_role, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm" %>
      </div>
      <div>
        <%= f.label :phone, class: "block text-sm font-medium text-gray-700" %>
        <%= f.telephone_field :phone, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm" %>
      </div>
      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
        <%= f.email_field :email, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm" %>
      </div>
    </div>
  </div>

  <%# Location %>
  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Location</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :city, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :city, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm" %>
      </div>
      <div>
        <%= f.label :state, class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :state,
              options_for_select([
                ["", ""],
                ["Alabama", "AL"], ["Alaska", "AK"], ["Arizona", "AZ"], ["Arkansas", "AR"],
                ["California", "CA"], ["Colorado", "CO"], ["Connecticut", "CT"], ["Delaware", "DE"],
                ["Florida", "FL"], ["Georgia", "GA"], ["Hawaii", "HI"], ["Idaho", "ID"],
                ["Illinois", "IL"], ["Indiana", "IN"], ["Iowa", "IA"], ["Kansas", "KS"],
                ["Kentucky", "KY"], ["Louisiana", "LA"], ["Maine", "ME"], ["Maryland", "MD"],
                ["Massachusetts", "MA"], ["Michigan", "MI"], ["Minnesota", "MN"], ["Mississippi", "MS"],
                ["Missouri", "MO"], ["Montana", "MT"], ["Nebraska", "NE"], ["Nevada", "NV"],
                ["New Hampshire", "NH"], ["New Jersey", "NJ"], ["New Mexico", "NM"], ["New York", "NY"],
                ["North Carolina", "NC"], ["North Dakota", "ND"], ["Ohio", "OH"], ["Oklahoma", "OK"],
                ["Oregon", "OR"], ["Pennsylvania", "PA"], ["Rhode Island", "RI"], ["South Carolina", "SC"],
                ["South Dakota", "SD"], ["Tennessee", "TN"], ["Texas", "TX"], ["Utah", "UT"],
                ["Vermont", "VT"], ["Virginia", "VA"], ["Washington", "WA"], ["West Virginia", "WV"],
                ["Wisconsin", "WI"], ["Wyoming", "WY"], ["District of Columbia", "DC"]
              ], @lead.state),
              {},
              class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm" %>
      </div>
    </div>
  </div>

  <%# Deal Information %>
  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Deal Information</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :estimated_volume, class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :estimated_volume,
              options_for_select([
                ["", ""],
                ["Small", "small"],
                ["Mid", "mid"],
                ["High", "high"]
              ], @lead.estimated_volume),
              {},
              class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm" %>
      </div>
      <div>
        <%= f.label :deal_value_dollars, "Deal Value ($/mo)", class: "block text-sm font-medium text-gray-700" %>
        <%= f.number_field :deal_value_dollars, step: 0.01, min: 0,
              class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm" %>
      </div>
      <% if @lead.persisted? %>
        <div>
          <%= f.label :pipeline_stage, "Pipeline Stage", class: "block text-sm font-medium text-gray-700" %>
          <%= f.select :pipeline_stage,
                Crm::Lead::PIPELINE_STAGES.map { |s| [Crm::Lead::STAGE_LABELS[s], s] },
                {},
                class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Details %>
  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Details</h2>
    <div class="space-y-4">
      <div>
        <%= f.label :pain_point, "Pain Point", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_area :pain_point, rows: 3,
              class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm" %>
      </div>
      <div>
        <%= f.label :current_suppliers, "Current Suppliers", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_area :current_suppliers, rows: 3,
              class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm" %>
      </div>
      <div>
        <%= f.label :next_action, "Next Action", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_area :next_action, rows: 2,
              class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green sm:text-sm" %>
      </div>
    </div>
  </div>

  <%# Actions %>
  <div class="flex items-center justify-end gap-3">
    <%= link_to "Cancel",
          (@lead.persisted? ? crm_lead_path(@lead) : crm_leads_path),
          class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition" %>
    <%= f.submit (@lead.persisted? ? "Save Changes" : "Create Lead"),
          class: "px-6 py-2 bg-brand-green hover:bg-brand-green-dark text-white text-sm font-medium rounded-lg shadow-sm transition cursor-pointer" %>
  </div>
<% end %>
