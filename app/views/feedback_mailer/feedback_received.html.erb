<div style="max-width: 600px; margin: 0 auto; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1f2937;">
  <div style="padding: 32px 24px;">
    <h1 style="font-size: 24px; font-weight: 700; margin-bottom: 8px; color: #111827;">
      New Feedback: <%= @category %>
    </h1>
    <p style="font-size: 14px; color: #9ca3af; margin-bottom: 24px;">
      <%= Time.current.strftime("%B %d, %Y at %l:%M %p") %>
    </p>

    <table style="width: 100%; border-collapse: collapse; margin-bottom: 24px;">
      <tr>
        <td style="padding: 8px 0; font-size: 14px; color: #6b7280; width: 120px;">From</td>
        <td style="padding: 8px 0; font-size: 14px; font-weight: 600; color: #111827;"><%= @user.full_name %> (<%= @user.email %>)</td>
      </tr>
      <tr>
        <td style="padding: 8px 0; font-size: 14px; color: #6b7280;">Organization</td>
        <td style="padding: 8px 0; font-size: 14px; font-weight: 600; color: #111827;"><%= @organization&.name || "N/A" %></td>
      </tr>
      <tr>
        <td style="padding: 8px 0; font-size: 14px; color: #6b7280;">Category</td>
        <td style="padding: 8px 0; font-size: 14px; font-weight: 600; color: #111827;"><%= @category %></td>
      </tr>
      <% if @has_attachments %>
        <tr>
          <td style="padding: 8px 0; font-size: 14px; color: #6b7280;">Attachments</td>
          <td style="padding: 8px 0; font-size: 14px; font-weight: 600; color: #111827;">See attached files</td>
        </tr>
      <% end %>
    </table>

    <div style="border-top: 2px solid #e5e7eb; padding-top: 16px;">
      <h2 style="font-size: 14px; font-weight: 600; color: #6b7280; text-transform: uppercase; margin-bottom: 12px;">Message</h2>
      <div style="font-size: 14px; color: #1f2937; line-height: 1.6; white-space: pre-wrap; background-color: #f9fafb; padding: 16px; border-radius: 8px;"><%=
        @message %></div>
    </div>
  </div>
</div>
