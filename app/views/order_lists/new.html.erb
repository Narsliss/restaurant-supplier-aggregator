<div class="max-w-3xl mx-auto py-6">
  <div class="mb-6">
    <%= link_to "&larr; Order Lists".html_safe, order_lists_path,
        class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-full border border-brand-orange/30 text-brand-orange bg-brand-orange/5 hover:bg-brand-orange/10 transition-colors" %>
  </div>

  <h1 class="text-2xl font-heading font-bold text-gray-900 mb-6">New Order List</h1>

  <%= form_with(model: @order_list, class: "space-y-6") do |form| %>
    <% if @order_list.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h3 class="text-red-800 font-medium">Please fix the following errors:</h3>
        <ul class="mt-2 list-disc list-inside text-sm text-red-700">
          <% @order_list.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# Name + description %>
    <div class="bg-white shadow rounded-lg p-5 space-y-4">
      <div>
        <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :name, placeholder: "e.g. Monday Produce, Weekly Proteins",
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green", required: true %>
      </div>
      <div>
        <%= form.label :description, "Description (optional)", class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_area :description, rows: 2, placeholder: "What is this list for?",
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green" %>
      </div>
    </div>

    <%# Product selection from matched list %>
    <% if @product_matches.present? %>
      <div class="bg-white shadow rounded-lg p-5" data-controller="select-all">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-lg font-heading font-semibold text-gray-900">Select Products</h2>
          <label class="flex items-center gap-1.5 text-sm text-gray-500 cursor-pointer">
            <input type="checkbox" data-select-all-target="toggle" data-action="change->select-all#toggleAll"
                   class="rounded border-gray-300 text-brand-green focus:ring-brand-green">
            Select All
          </label>
        </div>
        <p class="text-sm text-gray-500 mb-3">
          <%= pluralize(@product_matches.size, "matched product") %> available from
          <span class="font-medium text-gray-700"><%= @matched_list.name %></span>
        </p>
        <div class="space-y-1 max-h-96 overflow-y-auto border border-gray-200 rounded-lg p-2" data-select-all-target="container">
          <% @product_matches.each do |pm| %>
            <label class="flex items-center gap-3 p-2 rounded hover:bg-gray-50 cursor-pointer">
              <input type="checkbox" name="product_match_ids[]" value="<%= pm.id %>"
                     data-select-all-target="checkbox"
                     class="rounded border-gray-300 text-brand-green focus:ring-brand-green">
              <span class="text-sm text-gray-900 flex-1"><%= pm.canonical_name %></span>
              <span class="text-xs text-gray-400 flex-shrink-0">
                <%= pm.product_match_items.size %> supplier<%= pm.product_match_items.size == 1 ? '' : 's' %>
              </span>
            </label>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="bg-white shadow rounded-lg p-8 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No matched products available</h3>
        <p class="mt-1 text-sm text-gray-500">Set up your matched list first, then come back to create order lists from it.</p>
        <%= link_to "Go to Product Matching &rarr;".html_safe, aggregated_lists_path,
            class: "mt-4 inline-block text-brand-orange hover:text-brand-orange-light font-medium text-sm" %>
      </div>
    <% end %>

    <div class="flex flex-col-reverse sm:flex-row sm:justify-end gap-3">
      <%= link_to "Cancel", order_lists_path,
          class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 text-center" %>
      <%= form.submit "Create Order List",
          class: "px-4 py-2 text-sm font-medium text-white bg-brand-orange rounded-md hover:bg-brand-orange-dark cursor-pointer" %>
    </div>
  <% end %>
</div>
