<div class="max-w-4xl mx-auto">
  <div class="flex flex-col gap-3 sm:flex-row sm:justify-between sm:items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Order Lists</h1>
    <%= link_to "New Order List", new_order_list_path, class: "inline-flex items-center justify-center bg-brand-orange text-white px-4 py-2 rounded-lg hover:bg-brand-orange-dark text-sm" %>
  </div>

  <% if @order_lists.any? %>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% @order_lists.each do |list| %>
        <div class="bg-white shadow rounded-lg p-5">
          <h3 class="font-semibold text-gray-900"><%= list.name %></h3>
          <p class="mt-1 text-sm text-gray-500">
            <%= pluralize(list.order_list_items.size, "item") %>
            <% if list.description.present? %>
              &middot; <%= truncate(list.description, length: 60) %>
            <% end %>
          </p>
          <div class="mt-4 space-y-2">
            <% can_edit = owner? || list.user_id == current_user.id %>
            <% if can_edit %>
              <div class="flex gap-2">
                <%= link_to "Edit Details", edit_order_list_path(list),
                    class: "flex-1 text-center rounded-md border border-gray-300 px-3 py-1.5 text-xs font-medium text-gray-700 hover:bg-gray-50 transition-colors" %>
                <%= link_to "Edit Items", order_list_path(list),
                    class: "flex-1 text-center rounded-md border border-gray-300 px-3 py-1.5 text-xs font-medium text-gray-700 hover:bg-gray-50 transition-colors" %>
              </div>
            <% end %>
            <% matched_list = @promoted_list || @aggregated_lists&.first %>
            <% if matched_list %>
              <%= link_to "Order", order_builder_aggregated_list_path(matched_list, order_list_id: list.id),
                  data: { turbo: false },
                  class: "block w-full text-center rounded-md bg-brand-green px-3 py-2 text-sm font-semibold text-white hover:bg-brand-green-dark transition-colors" %>
            <% else %>
              <span class="block w-full text-center text-sm text-gray-400 py-2">No matched list available</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-lg shadow">
      <p class="text-gray-500">No order lists yet. Create your first order list to get started.</p>
    </div>
  <% end %>
</div>
