<div class="max-w-4xl mx-auto">
  <div class="flex flex-col gap-3 sm:flex-row sm:justify-between sm:items-start mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @order_list.name %></h1>
      <% if @order_list.description.present? %>
        <p class="text-sm text-gray-500 mt-1"><%= @order_list.description %></p>
      <% end %>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Back to Lists", order_lists_path, class: "rounded-md border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors" %>
    </div>
  </div>

  <%# ===== CURRENT LIST ITEMS ===== %>
  <div class="bg-white shadow rounded-lg mb-6">
    <div class="px-4 py-3 bg-brand-green-50 border-b border-gray-200">
      <h3 class="text-sm font-bold text-brand-green-dark uppercase tracking-wide">List Items (<%= @items.size %>)</h3>
    </div>
    <% if @items.any? %>
      <div class="divide-y divide-gray-200">
        <% @items.each do |item| %>
          <div class="px-4 py-3 flex items-center justify-between gap-3">
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium text-gray-900"><%= item.display_name %></p>
              <% if item.display_unit_info.present? %>
                <p class="text-xs text-gray-500"><%= item.display_unit_info %></p>
              <% end %>
            </div>
            <% can_edit = owner? || @order_list.user_id == current_user.id %>
            <% if can_edit %>
              <%= button_to "Remove", remove_match_order_list_path(@order_list, product_match_id: item.product_match_id),
                  method: :post,
                  class: "rounded-md border border-red-200 px-3 py-1 text-xs font-medium text-red-600 hover:bg-red-50 transition-colors" %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8">
        <p class="text-gray-500">No items yet. Add products from your matched list below.</p>
      </div>
    <% end %>
  </div>

  <%# ===== AVAILABLE MATCHED PRODUCTS ===== %>
  <% can_edit = owner? || @order_list.user_id == current_user.id %>
  <% if can_edit %>
    <div class="bg-white shadow rounded-lg" data-controller="list-filter">
      <div class="px-4 py-3 bg-gray-100 border-b border-gray-200">
        <h3 class="text-sm font-bold text-gray-700 uppercase tracking-wide">
          Available Products
          <% if @available_matches.any? %>
            <span class="text-gray-500 font-normal">(<%= @available_matches.size %> remaining)</span>
          <% end %>
        </h3>
      </div>
      <% if @available_matches.any? %>
        <div class="px-5 py-4 border-b border-gray-200 bg-white">
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
              <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
            </div>
            <input type="text" placeholder="Search products to add..."
                   data-list-filter-target="input"
                   data-action="input->list-filter#filter"
                   class="block w-full rounded-lg border-gray-300 pl-10 py-2.5 text-sm shadow-sm focus:border-brand-green focus:ring-brand-green" />
          </div>
        </div>
      <% end %>
      <% if @available_matches.any? %>
        <div class="divide-y divide-gray-200 max-h-[500px] overflow-y-auto">
          <% @available_matches.each do |pm| %>
            <div class="px-4 py-3 flex items-center justify-between gap-3 hover:bg-gray-50"
                 data-list-filter-target="item"
                 data-filter-text="<%= pm.canonical_name.downcase %>">
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-gray-900"><%= pm.canonical_name %></p>
                <p class="text-xs text-gray-500">
                  <% pm.product_match_items.each_with_index do |pmi, i| %>
                    <% sp = pmi.supplier_list_item&.supplier_product %>
                    <% supplier = pmi.supplier_list_item&.supplier_list&.supplier %>
                    <% if supplier %>
                      <%= ", " if i > 0 %>
                      <span class="text-gray-400"><%= supplier.name %></span>
                    <% end %>
                  <% end %>
                </p>
              </div>
              <%= button_to "Add", add_match_order_list_path(@order_list, product_match_id: pm.id),
                  method: :post,
                  class: "rounded-md bg-brand-green px-3 py-1 text-xs font-medium text-white hover:bg-brand-green-dark transition-colors flex-shrink-0" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8">
          <% if @product_matches.blank? %>
            <p class="text-gray-500">No matched list found. Set up product matching first.</p>
          <% else %>
            <p class="text-gray-500">All matched products have been added to this list.</p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
