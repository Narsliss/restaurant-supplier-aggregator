<div class="max-w-6xl mx-auto pb-6" data-controller="order-builder"
     data-order-builder-supplier-minimums-value="<%= @supplier_minimums.to_json %>">
  <div class="mb-6">
    <%= link_to "&larr; New Order".html_safe, select_list_orders_path, class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-full border border-brand-orange/30 text-brand-orange bg-brand-orange/5 hover:bg-brand-orange/10 transition-colors" %>
  </div>

  <div class="mb-6">
    <h1 class="text-2xl font-heading font-bold text-gray-900">Build Order</h1>
    <p class="mt-1 text-sm text-gray-500"><%= @order_list.name %> &middot; <%= pluralize(@items.size, "item") %></p>
    <div class="mt-2 flex flex-wrap gap-1.5">
      <% @suppliers.each do |supplier| %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">
          <%= supplier.name %>
        </span>
      <% end %>
    </div>
  </div>

  <%= form_with(url: create_from_order_list_orders_path, method: :post, id: "order-form") do |form| %>
    <%= hidden_field_tag :order_list_id, @order_list.id %>
    <div id="supplier-overrides"></div>

    <%# Command bar %>
    <div id="order-builder-command-bar" class="bg-gray-50 py-2">
      <div class="flex items-center gap-2">
        <div class="bg-white shadow rounded-lg px-3 py-1.5 flex items-center gap-1 shrink-0">
          <span class="text-xs font-medium text-gray-500 uppercase">Items</span>
          <span class="text-lg font-bold text-gray-900" data-order-builder-target="itemCount">0</span>
        </div>
        <div class="bg-white shadow rounded-lg px-3 py-1.5 flex items-center gap-1 shrink-0">
          <span class="text-xs font-medium text-gray-500 uppercase">Total</span>
          <span class="text-lg font-bold text-gray-900" data-order-builder-target="runningTotal">$0.00</span>
        </div>
        <% @suppliers.each do |supplier| %>
          <% min_info = @supplier_minimums[supplier.id] %>
          <div class="bg-white shadow rounded-lg px-2 py-1 flex flex-col hidden" data-supplier-breakdown-id="<%= supplier.id %>">
            <div class="flex items-center justify-between gap-1">
              <span class="text-[10px] font-medium text-gray-500 uppercase truncate max-w-[80px]"><%= supplier.name %></span>
              <span class="text-xs font-bold text-gray-900 whitespace-nowrap" data-supplier-subtotal="<%= supplier.id %>">$0</span>
            </div>
            <% if min_info && min_info[:minimum] && min_info[:minimum] > 0 %>
              <div class="mt-0.5 flex items-center gap-1">
                <div class="flex-1 h-1 bg-gray-200 rounded-full overflow-hidden">
                  <div class="h-full rounded-full bg-gray-300 transition-all duration-300"
                       data-supplier-progress-bar="<%= supplier.id %>"
                       style="width: 0%"></div>
                </div>
                <span class="text-[10px] text-gray-400 whitespace-nowrap" data-supplier-minimum-label="<%= supplier.id %>">
                  / $<%= min_info[:minimum].to_i %>
                </span>
              </div>
            <% else %>
              <span class="text-[10px] text-gray-400 mt-0.5">No minimum</span>
            <% end %>
          </div>
        <% end %>
        <div class="bg-white shadow rounded-lg px-3 py-1.5 flex items-center gap-1 shrink-0">
          <span class="text-xs font-medium text-gray-500 uppercase">Delivery</span>
          <%= date_field_tag :delivery_date, Date.tomorrow, min: Date.tomorrow, max: Date.today + 30.days, required: true, class: "w-32 rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm", data: { order_builder_target: "deliveryDate" } %>
        </div>
        <div class="ml-auto shrink-0 bg-white shadow rounded-lg px-3 py-1.5 flex items-center gap-3">
          <%= link_to "Cancel", select_list_orders_path, class: "text-sm font-medium text-gray-700 hover:text-gray-900" %>
          <button type="submit"
                  disabled
                  data-order-builder-target="submitButton"
                  class="px-5 py-1.5 rounded-md text-sm font-semibold text-white shadow-sm transition-colors bg-gray-300 cursor-not-allowed">
            Create Orders
          </button>
        </div>
      </div>
    </div>

    <% if @items.any? %>
      <div class="bg-white shadow rounded-lg mb-20">
        <table class="min-w-full divide-y divide-gray-200" id="order-builder-table">
          <thead id="order-builder-thead">
            <tr>
              <th class="px-4 py-2 text-left text-xs font-medium text-white uppercase tracking-wider bg-brand-green-dark">Product</th>
              <% @suppliers.each do |supplier| %>
                <th class="px-4 py-2 text-left text-xs font-medium text-white uppercase tracking-wider bg-brand-green-dark"><%= supplier.name %></th>
              <% end %>
              <th class="px-4 py-2 text-center text-xs font-medium text-white uppercase tracking-wider bg-brand-green-dark">Qty</th>
              <th class="px-4 py-2 text-right text-xs font-medium text-white uppercase tracking-wider bg-brand-green-dark">Line Total</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white">
            <% @items.each_with_index do |item, idx| %>
              <% pm = item.product_match %>
              <% next unless pm %>
              <%
                # Find cheapest supplier for this item
                cheapest_supplier_id = nil
                cheapest_price = nil
                supplier_product_id = nil
                @suppliers.each do |supplier|
                  data = @price_data.dig(item.id, supplier.id)
                  next unless data && data[:price]
                  if cheapest_price.nil? || data[:price] < cheapest_price
                    cheapest_price = data[:price]
                    cheapest_supplier_id = supplier.id
                    supplier_product_id = data[:supplier_product]&.id
                  end
                end
              %>
              <tr class="hover:bg-gray-50"
                  data-order-builder-target="productRow"
                  data-order-builder-row
                  data-product-name="<%= pm.canonical_name&.downcase %>">
                <td class="px-4 py-3">
                  <div class="text-sm font-medium text-gray-900"><%= pm.canonical_name %></div>
                </td>
                <% @suppliers.each do |supplier| %>
                  <% data = @price_data.dig(item.id, supplier.id) %>
                  <td class="px-4 py-3">
                    <% if data && data[:price] %>
                      <button type="button"
                              class="text-left w-full group rounded px-1 py-0.5 -mx-1 transition-colors
                                     <%= supplier.id == cheapest_supplier_id ? 'ring-2 ring-brand-green bg-green-50' : 'hover:bg-gray-100' %>"
                              data-action="click->order-builder#selectSupplier"
                              data-match-id="<%= pm.id %>"
                              data-supplier-id-value="<%= supplier.id %>"
                              data-supplier-price="<%= data[:price] %>"
                              data-supplier-product-id="<%= data[:supplier_product]&.id %>"
                              data-order-builder-target="supplierCell"
                              data-default="<%= supplier.id == cheapest_supplier_id %>">
                        <span class="text-sm font-semibold text-gray-900">$<%= number_with_precision(data[:price], precision: 2) %></span>
                        <% if data[:pack_size].present? %>
                          <span class="text-xs text-gray-400 block"><%= data[:pack_size].truncate(25) %></span>
                        <% end %>
                        <% if data[:per_unit_price].present? %>
                          <span class="text-[10px] text-gray-400 block">$<%= number_with_precision(data[:per_unit_price], precision: 2) %>/unit</span>
                        <% end %>
                      </button>
                    <% else %>
                      <span class="text-xs text-gray-300">—</span>
                    <% end %>
                  </td>
                <% end %>
                <td class="px-4 py-3 text-center">
                  <div class="inline-flex items-center gap-1">
                    <button type="button"
                            data-action="order-builder#decrement"
                            class="w-7 h-7 flex items-center justify-center rounded-md border border-gray-300 text-gray-600 hover:bg-gray-200 hover:border-gray-400 hover:text-gray-900 active:bg-gray-300 transition-colors text-sm">
                      &minus;
                    </button>
                    <input type="number"
                           name="quantities[<%= pm.id %>]"
                           value="0"
                           min="0"
                           class="w-14 rounded-md border-gray-300 text-sm text-center [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
                           data-order-builder-target="quantityInput"
                           data-action="input->order-builder#updateTotals"
                           data-price="<%= cheapest_price || 0 %>"
                           data-supplier-id="<%= cheapest_supplier_id %>"
                           data-match-id="<%= pm.id %>">
                    <button type="button"
                            data-action="order-builder#increment"
                            class="w-7 h-7 flex items-center justify-center rounded-md border border-gray-300 text-gray-600 hover:bg-gray-200 hover:border-gray-400 hover:text-gray-900 active:bg-gray-300 transition-colors text-sm">
                      +
                    </button>
                    <button type="button"
                            data-action="order-builder#clearQuantity"
                            title="Clear quantity"
                            class="w-7 h-7 flex items-center justify-center rounded-md text-gray-400 hover:text-red-500 hover:bg-red-50 transition-colors ml-0.5">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                      </svg>
                    </button>
                  </div>
                </td>
                <td class="px-4 py-3 text-right">
                  <span class="text-sm font-medium text-gray-900" data-order-builder-target="lineTotal">&mdash;</span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="bg-white shadow rounded-lg p-8 text-center">
        <p class="text-gray-500">This order list is empty. Add products to it first.</p>
        <p class="mt-3">
          <%= link_to "Edit Order List", @order_list, class: "text-brand-orange hover:text-brand-orange-dark font-medium" %>
        </p>
      </div>
    <% end %>

    <%# ===== FULL MATCHED LIST (additional items not on this order list) ===== %>
    <% if @extra_matches.any? %>
      <div class="bg-white shadow rounded-lg mb-20" data-controller="list-filter">
        <div class="px-4 py-3 bg-gray-100 border-b border-gray-200">
          <h3 class="text-sm font-bold text-gray-700 uppercase tracking-wide">
            Full Matched List
            <span class="text-gray-500 font-normal">(<%= @extra_matches.size %> more products)</span>
          </h3>
          <p class="text-xs text-gray-500 mt-0.5">Add items from your full matched list that aren't on this order list.</p>
        </div>
        <div class="px-5 py-4 border-b border-gray-200 bg-white">
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
              <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
            </div>
            <input type="text" placeholder="Search matched products..."
                   data-list-filter-target="input"
                   data-action="input->list-filter#filter"
                   class="block w-full rounded-lg border-gray-300 pl-10 py-2.5 text-sm shadow-sm focus:border-brand-green focus:ring-brand-green" />
          </div>
        </div>
        <table class="min-w-full divide-y divide-gray-200">
          <thead>
            <tr>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider bg-gray-50">Product</th>
              <% @suppliers.each do |supplier| %>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider bg-gray-50"><%= supplier.name %></th>
              <% end %>
              <th class="px-4 py-2 text-center text-xs font-medium text-gray-500 uppercase tracking-wider bg-gray-50">Qty</th>
              <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase tracking-wider bg-gray-50">Line Total</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white">
            <% @extra_matches.each do |pm| %>
              <%
                cheapest_supplier_id = nil
                cheapest_price = nil
                supplier_product_id = nil
                @suppliers.each do |supplier|
                  data = @extra_price_data.dig(pm.id, supplier.id)
                  next unless data && data[:price]
                  if cheapest_price.nil? || data[:price] < cheapest_price
                    cheapest_price = data[:price]
                    cheapest_supplier_id = supplier.id
                    supplier_product_id = data[:supplier_product]&.id
                  end
                end
              %>
              <tr class="hover:bg-gray-50"
                  data-order-builder-target="productRow"
                  data-order-builder-row
                  data-product-name="<%= pm.canonical_name&.downcase %>"
                  data-list-filter-target="item"
                  data-filter-text="<%= pm.canonical_name&.downcase %>">
                <td class="px-4 py-3">
                  <div class="text-sm font-medium text-gray-900"><%= pm.canonical_name %></div>
                </td>
                <% @suppliers.each do |supplier| %>
                  <% data = @extra_price_data.dig(pm.id, supplier.id) %>
                  <td class="px-4 py-3">
                    <% if data && data[:price] %>
                      <button type="button"
                              class="text-left w-full group rounded px-1 py-0.5 -mx-1 transition-colors
                                     <%= supplier.id == cheapest_supplier_id ? 'ring-2 ring-brand-green bg-green-50' : 'hover:bg-gray-100' %>"
                              data-action="click->order-builder#selectSupplier"
                              data-match-id="<%= pm.id %>"
                              data-supplier-id-value="<%= supplier.id %>"
                              data-supplier-price="<%= data[:price] %>"
                              data-supplier-product-id="<%= data[:supplier_product]&.id %>"
                              data-order-builder-target="supplierCell"
                              data-default="<%= supplier.id == cheapest_supplier_id %>">
                        <span class="text-sm font-semibold text-gray-900">$<%= number_with_precision(data[:price], precision: 2) %></span>
                        <% if data[:pack_size].present? %>
                          <span class="text-xs text-gray-400 block"><%= data[:pack_size].truncate(25) %></span>
                        <% end %>
                        <% if data[:per_unit_price].present? %>
                          <span class="text-[10px] text-gray-400 block">$<%= number_with_precision(data[:per_unit_price], precision: 2) %>/unit</span>
                        <% end %>
                      </button>
                    <% else %>
                      <span class="text-xs text-gray-300">—</span>
                    <% end %>
                  </td>
                <% end %>
                <td class="px-4 py-3 text-center">
                  <div class="inline-flex items-center gap-1">
                    <button type="button"
                            data-action="order-builder#decrement"
                            class="w-7 h-7 flex items-center justify-center rounded-md border border-gray-300 text-gray-600 hover:bg-gray-200 hover:border-gray-400 hover:text-gray-900 active:bg-gray-300 transition-colors text-sm">
                      &minus;
                    </button>
                    <input type="number"
                           name="quantities[<%= pm.id %>]"
                           value="0"
                           min="0"
                           class="w-14 rounded-md border-gray-300 text-sm text-center [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
                           data-order-builder-target="quantityInput"
                           data-action="input->order-builder#updateTotals"
                           data-price="<%= cheapest_price || 0 %>"
                           data-supplier-id="<%= cheapest_supplier_id %>"
                           data-match-id="<%= pm.id %>">
                    <button type="button"
                            data-action="order-builder#increment"
                            class="w-7 h-7 flex items-center justify-center rounded-md border border-gray-300 text-gray-600 hover:bg-gray-200 hover:border-gray-400 hover:text-gray-900 active:bg-gray-300 transition-colors text-sm">
                      +
                    </button>
                    <button type="button"
                            data-action="order-builder#clearQuantity"
                            title="Clear quantity"
                            class="w-7 h-7 flex items-center justify-center rounded-md text-gray-400 hover:text-red-500 hover:bg-red-50 transition-colors ml-0.5">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                      </svg>
                    </button>
                  </div>
                </td>
                <td class="px-4 py-3 text-right">
                  <span class="text-sm font-medium text-gray-900" data-order-builder-target="lineTotal">&mdash;</span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  <% end %>
</div>
