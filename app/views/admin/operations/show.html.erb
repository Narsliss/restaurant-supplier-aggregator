<% content_for(:title) { "Operations — Admin — EnPlace Pro" } %>

<div class="space-y-8" data-controller="auto-refresh" data-auto-refresh-interval-value="30000">
  <%# Header %>
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Operations</h1>
    <p class="text-gray-500 mt-1">System health and scraper status</p>
  </div>

  <%# Queue Stat Cards %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
    <%= render "admin/shared/stat_card",
        label: "Queue Pending",
        value: @queue_stats[:pending],
        color: @queue_stats[:pending] > 0 ? "text-yellow-600" : "text-gray-900" %>
    <%= render "admin/shared/stat_card",
        label: "Queue Failed",
        value: @queue_stats[:failed],
        color: @queue_stats[:failed] > 0 ? "text-red-600" : "text-gray-900" %>
    <%= render "admin/shared/stat_card",
        label: "Running Jobs",
        value: @queue_stats[:running] %>
  </div>

  <%# Supplier Health Table %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Supplier Health</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Supplier</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Last Scrape</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Success Rate 24h</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Products</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Stale</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Active Creds</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Failed Creds</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @supplier_health.each do |sh| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= sh[:supplier].name %></td>
              <td class="px-6 py-4 text-sm text-gray-500">
                <% if sh[:last_scrape] %>
                  <%= time_ago_in_words(sh[:last_scrape].created_at) %> ago
                  <span class="text-gray-400">(<%= sh[:last_scrape].duration_formatted %>)</span>
                <% else %>
                  <span class="text-gray-400">Never</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm">
                <% if sh[:success_rate_24h] %>
                  <% rate_color = if sh[:success_rate_24h] >= 90
                                    "text-green-600"
                                  elsif sh[:success_rate_24h] >= 70
                                    "text-yellow-600"
                                  else
                                    "text-red-600"
                                  end %>
                  <span class="font-medium <%= rate_color %>"><%= sh[:success_rate_24h] %>%</span>
                <% else %>
                  <span class="text-gray-400">N/A</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-900 text-right"><%= sh[:total_products] %></td>
              <td class="px-6 py-4 text-sm text-right">
                <% if sh[:stale_products] > 0 %>
                  <span class="text-yellow-600 font-medium"><%= sh[:stale_products] %></span>
                <% else %>
                  <span class="text-gray-500">0</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-900 text-right"><%= sh[:active_credentials] %></td>
              <td class="px-6 py-4 text-sm text-right">
                <% if sh[:failed_credentials] > 0 %>
                  <span class="text-red-600 font-medium"><%= sh[:failed_credentials] %></span>
                <% else %>
                  <span class="text-gray-500">0</span>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @supplier_health.empty? %>
            <tr><td colspan="7" class="px-6 py-8 text-center text-sm text-gray-400">No active suppliers</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# Credential Status %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Credential Status</h2>
    <div class="flex flex-wrap gap-3">
      <% credential_colors = {
           'active'  => 'bg-green-100 text-green-800',
           'pending' => 'bg-gray-100 text-gray-800',
           'expired' => 'bg-yellow-100 text-yellow-800',
           'failed'  => 'bg-red-100 text-red-800',
           'hold'    => 'bg-blue-100 text-blue-800'
         } %>
      <% %w[active pending expired failed hold].each do |status| %>
        <% count = @credential_stats[status] || 0 %>
        <span class="rounded-full px-3 py-1 text-xs font-medium <%= credential_colors[status] %>">
          <%= status.capitalize %> &middot; <%= count %>
        </span>
      <% end %>
    </div>
  </div>

  <%# Recent Scraping Logs %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Recent Scraping Logs</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Supplier</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Imported</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Updated</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Duration</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Time</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @recent_logs.each do |log| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= log.supplier.name %></td>
              <td class="px-6 py-4">
                <% badge_color = case log.status
                     when 'completed' then 'bg-green-100 text-green-800'
                     when 'running'   then 'bg-blue-100 text-blue-800'
                     when 'failed'    then 'bg-red-100 text-red-800'
                     when 'pending'   then 'bg-gray-100 text-gray-800'
                     when 'cancelled' then 'bg-gray-100 text-gray-800'
                     else 'bg-gray-100 text-gray-800'
                     end %>
                <span class="rounded-full px-2 py-1 text-xs font-medium <%= badge_color %>"><%= log.status.capitalize %></span>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500 text-right"><%= log.products_imported || '—' %></td>
              <td class="px-6 py-4 text-sm text-gray-500 text-right"><%= log.products_updated || '—' %></td>
              <td class="px-6 py-4 text-sm text-gray-500 text-right"><%= log.duration_formatted %></td>
              <td class="px-6 py-4 text-sm text-gray-500 text-right"><%= time_ago_in_words(log.created_at) %> ago</td>
            </tr>
          <% end %>
          <% if @recent_logs.empty? %>
            <tr><td colspan="6" class="px-6 py-8 text-center text-sm text-gray-400">No scraping logs yet</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# Recent Failures %>
  <% if @recent_failures.any? %>
    <div class="bg-white rounded-xl shadow-sm border-2 border-red-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-red-200 bg-red-50">
        <h2 class="text-lg font-semibold text-red-800">Recent Failures</h2>
      </div>
      <div class="divide-y divide-gray-200">
        <% @recent_failures.each do |log| %>
          <div class="px-6 py-4">
            <div class="flex items-center justify-between">
              <span class="text-sm font-medium text-gray-900"><%= log.supplier.name %></span>
              <span class="text-sm text-gray-500"><%= time_ago_in_words(log.created_at) %> ago</span>
            </div>
            <p class="mt-1 text-sm text-red-600"><%= truncate(log.error_message, length: 100) %></p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Pending 2FA %>
  <% if @pending_2fa.any? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Pending 2FA Requests</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Supplier</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">User</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Expires In</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @pending_2fa.each do |req| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= req.supplier_credential.supplier.name %></td>
                <td class="px-6 py-4 text-sm text-gray-500"><%= req.supplier_credential.user.email %></td>
                <td class="px-6 py-4 text-sm text-gray-500 text-right"><%= time_ago_in_words(req.expires_at) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <%# List Sync Status %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">List Sync Status</h2>
    <div class="flex flex-wrap gap-3">
      <% sync_colors = {
           'synced'  => 'bg-green-100 text-green-800',
           'syncing' => 'bg-blue-100 text-blue-800',
           'pending' => 'bg-gray-100 text-gray-800',
           'failed'  => 'bg-red-100 text-red-800'
         } %>
      <% %w[synced syncing pending failed].each do |status| %>
        <% count = @list_sync_stats[status] || 0 %>
        <span class="rounded-full px-3 py-1 text-xs font-medium <%= sync_colors[status] %>">
          <%= status.capitalize %> &middot; <%= count %>
        </span>
      <% end %>
    </div>
  </div>
</div>
