<nav class="bg-brand-green-dark shadow-lg">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 justify-between">
      <div class="flex">
        <div class="flex flex-shrink-0 items-center">
          <%= link_to admin_root_path, class: "flex items-center group" do %>
            <%= render "shared/logo", variant: :nav %>
          <% end %>
        </div>
        <div class="hidden sm:ml-8 sm:flex sm:space-x-6">
          <%= link_to "Dashboard", admin_root_path,
              class: "inline-flex items-center border-b-2 #{current_admin_section == 'dashboard' ? 'border-brand-orange text-white' : 'border-transparent text-gray-300 hover:border-gray-400 hover:text-white'} px-1 pt-1 text-sm font-medium transition-colors duration-150" %>
          <%= link_to "Users", admin_users_path,
              class: "inline-flex items-center border-b-2 #{current_admin_section == 'users' ? 'border-brand-orange text-white' : 'border-transparent text-gray-300 hover:border-gray-400 hover:text-white'} px-1 pt-1 text-sm font-medium transition-colors duration-150" %>
          <%= link_to "Organizations", admin_organizations_path,
              class: "inline-flex items-center border-b-2 #{current_admin_section == 'organizations' ? 'border-brand-orange text-white' : 'border-transparent text-gray-300 hover:border-gray-400 hover:text-white'} px-1 pt-1 text-sm font-medium transition-colors duration-150" %>
          <%= link_to "Revenue", admin_revenue_path,
              class: "inline-flex items-center border-b-2 #{current_admin_section == 'revenues' ? 'border-brand-orange text-white' : 'border-transparent text-gray-300 hover:border-gray-400 hover:text-white'} px-1 pt-1 text-sm font-medium transition-colors duration-150" %>
          <%= link_to "Operations", admin_operations_path,
              class: "inline-flex items-center border-b-2 #{current_admin_section == 'operations' ? 'border-brand-orange text-white' : 'border-transparent text-gray-300 hover:border-gray-400 hover:text-white'} px-1 pt-1 text-sm font-medium transition-colors duration-150" %>
          <%= link_to "Usage", admin_usage_path,
              class: "inline-flex items-center border-b-2 #{current_admin_section == 'usages' ? 'border-brand-orange text-white' : 'border-transparent text-gray-300 hover:border-gray-400 hover:text-white'} px-1 pt-1 text-sm font-medium transition-colors duration-150" %>
          <%= link_to "Products", products_path,
              class: "inline-flex items-center border-b-2 #{controller_name == 'products' ? 'border-brand-orange text-white' : 'border-transparent text-gray-300 hover:border-gray-400 hover:text-white'} px-1 pt-1 text-sm font-medium transition-colors duration-150" %>
        </div>
      </div>

      <div class="hidden sm:ml-6 sm:flex sm:items-center sm:space-x-4">
        <%= link_to "Jobs", mission_control_jobs.root_path,
            class: "text-sm font-medium text-gray-300 hover:text-white transition-colors duration-150" %>
        <%= link_to "Exit to App", root_path,
            class: "inline-flex items-center rounded-md bg-brand-green/80 px-3 py-1.5 text-sm font-medium text-white hover:bg-brand-green transition-colors duration-150",
            data: { turbo: false } %>

        <%# Avatar dropdown %>
        <div class="relative" data-controller="dropdown">
          <button type="button"
                  class="flex rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-green focus:ring-offset-2 focus:ring-offset-brand-green-dark"
                  data-action="click->dropdown#toggle">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-orange">
              <span class="text-sm font-medium leading-none text-white"><%= current_user.full_name.first.upcase %></span>
            </span>
          </button>
          <div class="hidden absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-md bg-white py-1 shadow-lg ring-1 ring-black/5"
               data-dropdown-target="menu">
            <div class="px-4 py-2 text-sm text-brand-green-dark font-medium border-b border-gray-100">
              <%= current_user.full_name %>
              <span class="block text-xs text-gray-400 font-normal">Super Admin</span>
            </div>
            <%= link_to "Settings", edit_user_registration_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-brand-green-50 hover:text-brand-green-dark" %>
            <div class="border-t border-gray-100 mt-1 pt-1">
              <button type="button"
                      data-action="click->theme#cycle"
                      class="flex w-full items-center px-4 py-2 text-sm text-gray-700 hover:bg-brand-green-50 hover:text-brand-green-dark">
                <svg data-theme-target="lightIcon" class="w-4 h-4 mr-2 hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
                </svg>
                <svg data-theme-target="darkIcon" class="w-4 h-4 mr-2 hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
                </svg>
                <svg data-theme-target="systemIcon" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z" />
                </svg>
                <span data-theme-target="label">System</span>
              </button>
            </div>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-brand-orange hover:bg-red-50" %>
          </div>
        </div>
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center sm:hidden">
        <button type="button"
                class="inline-flex items-center justify-center rounded-md p-2 text-gray-300 hover:bg-brand-green/80 hover:text-white focus:outline-none focus:ring-2 focus:ring-inset focus:ring-brand-green"
                data-action="click->mobile-menu#toggle">
          <svg data-mobile-menu-target="openIcon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <svg data-mobile-menu-target="closeIcon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div class="hidden sm:hidden" data-mobile-menu-target="menu" data-controller="mobile-menu">
    <div class="space-y-1 px-2 pb-3 pt-2">
      <%= link_to "Dashboard", admin_root_path,
          class: "block rounded-md px-3 py-2 text-base font-medium #{current_admin_section == 'dashboard' ? 'bg-brand-green/80 text-white border-l-4 border-brand-orange' : 'text-gray-300 hover:bg-brand-green/80 hover:text-white'}" %>
      <%= link_to "Users", admin_users_path,
          class: "block rounded-md px-3 py-2 text-base font-medium #{current_admin_section == 'users' ? 'bg-brand-green/80 text-white border-l-4 border-brand-orange' : 'text-gray-300 hover:bg-brand-green/80 hover:text-white'}" %>
      <%= link_to "Organizations", admin_organizations_path,
          class: "block rounded-md px-3 py-2 text-base font-medium #{current_admin_section == 'organizations' ? 'bg-brand-green/80 text-white border-l-4 border-brand-orange' : 'text-gray-300 hover:bg-brand-green/80 hover:text-white'}" %>
      <%= link_to "Revenue", admin_revenue_path,
          class: "block rounded-md px-3 py-2 text-base font-medium #{current_admin_section == 'revenues' ? 'bg-brand-green/80 text-white border-l-4 border-brand-orange' : 'text-gray-300 hover:bg-brand-green/80 hover:text-white'}" %>
      <%= link_to "Operations", admin_operations_path,
          class: "block rounded-md px-3 py-2 text-base font-medium #{current_admin_section == 'operations' ? 'bg-brand-green/80 text-white border-l-4 border-brand-orange' : 'text-gray-300 hover:bg-brand-green/80 hover:text-white'}" %>
      <%= link_to "Usage", admin_usage_path,
          class: "block rounded-md px-3 py-2 text-base font-medium #{current_admin_section == 'usages' ? 'bg-brand-green/80 text-white border-l-4 border-brand-orange' : 'text-gray-300 hover:bg-brand-green/80 hover:text-white'}" %>
      <%= link_to "Products", products_path,
          class: "block rounded-md px-3 py-2 text-base font-medium #{controller_name == 'products' ? 'bg-brand-green/80 text-white border-l-4 border-brand-orange' : 'text-gray-300 hover:bg-brand-green/80 hover:text-white'}" %>
    </div>
    <div class="border-t border-white/10 px-4 pb-3 pt-4">
      <div class="space-y-1">
        <%= link_to "Jobs", mission_control_jobs.root_path, class: "block rounded-md px-3 py-2 text-base font-medium text-gray-300 hover:bg-brand-green/80 hover:text-white" %>
        <%= link_to "Exit to App", root_path, class: "block rounded-md px-3 py-2 text-base font-medium text-brand-orange hover:bg-brand-green/80", data: { turbo: false } %>
        <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "block w-full text-left rounded-md px-3 py-2 text-base font-medium text-brand-orange hover:bg-brand-green/80" %>
      </div>
    </div>
  </div>
</nav>
