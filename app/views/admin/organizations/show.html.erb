<% content_for(:title) { "#{@org.name} — Organizations — Admin — SupplierHub" } %>

<div class="space-y-6">
  <%# Back link %>
  <div>
    <%= link_to admin_organizations_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 transition-colors duration-150" do %>
      <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Back to Organizations
    <% end %>
  </div>

  <%# Header %>
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div class="flex items-center gap-3">
      <h1 class="text-3xl font-bold text-gray-900"><%= @org.name %></h1>
      <% unless @org.active? %>
        <span class="rounded-full px-2 py-1 text-xs font-medium bg-red-100 text-red-800">Suspended</span>
      <% end %>
    </div>

    <%# Action buttons %>
    <div class="flex flex-wrap gap-2">
      <% if @org.active? %>
        <%= button_to "Suspend", suspend_admin_organization_path(@org),
            method: :post,
            class: "inline-flex items-center rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700 transition-colors duration-150",
            data: { turbo_confirm: "Are you sure you want to suspend #{@org.name}? All members will lose access." } %>
      <% else %>
        <%= button_to "Reactivate", reactivate_admin_organization_path(@org),
            method: :post,
            class: "inline-flex items-center rounded-lg bg-green-600 px-4 py-2 text-sm font-medium text-white hover:bg-green-700 transition-colors duration-150",
            data: { turbo_confirm: "Reactivate #{@org.name}?" } %>
      <% end %>
    </div>
  </div>

  <%# Stat cards %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    <%= render "admin/shared/stat_card",
        label: "Members",
        value: "#{@stats[:member_count]} / #{@stats[:seat_limit]}" %>
    <%= render "admin/shared/stat_card",
        label: "Locations",
        value: @stats[:location_count] %>
    <%= render "admin/shared/stat_card",
        label: "Total Orders",
        value: @stats[:total_orders] %>
    <%= render "admin/shared/stat_card",
        label: "Total Spend",
        value: number_to_currency(@stats[:total_spend]) %>
  </div>

  <%# Billing Management card %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Billing Management</h2>
    </div>
    <div class="px-6 py-4 space-y-4">
      <%# Complimentary Access %>
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-sm font-medium text-gray-900">Complimentary Access</h3>
          <% if @org.complimentary? %>
            <p class="text-sm text-gray-500 mt-1">
              <span class="inline-flex items-center rounded-full bg-purple-100 text-purple-800 px-2 py-0.5 text-xs font-medium mr-2">Complimentary</span>
              <%= @org.complimentary_reason %>
            </p>
            <p class="text-xs text-gray-400 mt-0.5">
              Granted <%= @org.complimentary_granted_at&.strftime("%b %-d, %Y") %>
              <% if @org.complimentary_granted_by %>
                by <%= @org.complimentary_granted_by.full_name %>
              <% end %>
            </p>
          <% else %>
            <p class="text-sm text-gray-500 mt-1">This organization must subscribe to access the app.</p>
          <% end %>
        </div>
        <div>
          <% if @org.complimentary? %>
            <%= button_to "Revoke", revoke_complimentary_admin_organization_path(@org),
                method: :post,
                class: "inline-flex items-center rounded-lg bg-red-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-red-700 transition-colors duration-150",
                data: { turbo_confirm: "Revoke complimentary access for #{@org.name}? They will need to subscribe." } %>
          <% else %>
            <%= form_with url: grant_complimentary_admin_organization_path(@org), method: :post, class: "flex items-center gap-2" do |f| %>
              <%= f.text_field :reason, placeholder: "Reason (e.g., Beta tester)", class: "rounded-lg border-gray-300 text-sm px-3 py-1.5 focus:ring-brand-green-dark focus:border-brand-green-dark", size: 25 %>
              <%= f.submit "Grant Free Access", class: "inline-flex items-center rounded-lg bg-purple-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-purple-700 transition-colors duration-150 cursor-pointer" %>
            <% end %>
          <% end %>
        </div>
      </div>

      <% if @subscription %>
        <hr class="border-gray-200">

        <%# Trial Extension %>
        <% if @subscription.trialing? %>
          <div class="flex items-center justify-between">
            <div>
              <h3 class="text-sm font-medium text-gray-900">Trial Period</h3>
              <p class="text-sm text-gray-500 mt-1">
                Ends <%= @subscription.trial_end&.strftime("%b %-d, %Y") %>
                (<%= @subscription.trial_days_remaining %> days remaining)
              </p>
            </div>
            <%= form_with url: extend_trial_admin_organization_path(@org), method: :post, class: "flex items-center gap-2" do |f| %>
              <%= f.number_field :days, value: 14, min: 1, max: 90, class: "rounded-lg border-gray-300 text-sm px-3 py-1.5 w-20 focus:ring-brand-green-dark focus:border-brand-green-dark" %>
              <span class="text-sm text-gray-500">days</span>
              <%= f.submit "Extend Trial", class: "inline-flex items-center rounded-lg bg-blue-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-blue-700 transition-colors duration-150 cursor-pointer" %>
            <% end %>
          </div>
        <% end %>

        <%# Cancel Subscription %>
        <% if @subscription.allows_access? && !@subscription.cancel_at_period_end? %>
          <div class="flex items-center justify-between">
            <div>
              <h3 class="text-sm font-medium text-gray-900">Cancel Subscription</h3>
              <p class="text-sm text-gray-500 mt-1">Cancels at end of current billing period.</p>
            </div>
            <%= button_to "Cancel at Period End", cancel_subscription_admin_organization_path(@org),
                method: :post,
                class: "inline-flex items-center rounded-lg bg-red-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-red-700 transition-colors duration-150",
                data: { turbo_confirm: "Cancel #{@org.name}'s subscription at end of period?" } %>
          </div>
        <% end %>

        <% if @subscription.cancel_at_period_end? %>
          <div class="rounded-lg bg-yellow-50 border border-yellow-200 px-4 py-3">
            <p class="text-sm text-yellow-800">
              Subscription set to cancel on <%= @subscription.current_period_end&.strftime("%b %-d, %Y") %>.
            </p>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Subscription card %>
  <% if @subscription %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Subscription</h2>
      </div>
      <dl class="divide-y divide-gray-200">
        <div class="px-6 py-3 flex justify-between">
          <dt class="text-sm font-medium text-gray-500">Plan</dt>
          <dd class="text-sm text-gray-900"><%= @subscription.plan_name %></dd>
        </div>
        <div class="px-6 py-3 flex justify-between">
          <dt class="text-sm font-medium text-gray-500">Status</dt>
          <dd>
            <% sub_colors = {
              'active'   => 'bg-green-100 text-green-800',
              'trialing' => 'bg-blue-100 text-blue-800',
              'past_due' => 'bg-yellow-100 text-yellow-800',
              'canceled' => 'bg-red-100 text-red-800'
            } %>
            <span class="rounded-full px-2 py-1 text-xs font-medium <%= sub_colors[@subscription.status] || 'bg-gray-100 text-gray-800' %>">
              <%= @subscription.status.titleize %>
            </span>
          </dd>
        </div>
        <div class="px-6 py-3 flex justify-between">
          <dt class="text-sm font-medium text-gray-500">Amount</dt>
          <dd class="text-sm text-gray-900"><%= @subscription.formatted_amount %> / <%= @subscription.interval %></dd>
        </div>
        <div class="px-6 py-3 flex justify-between">
          <dt class="text-sm font-medium text-gray-500">Current Period</dt>
          <dd class="text-sm text-gray-900">
            <%= @subscription.current_period_start&.strftime("%b %-d, %Y") %> &mdash; <%= @subscription.current_period_end&.strftime("%b %-d, %Y") %>
          </dd>
        </div>
        <% if @subscription.trialing? && @subscription.trial_end.present? %>
          <div class="px-6 py-3 flex justify-between">
            <dt class="text-sm font-medium text-gray-500">Trial Ends</dt>
            <dd class="text-sm text-gray-900">
              <%= @subscription.trial_end.strftime("%b %-d, %Y") %>
              <span class="text-gray-400 text-xs ml-1">(<%= time_ago_in_words(@subscription.trial_end) %> from now)</span>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>
  <% end %>

  <%# Members table %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Members</h2>
    </div>
    <% if @members.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Role</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Last Sign-in</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @members.each do |membership| %>
              <% user = membership.user %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-3 text-sm font-medium text-gray-900">
                  <% display_name = [user.first_name, user.last_name].compact.join(' ').presence %>
                  <%= link_to (display_name || "—"), admin_user_path(user), class: "text-brand-green-dark hover:underline" %>
                </td>
                <td class="px-6 py-3 text-sm text-gray-500">
                  <%= user.email %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap">
                  <% role_colors = { 'owner' => 'bg-green-100 text-green-800', 'manager' => 'bg-blue-100 text-blue-800', 'chef' => 'bg-orange-100 text-orange-800' } %>
                  <span class="rounded-full px-2 py-1 text-xs font-medium <%= role_colors[membership.role] || 'bg-gray-100 text-gray-800' %>">
                    <%= membership.role.titleize %>
                  </span>
                </td>
                <td class="px-6 py-3 text-sm text-gray-500 whitespace-nowrap">
                  <% if user.current_sign_in_at.present? %>
                    <%= time_ago_in_words(user.current_sign_in_at) %> ago
                  <% else %>
                    Never
                  <% end %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap">
                  <% if user.locked_at.present? %>
                    <span class="rounded-full px-2 py-1 text-xs font-medium bg-red-100 text-red-800">Locked</span>
                  <% elsif user.current_sign_in_at.present? && user.current_sign_in_at >= 7.days.ago %>
                    <span class="rounded-full px-2 py-1 text-xs font-medium bg-green-100 text-green-800">Active</span>
                  <% elsif user.sign_in_count == 0 || user.sign_in_count.nil? %>
                    <span class="rounded-full px-2 py-1 text-xs font-medium bg-blue-100 text-blue-800">New</span>
                  <% else %>
                    <span class="rounded-full px-2 py-1 text-xs font-medium bg-gray-100 text-gray-800">Dormant</span>
                  <% end %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap text-right">
                  <div class="flex items-center justify-end gap-2">
                    <%= button_to impersonate_admin_user_path(user),
                        method: :post,
                        class: "inline-flex items-center gap-1 rounded-md bg-brand-orange/10 px-2.5 py-1 text-xs font-medium text-brand-orange hover:bg-brand-orange hover:text-white transition-colors duration-150",
                        data: { turbo_confirm: "View the app as #{user.full_name || user.email}?" } do %>
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      Impersonate
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-8 text-center text-sm text-gray-400">
        No active members.
      </div>
    <% end %>
  </div>

  <%# Pending Invitations %>
  <% if @pending_invitations.any? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Pending Invitations</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Role</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Expires</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @pending_invitations.each do |invitation| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-3 text-sm font-medium text-gray-900">
                  <%= invitation.email %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap">
                  <% role_colors = { 'owner' => 'bg-green-100 text-green-800', 'manager' => 'bg-blue-100 text-blue-800', 'chef' => 'bg-orange-100 text-orange-800' } %>
                  <span class="rounded-full px-2 py-1 text-xs font-medium <%= role_colors[invitation.role] || 'bg-gray-100 text-gray-800' %>">
                    <%= invitation.role.titleize %>
                  </span>
                </td>
                <td class="px-6 py-3 text-sm text-gray-500">
                  <%= invitation.expires_at.strftime("%b %-d, %Y") %>
                  <span class="text-gray-400 text-xs ml-1">(<%= time_ago_in_words(invitation.expires_at) %>)</span>
                </td>
                <td class="px-6 py-3 text-right">
                  <%= button_to "Resend", reinvite_admin_organization_path(@org, invitation_id: invitation.id),
                      method: :post,
                      class: "inline-flex items-center rounded-md bg-blue-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-blue-700 transition-colors duration-150" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <%# Credentials table %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Supplier Credentials</h2>
    </div>
    <% if @credentials.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Supplier</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">User</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Last Login</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @credentials.each do |cred| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-3 text-sm font-medium text-gray-900">
                  <%= cred.supplier&.name || "Unknown" %>
                </td>
                <td class="px-6 py-3 text-sm text-gray-500">
                  <%= cred.user&.full_name || "—" %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap">
                  <% cred_colors = {
                    'active'  => 'bg-green-100 text-green-800',
                    'pending' => 'bg-yellow-100 text-yellow-800',
                    'expired' => 'bg-gray-100 text-gray-800',
                    'failed'  => 'bg-red-100 text-red-800',
                    'hold'    => 'bg-red-100 text-red-800'
                  } %>
                  <span class="rounded-full px-2 py-1 text-xs font-medium <%= cred_colors[cred.status] || 'bg-gray-100 text-gray-800' %>">
                    <%= cred.status.titleize %>
                  </span>
                </td>
                <td class="px-6 py-3 text-sm text-gray-500 text-right">
                  <% if cred.last_login_at.present? %>
                    <%= time_ago_in_words(cred.last_login_at) %> ago
                  <% else %>
                    Never
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-8 text-center text-sm text-gray-400">
        No supplier credentials configured.
      </div>
    <% end %>
  </div>

  <%# Recent Orders %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Recent Orders</h2>
    </div>
    <% if @recent_orders.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">User</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Supplier</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Date</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @recent_orders.each do |order| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-3 text-sm font-medium text-gray-900">
                  <%= order.user&.full_name || "—" %>
                </td>
                <td class="px-6 py-3 text-sm text-gray-500">
                  <%= order.supplier&.name || "Unknown" %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap">
                  <% order_colors = {
                    'pending'        => 'bg-yellow-100 text-yellow-800',
                    'verifying'      => 'bg-yellow-100 text-yellow-800',
                    'price_changed'  => 'bg-yellow-100 text-yellow-800',
                    'processing'     => 'bg-blue-100 text-blue-800',
                    'pending_review' => 'bg-yellow-100 text-yellow-800',
                    'pending_manual' => 'bg-yellow-100 text-yellow-800',
                    'submitted'      => 'bg-green-100 text-green-800',
                    'confirmed'      => 'bg-green-100 text-green-800',
                    'failed'         => 'bg-red-100 text-red-800',
                    'cancelled'      => 'bg-gray-100 text-gray-800',
                    'dry_run_complete' => 'bg-blue-100 text-blue-800'
                  } %>
                  <span class="rounded-full px-2 py-1 text-xs font-medium <%= order_colors[order.status] || 'bg-gray-100 text-gray-800' %>">
                    <%= order.status.titleize %>
                  </span>
                </td>
                <td class="px-6 py-3 text-sm text-gray-900 text-right font-medium">
                  <% if order.total_amount.present? %>
                    <%= number_to_currency(order.total_amount) %>
                  <% else %>
                    —
                  <% end %>
                </td>
                <td class="px-6 py-3 text-sm text-gray-500 text-right">
                  <% if order.submitted_at.present? %>
                    <%= order.submitted_at.strftime("%b %-d, %Y") %>
                  <% else %>
                    <%= order.created_at.strftime("%b %-d, %Y") %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-8 text-center text-sm text-gray-400">
        No orders placed yet.
      </div>
    <% end %>
  </div>

  <%# Recent Invoices %>
  <% if @invoices.any? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Recent Invoices</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Invoice ID</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Paid At</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @invoices.each do |invoice| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-3 text-sm font-medium text-gray-900 font-mono">
                  <% if invoice.hosted_invoice_url.present? %>
                    <%= link_to invoice.stripe_invoice_id, invoice.hosted_invoice_url, target: "_blank", rel: "noopener", class: "text-brand-green-dark hover:underline" %>
                  <% else %>
                    <%= invoice.stripe_invoice_id %>
                  <% end %>
                </td>
                <td class="px-6 py-3 text-sm text-gray-900 text-right font-medium">
                  <% if invoice.paid? %>
                    <%= invoice.formatted_amount_paid %>
                  <% else %>
                    <%= invoice.formatted_amount_due %>
                  <% end %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap">
                  <% invoice_colors = {
                    'paid'  => 'bg-green-100 text-green-800',
                    'open'  => 'bg-yellow-100 text-yellow-800',
                    'draft' => 'bg-gray-100 text-gray-800'
                  } %>
                  <span class="rounded-full px-2 py-1 text-xs font-medium <%= invoice_colors[invoice.status] || 'bg-gray-100 text-gray-800' %>">
                    <%= invoice.status.titleize %>
                  </span>
                </td>
                <td class="px-6 py-3 text-sm text-gray-500 text-right">
                  <% if invoice.paid_at.present? %>
                    <%= invoice.paid_at.strftime("%b %-d, %Y") %>
                  <% else %>
                    —
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>
