<% content_for(:title) { "Supplier Portal Users — Admin — EnPlace Pro" } %>

<div class="space-y-6">
  <%# Header %>
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Supplier Portal Users</h1>
      <p class="text-gray-500 mt-1"><%= @supplier_users.size %> users across all suppliers</p>
    </div>
    <%= link_to "Invite Supplier User", new_admin_supplier_portal_user_path,
        class: "inline-flex items-center gap-1.5 rounded-lg bg-brand-orange px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-orange-dark transition-colors" %>
  </div>

  <% flash.each do |type, message| %>
    <% next if message.blank? %>
    <div class="rounded-lg border px-4 py-3 text-sm
      <%= type.to_s == 'alert' ? 'bg-red-50 border-red-200 text-red-700' : 'bg-blue-50 border-blue-200 text-blue-700' %>">
      <%= message %>
    </div>
  <% end %>

  <%# Users table %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Active Users</h2>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Supplier</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Role</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Last Sign-in</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @supplier_users.each do |su| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= su.full_name %></td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= su.email %></td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= su.supplier.name %></td>
              <td class="px-6 py-4">
                <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium <%= su.admin? ? 'bg-purple-100 text-purple-800' : 'bg-blue-100 text-blue-800' %>">
                  <%= su.role.capitalize %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500">
                <% if su.current_sign_in_at.present? %>
                  <%= time_ago_in_words(su.current_sign_in_at) %> ago
                <% else %>
                  Never
                <% end %>
              </td>
              <td class="px-6 py-4 text-center">
                <% if !su.active? %>
                  <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Inactive</span>
                <% elsif su.locked_at.present? %>
                  <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Locked</span>
                <% elsif su.invitation_accepted_at.blank? %>
                  <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Pending</span>
                <% else %>
                  <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Active</span>
                <% end %>
              </td>
            </tr>
          <% end %>

          <% if @supplier_users.empty? %>
            <tr>
              <td colspan="6" class="px-6 py-12 text-center text-sm text-gray-400">
                No supplier portal users yet. Invite your first supplier user above.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# Pending Invitations %>
  <% if @pending_invitations.any? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <div class="flex items-center gap-3">
          <h2 class="text-lg font-semibold text-gray-900">Pending Invitations</h2>
          <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800"><%= @pending_invitations.size %></span>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Supplier</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Role</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Sent</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Expires</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Link</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @pending_invitations.each do |inv| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-sm text-gray-900"><%= inv.email %></td>
                <td class="px-6 py-4 text-sm text-gray-500"><%= inv.supplier.name %></td>
                <td class="px-6 py-4">
                  <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium <%= inv.role == 'admin' ? 'bg-purple-100 text-purple-800' : 'bg-blue-100 text-blue-800' %>">
                    <%= inv.role.capitalize %>
                  </span>
                </td>
                <td class="px-6 py-4 text-sm text-gray-500"><%= time_ago_in_words(inv.created_at) %> ago</td>
                <td class="px-6 py-4 text-sm text-gray-500">
                  <% if inv.expires_at > Time.current %>
                    <span class="text-gray-900">in <%= time_ago_in_words(inv.expires_at) %></span>
                  <% else %>
                    <span class="text-red-600">Expired</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 text-sm">
                  <button type="button"
                          onclick="navigator.clipboard.writeText('<%= accept_supplier_portal_invitation_url(token: inv.token) %>')"
                          class="text-brand-green-dark hover:underline text-sm font-medium cursor-pointer">
                    Copy Link
                  </button>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>
