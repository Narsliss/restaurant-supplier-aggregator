<% content_for(:title) { "Admin Dashboard — SupplierHub" } %>

<div class="space-y-8">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Admin Dashboard</h1>
    <p class="text-gray-500 mt-1"><%= Time.current.strftime("%A, %B %-d, %Y") %></p>
  </div>

  <%# Alerts %>
  <% if @alerts.any? %>
    <div class="space-y-3">
      <% @alerts.each do |alert| %>
        <% bg, border, text, icon_color = case alert[:level]
           when :error   then %w[bg-red-50 border-red-200 text-red-800 text-red-600]
           when :warning then %w[bg-yellow-50 border-yellow-200 text-yellow-800 text-yellow-600]
           else               %w[bg-blue-50 border-blue-200 text-blue-800 text-blue-600]
           end %>
        <div class="<%= bg %> border <%= border %> rounded-lg px-4 py-3 flex items-center">
          <svg class="h-5 w-5 <%= icon_color %> mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
          </svg>
          <span class="text-sm font-medium <%= text %>"><%= alert[:message] %></span>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Top-line stat cards %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    <% user_change = @new_users_prev_30 > 0 ? (((@new_users_30d - @new_users_prev_30).to_f / @new_users_prev_30) * 100).round : nil %>
    <%= render "admin/shared/stat_card",
        label: "Total Users",
        value: @stats[:total_users],
        change: @new_users_30d > 0 ? "+#{@new_users_30d} last 30d#{user_change ? " (#{user_change > 0 ? '+' : ''}#{user_change}%)" : ''}" : nil %>
    <%= render "admin/shared/stat_card",
        label: "Organizations",
        value: @stats[:total_organizations],
        change: @new_orgs_30d > 0 ? "+#{@new_orgs_30d} last 30d" : nil %>
    <%= render "admin/shared/stat_card",
        label: "Active Subscriptions",
        value: @stats[:active_subscriptions] %>
    <% rate = @stats[:scraper_success_rate] %>
    <%= render "admin/shared/stat_card",
        label: "Scraper Success (24h)",
        value: rate ? "#{rate}%" : "N/A",
        color: rate.nil? ? "text-gray-400" : (rate >= 90 ? "text-green-600" : (rate >= 70 ? "text-yellow-600" : "text-red-600")) %>
  </div>

  <%# Recent activity %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <%# Recent Signups %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
        <h2 class="text-lg font-semibold text-gray-900">Recent Signups</h2>
        <%= link_to "View all", admin_users_path, class: "text-sm text-brand-green-dark hover:underline" %>
      </div>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Signed Up</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @recent_signups.each do |user| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm font-medium text-gray-900">
                <%= link_to user.full_name, admin_user_path(user), class: "text-brand-green-dark hover:underline" %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= user.email %></td>
              <td class="px-6 py-4 text-sm text-gray-500 text-right"><%= time_ago_in_words(user.created_at) %> ago</td>
            </tr>
          <% end %>
          <% if @recent_signups.empty? %>
            <tr><td colspan="3" class="px-6 py-8 text-center text-sm text-gray-400">No signups yet</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# Recent Logins %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Recent Logins</h2>
      </div>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Last Login</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @recent_logins.each do |user| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm font-medium text-gray-900">
                <%= link_to user.full_name, admin_user_path(user), class: "text-brand-green-dark hover:underline" %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= user.email %></td>
              <td class="px-6 py-4 text-sm text-gray-500 text-right"><%= time_ago_in_words(user.current_sign_in_at) %> ago</td>
            </tr>
          <% end %>
          <% if @recent_logins.empty? %>
            <tr><td colspan="3" class="px-6 py-8 text-center text-sm text-gray-400">No logins yet</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
