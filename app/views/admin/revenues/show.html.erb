<% content_for(:title) { "Revenue — Admin — SupplierHub" } %>

<div class="space-y-8">
  <%# Header %>
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Revenue</h1>
    <p class="text-gray-500 mt-1">Subscription metrics and billing overview</p>
  </div>

  <%# Stat cards %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    <%= render "admin/shared/stat_card",
        label: "MRR",
        value: number_to_currency(@mrr) %>
    <%= render "admin/shared/stat_card",
        label: "Active Subscriptions",
        value: @active_count %>
    <%= render "admin/shared/stat_card",
        label: "Trialing",
        value: @trialing_count,
        color: @trialing_count > 0 ? "text-blue-600" : "text-gray-900" %>
    <%= render "admin/shared/stat_card",
        label: "Past Due",
        value: @past_due_count,
        color: @past_due_count > 0 ? "text-red-600" : "text-gray-900" %>
  </div>

  <%# Monthly Revenue Chart %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Monthly Revenue (Last 12 Months)</h2>
    </div>
    <div class="p-6">
      <% if @monthly_revenue.any? %>
        <% max_rev = [@monthly_revenue.map(&:last).max.to_i, 1].max %>
        <div class="flex items-end justify-between h-48 gap-2">
          <% @monthly_revenue.each do |date, amount| %>
            <div class="flex flex-col items-center flex-1">
              <div class="w-full relative" style="height: <%= [(amount / max_rev.to_f * 100).round, 2].max %>%">
                <div class="absolute -top-6 left-1/2 transform -translate-x-1/2 text-xs text-gray-600 whitespace-nowrap">
                  <%= number_to_currency(amount, precision: 0) %>
                </div>
                <div class="w-full h-full bg-brand-green rounded-t"></div>
              </div>
              <p class="text-xs text-gray-500 mt-2"><%= date.strftime('%b') %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="h-48 flex items-center justify-center text-sm text-gray-400">
          No revenue data available yet.
        </div>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <%# Subscription Status Breakdown %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Subscription Status Breakdown</h2>
      </div>
      <% if @sub_by_status.any? %>
        <% total_subs = [@sub_by_status.values.sum, 1].max %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Count</th>
                <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Percentage</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <% @sub_by_status.each do |status, count| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-3 whitespace-nowrap">
                    <% status_colors = {
                      'active'              => 'bg-green-100 text-green-800',
                      'trialing'            => 'bg-blue-100 text-blue-800',
                      'past_due'            => 'bg-yellow-100 text-yellow-800',
                      'canceled'            => 'bg-red-100 text-red-800',
                      'incomplete'          => 'bg-gray-100 text-gray-800',
                      'incomplete_expired'  => 'bg-gray-100 text-gray-800',
                      'unpaid'              => 'bg-red-100 text-red-800',
                      'paused'              => 'bg-gray-100 text-gray-800'
                    } %>
                    <span class="rounded-full px-2 py-1 text-xs font-medium <%= status_colors[status] || 'bg-gray-100 text-gray-800' %>">
                      <%= status.titleize %>
                    </span>
                  </td>
                  <td class="px-6 py-3 text-sm text-gray-900 text-right font-medium">
                    <%= count %>
                  </td>
                  <td class="px-6 py-3 text-sm text-gray-500 text-right">
                    <%= ((count.to_f / total_subs) * 100).round(1) %>%
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="px-6 py-8 text-center text-sm text-gray-400">
          No subscriptions yet.
        </div>
      <% end %>
    </div>

    <%# Trials Expiring Soon %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Trials Expiring Soon</h2>
      </div>
      <% if @trials_expiring.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">User</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Organization</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Trial End</th>
                <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Days Left</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <% @trials_expiring.each do |sub| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-3 text-sm font-medium text-gray-900">
                    <% display_name = [sub.user.first_name, sub.user.last_name].compact.join(' ').presence || sub.user.email %>
                    <%= link_to display_name, admin_user_path(sub.user), class: "text-brand-green-dark hover:underline" %>
                  </td>
                  <td class="px-6 py-3 text-sm text-gray-500">
                    <%= sub.user.current_organization&.name || "—" %>
                  </td>
                  <td class="px-6 py-3 text-sm text-gray-500">
                    <%= sub.trial_end.strftime("%b %-d, %Y") %>
                  </td>
                  <td class="px-6 py-3 text-sm text-right">
                    <% days_left = ((sub.trial_end - Time.current) / 1.day).ceil %>
                    <span class="font-medium <%= days_left <= 2 ? 'text-red-600' : 'text-yellow-600' %>">
                      <%= days_left %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="px-6 py-8 text-center text-sm text-gray-400">
          No trials expiring in the next 7 days.
        </div>
      <% end %>
    </div>
  </div>

  <%# Recent Invoices %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Recent Invoices</h2>
    </div>
    <% if @recent_invoices.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Invoice</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">User</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Date</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @recent_invoices.each do |invoice| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-3 text-sm font-medium text-gray-900 font-mono">
                  <% if invoice.hosted_invoice_url.present? %>
                    <%= link_to invoice.stripe_invoice_id, invoice.hosted_invoice_url, target: "_blank", rel: "noopener", class: "text-brand-green-dark hover:underline" %>
                  <% else %>
                    <%= invoice.stripe_invoice_id %>
                  <% end %>
                </td>
                <td class="px-6 py-3 text-sm text-gray-500">
                  <% if invoice.user.present? %>
                    <% display_name = [invoice.user.first_name, invoice.user.last_name].compact.join(' ').presence || invoice.user.email %>
                    <%= link_to display_name, admin_user_path(invoice.user), class: "text-brand-green-dark hover:underline" %>
                  <% else %>
                    —
                  <% end %>
                </td>
                <td class="px-6 py-3 text-sm text-gray-900 text-right font-medium">
                  <% if invoice.paid? %>
                    <%= invoice.formatted_amount_paid %>
                  <% else %>
                    <%= invoice.formatted_amount_due %>
                  <% end %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap">
                  <% invoice_colors = {
                    'paid'  => 'bg-green-100 text-green-800',
                    'open'  => 'bg-yellow-100 text-yellow-800',
                    'draft' => 'bg-gray-100 text-gray-800'
                  } %>
                  <span class="rounded-full px-2 py-1 text-xs font-medium <%= invoice_colors[invoice.status] || 'bg-gray-100 text-gray-800' %>">
                    <%= invoice.status.titleize %>
                  </span>
                </td>
                <td class="px-6 py-3 text-sm text-gray-500 text-right">
                  <%= invoice.created_at.strftime("%b %-d, %Y") %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-8 text-center text-sm text-gray-400">
        No invoices yet.
      </div>
    <% end %>
  </div>
</div>
