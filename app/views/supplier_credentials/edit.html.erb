<% if params[:from_wizard].present? %>
  <%# Wizard-frame mode: render the form chrome wrapped in the matching
      turbo-frame so the parent panel's frame swaps in this content. %>
  <turbo-frame id="onboarding-supplier-form">
    <div class="onboarding-supplier-form-inner">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold text-gray-900">
          Reconnect <%= @credential.supplier&.name %>
        </h3>
        <button type="button"
                data-action="click->onboarding-wizard#backToPicker"
                class="text-xs text-gray-500 hover:text-gray-700 underline">
          ← Back to suppliers
        </button>
      </div>
      <% if @credential.last_error.present? %>
        <div class="mb-3 text-xs text-red-700 bg-red-50 border border-red-200 rounded-md px-3 py-2">
          Last error: <%= @credential.last_error %>
        </div>
      <% end %>
      <%= render "form", credential: @credential %>
    </div>
  </turbo-frame>
<% else %>
  <div class="max-w-lg mx-auto py-8 px-4">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-gray-900">Edit Supplier Credential</h1>
      <p class="text-sm text-gray-500 mt-1">Update your login details for <strong><%= @credential.supplier&.name %></strong>.</p>
    </div>
    <div class="bg-white shadow rounded-lg p-6">
      <%= render "form", credential: @credential %>
    </div>
  </div>
<% end %>
