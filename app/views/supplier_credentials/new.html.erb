<% if params[:from_wizard].present? %>
  <%# Wizard-frame mode: render just the form chrome wrapped in the matching
      turbo-frame so the parent panel's frame swaps in this content. %>
  <turbo-frame id="onboarding-supplier-form">
    <div class="onboarding-supplier-form-inner">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold text-gray-900">Add Supplier Credential</h3>
        <button type="button"
                data-action="click->onboarding-wizard#backToPicker"
                class="text-xs text-gray-500 hover:text-gray-700 underline">
          ← Back to suppliers
        </button>
      </div>
      <%= render "form", credential: @credential %>
    </div>
  </turbo-frame>
<% else %>
  <div class="max-w-lg mx-auto py-8 px-4">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-gray-900">Add Supplier Credential</h1>
      <p class="text-sm text-gray-500 mt-1">Connect a supplier account to import products and order guides.</p>
    </div>
    <div class="bg-white shadow rounded-lg p-6">
      <%= render "form", credential: @credential %>
    </div>
  </div>
<% end %>
