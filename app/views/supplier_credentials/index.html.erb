<div class="max-w-7xl mx-auto">
  <div class="flex flex-col gap-3 sm:flex-row sm:justify-between sm:items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Supplier Credentials</h1>
    <div class="flex items-center gap-2">
      <% if owner? %>
        <%= link_to organization_path(anchor: "case-minimums"), class: "inline-flex items-center justify-center border border-amber-300 text-amber-700 bg-amber-50 px-4 py-2 rounded-lg hover:bg-amber-100 text-sm" do %>
          <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"/></svg>
          Set Case Minimums
        <% end %>
      <% end %>
      <%= link_to "Add Credential", new_supplier_credential_path, class: "inline-flex items-center justify-center bg-brand-orange text-white px-4 py-2 rounded-lg hover:bg-brand-orange-dark text-sm" %>
    </div>
  </div>

  <% if @credentials.any? %>
    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      <% @credentials.each do |credential| %>
        <% pending_2fa = @pending_2fa[credential.id] %>
        <% needs_reconnect = (credential.active? && !credential.session_valid? && credential.supplier.no_password_required?) || credential.failed? %>
        <% fully_healthy = credential.active? && (credential.session_valid? || credential.supplier.password_auth?) %>
        <div class="bg-white shadow rounded-lg p-4 flex flex-col"
             data-controller="credential-validator"
             data-credential-validator-credential-id-value="<%= credential.id %>"
             data-credential-validator-status-url-value="<%= status_supplier_credential_path(credential, format: :json) %>"
             data-credential-validator-validate-url-value="<%= validate_supplier_credential_path(credential, format: :json) %>"
             data-credential-validator-submit-code-url-value="<%= submit_2fa_code_supplier_credential_path(credential, format: :json) %>"
             data-credential-validator-importing-value="<%= credential.importing? %>"
             data-credential-validator-credential-status-value="<%= credential.status %>">

          <%# Header: supplier name %>
          <h3 class="text-base font-semibold text-gray-900 truncate"><%= credential.supplier.name %></h3>

          <%# Username %>
          <p class="text-xs text-gray-500 mt-0.5 truncate">
            <% if credential.supplier.welcome_url_auth? %>
              <span title="<%= credential.username %>">Welcome URL configured</span>
            <% else %>
              <%= credential.username %>
            <% end %>
          </p>

          <%# Status badges %>
          <div class="flex flex-wrap items-center gap-1.5 mt-2">
            <% case credential.status %>
            <% when "active" %>
              <span data-credential-validator-target="statusBadge" class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Active</span>
            <% when "invalid" %>
              <span data-credential-validator-target="statusBadge" class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Invalid</span>
            <% when "failed" %>
              <span data-credential-validator-target="statusBadge" class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Failed</span>
            <% else %>
              <% if pending_2fa %>
                <span data-credential-validator-target="statusBadge" class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">Awaiting Code</span>
              <% else %>
                <span data-credential-validator-target="statusBadge" class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800"><%= credential.status.titleize %></span>
              <% end %>
            <% end %>
            <% if credential.active? %>
              <% if credential.session_valid? || credential.supplier.password_auth? %>
                <span data-session-badge class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700" title="Live price verification will work.">
                  <svg class="w-3 h-3 mr-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  Connected
                </span>
              <% else %>
                <span data-session-badge class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-700" title="Session expired. Click Validate to reconnect.">
                  <svg class="w-3 h-3 mr-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                  Disconnected
                </span>
              <% end %>
            <% end %>
          </div>

          <%# Metadata %>
          <div class="mt-2 space-y-0.5">
            <% last_catalog_update = @catalog_last_synced[credential.supplier_id] %>
            <% if last_catalog_update.present? %>
              <p class="text-xs text-gray-400">Catalog: <%= @catalog_product_counts[credential.supplier_id] || 0 %> products · <%= time_ago_in_words(last_catalog_update) %> ago</p>
            <% elsif credential.active? %>
              <p class="text-xs text-gray-400">Catalog sync pending</p>
            <% end %>
            <% if credential.last_login_at.present? %>
              <p class="text-xs text-gray-400">Last login: <%= time_ago_in_words(credential.last_login_at) %> ago</p>
            <% end %>
          </div>

          <%# Status message block — shown during validating/verifying states %>
          <div data-credential-validator-target="statusBlock" class="hidden mt-3 p-2.5 bg-blue-50 border border-blue-200 rounded-lg">
            <div class="flex items-start gap-2">
              <svg data-credential-validator-target="statusSpinner" class="animate-spin w-4 h-4 text-blue-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
              <div>
                <p data-credential-validator-target="statusTitle" class="text-xs font-medium text-blue-800"></p>
                <p data-credential-validator-target="statusDetail" class="text-xs text-blue-600 mt-0.5"></p>
              </div>
            </div>
          </div>

          <%# Error block %>
          <div data-credential-validator-target="errorBlock" class="mt-2 p-2 bg-red-50 border border-red-200 rounded text-xs text-red-700 <%= 'hidden' unless credential.status == 'failed' && credential.last_error.present? %>">
            <p class="font-medium">Validation Error:</p>
            <p data-credential-validator-target="errorText" class="mt-0.5 break-words"><%= credential.last_error %></p>
          </div>

          <% if credential.on_hold? && credential.hold_reason.present? %>
            <p class="text-xs text-yellow-600 mt-1">Hold: <%= credential.hold_reason %></p>
          <% end %>

          <%# Recovery banner for disconnected 2FA suppliers %>
          <% if credential.active? && !credential.session_valid? && credential.supplier.no_password_required? %>
            <div data-reconnect-banner class="mt-2 p-2 bg-red-50 border border-red-200 rounded-lg">
              <p class="text-xs font-medium text-red-800">Session expired</p>
              <p class="text-xs text-red-600 mt-0.5">Click <strong>Validate</strong> then enter the code sent to your email/phone.</p>
            </div>
          <% end %>

          <%# Recovery banner for failed password-based suppliers %>
          <% if credential.failed? && credential.supplier.password_auth? %>
            <div data-reconnect-banner class="mt-2 p-2 bg-red-50 border border-red-200 rounded-lg">
              <p class="text-xs font-medium text-red-800">Login failed</p>
              <p class="text-xs text-red-600 mt-0.5">Try <strong>Validate</strong> to re-test, or <strong>Edit</strong> to update credentials.</p>
            </div>
          <% end %>

          <%# Spacer to push actions to bottom %>
          <div class="flex-1"></div>

          <%# Action buttons — compact grid for card layout %>
          <div class="flex flex-wrap items-center gap-1.5 mt-3 pt-3 border-t border-gray-100">
            <button type="button"
                    data-credential-validator-target="validateBtn"
                    data-action="click->credential-validator#startValidation"
                    class="<%= fully_healthy ? 'hidden' : 'inline-flex' %> items-center px-2.5 py-1 text-xs font-medium rounded-md border transition-colors <%= needs_reconnect ? 'border-red-400 bg-red-50 text-red-700 hover:bg-red-100 ring-1 ring-red-300' : 'border-brand-orange text-brand-orange hover:bg-brand-orange hover:text-white' %>">
              <svg class="w-3.5 h-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              Validate
            </button>
            <% if credential.active? %>
              <%= button_to import_lists_supplier_credential_path(credential),
                  method: :post,
                  class: "inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-md border border-blue-300 text-blue-600 hover:bg-blue-50 transition-colors" do %>
                <svg class="w-3.5 h-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" /></svg>
                Import
              <% end %>
            <% end %>
            <div class="flex-1"></div>
            <%= link_to edit_supplier_credential_path(credential), class: "inline-flex items-center px-2 py-1 text-xs font-medium rounded-md border border-gray-300 text-gray-600 hover:bg-gray-50 transition-colors" do %>
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" /></svg>
            <% end %>
            <%= button_to supplier_credential_path(credential), method: :delete, data: { turbo_confirm: "Are you sure you want to remove these credentials?" }, class: "inline-flex items-center px-2 py-1 text-xs font-medium rounded-md border border-red-200 text-red-400 hover:text-red-600 hover:bg-red-50 transition-colors" do %>
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
            <% end %>
          </div>

          <%# Inline 2FA code entry — hidden by default, shown dynamically by Stimulus %>
          <div data-credential-validator-target="tfaBlock"
               class="mt-3 border-t border-amber-200 pt-3 bg-amber-50 -mx-4 -mb-4 px-4 pb-4 rounded-b-lg <%= 'hidden' unless pending_2fa&.pending? %>">
            <p class="text-xs font-medium text-amber-800">Verification code required</p>
            <p data-credential-validator-target="tfaPrompt" class="text-xs text-amber-600 mt-0.5"><%= pending_2fa&.prompt_message || "A verification code has been sent to your email." %></p>
            <p class="text-xs font-semibold text-red-600 mt-1">Codes expire in ~2 minutes!</p>

            <p data-credential-validator-target="tfaMessage" class="text-xs text-amber-700 mt-1 font-medium"></p>

            <div class="mt-2 flex items-end gap-2">
              <div class="flex-1">
                <label for="code_<%= credential.id %>" class="block text-xs font-medium text-amber-700 mb-1">Enter code</label>
                <input type="text"
                       data-credential-validator-target="tfaCodeInput"
                       data-action="keydown->credential-validator#handleCodeKeydown"
                       id="code_<%= credential.id %>"
                       placeholder="Code"
                       autocomplete="one-time-code"
                       inputmode="numeric"
                       maxlength="10"
                       class="block w-full rounded-md border-amber-300 text-sm shadow-sm focus:border-amber-500 focus:ring-amber-500 bg-white placeholder-gray-400 py-1.5 px-2">
              </div>
              <button type="button"
                      data-credential-validator-target="tfaSubmitBtn"
                      data-action="click->credential-validator#submitCode"
                      class="inline-flex items-center px-3 py-1.5 text-xs font-medium rounded-md bg-amber-600 text-white hover:bg-amber-700 shadow-sm transition-colors">
                <svg class="w-3.5 h-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Verify
              </button>
            </div>

            <p class="text-xs text-amber-500 mt-1.5">
              Expires in <span data-credential-validator-target="tfaTimer"><%= pending_2fa ? distance_of_time_in_words(Time.current, pending_2fa.expires_at) : "--" %></span>
            </p>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-lg shadow">
      <p class="text-gray-500">No supplier credentials configured. Add your first supplier login.</p>
    </div>
  <% end %>

  <%# ── Email Suppliers Section ── %>
  <div class="border-t border-gray-200 mt-8 pt-6">
    <div class="flex flex-col gap-3 sm:flex-row sm:justify-between sm:items-center mb-4">
      <div>
        <h2 class="text-lg font-bold text-gray-900">Email Suppliers</h2>
        <p class="text-sm text-gray-500">Suppliers that send PDF price lists via email. Upload their PDFs to compare prices.</p>
      </div>
      <% if operator? %>
        <%= link_to new_email_supplier_path, class: "inline-flex items-center justify-center border border-brand-orange text-brand-orange px-4 py-2 rounded-lg hover:bg-brand-orange hover:text-white text-sm transition-colors" do %>
          <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          Add Email Supplier
        <% end %>
      <% end %>
    </div>

    <% if @email_suppliers.any? %>
      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <% @email_suppliers.each do |supplier| %>
          <% stats = @email_supplier_stats[supplier.contact_email] %>
          <div class="bg-white shadow rounded-lg p-4 flex flex-col">
            <h3 class="text-base font-semibold text-gray-900 truncate"><%= supplier.name %></h3>
            <p class="text-xs text-gray-500 mt-0.5 truncate" title="<%= supplier.contact_email %>">
              <svg class="w-3 h-3 inline mr-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
              <%= supplier.contact_email %>
            </p>

            <% if supplier.ordering_instructions.present? %>
              <p class="text-xs text-gray-400 mt-1 italic truncate" title="<%= supplier.ordering_instructions %>"><%= supplier.ordering_instructions %></p>
            <% end %>

            <div class="mt-2 space-y-0.5">
              <% if stats %>
                <p class="text-xs text-gray-400">
                  Last PDF: <%= stats.try(:last_list_date) ? stats.last_list_date.strftime('%b %d, %Y') : time_ago_in_words(stats.last_received) + ' ago' %>
                </p>
                <p class="text-xs text-gray-400"><%= stats.last_product_count || 0 %> products</p>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Updated</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">No lists yet</span>
              <% end %>
            </div>

            <div class="flex-1"></div>

            <div class="flex flex-wrap items-center gap-1.5 mt-3 pt-3 border-t border-gray-100">
              <%# Upload PDF button — always visible %>
              <%= form_with url: upload_email_supplier_price_lists_path(supplier), method: :post, multipart: true, class: "inline-flex", data: { controller: "pdf-upload" } do %>
                <label class="inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-md border border-brand-orange text-brand-orange hover:bg-brand-orange hover:text-white transition-colors cursor-pointer">
                  <svg class="w-3.5 h-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" /></svg>
                  Upload PDF
                  <input type="file" name="pdf" accept=".pdf" class="hidden" data-action="change->pdf-upload#submit">
                </label>
              <% end %>

              <% if stats %>
                <% latest = InboundPriceList.latest_for(supplier.contact_email) %>
                <% if latest&.parsed? %>
                  <%= link_to review_email_supplier_price_list_path(supplier, latest),
                      class: "inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-md border border-blue-300 text-blue-600 hover:bg-blue-50 transition-colors" do %>
                    <svg class="w-3.5 h-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" /></svg>
                    View List
                  <% end %>
                <% end %>
              <% end %>

              <div class="flex-1"></div>
              <% if operator? %>
                <%= link_to edit_email_supplier_path(supplier), class: "inline-flex items-center px-2 py-1 text-xs font-medium rounded-md border border-gray-300 text-gray-600 hover:bg-gray-50 transition-colors" do %>
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" /></svg>
                <% end %>
                <%= button_to email_supplier_path(supplier), method: :delete, data: { turbo_confirm: "Remove #{supplier.name}? Imported lists will also be removed." }, class: "inline-flex items-center px-2 py-1 text-xs font-medium rounded-md border border-red-200 text-red-400 hover:text-red-600 hover:bg-red-50 transition-colors" do %>
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8 bg-white rounded-lg shadow">
        <svg class="w-10 h-10 mx-auto text-gray-300 mb-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
        <p class="text-gray-500 text-sm">No email suppliers added yet.</p>
        <p class="text-gray-400 text-xs mt-1">Add suppliers that send you PDF price lists via email.</p>
      </div>
    <% end %>
  </div>
</div>
