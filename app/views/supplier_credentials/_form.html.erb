<%# Build a map of supplier IDs to their auth_type and code %>
<% suppliers_auth_map = @all_suppliers.each_with_object({}) { |s, h| h[s.id] = { auth_type: s.auth_type, code: s.code } } %>

<%= form_with(model: credential, class: "space-y-5", data: { controller: "credential-form", credential_form_suppliers_value: suppliers_auth_map.to_json }) do |form| %>
  <% if credential.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <h3 class="text-red-800 font-medium text-sm">Please fix the following errors:</h3>
      <ul class="mt-2 list-disc list-inside text-sm text-red-700">
        <% credential.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Supplier select %>
  <div>
    <%= form.label :supplier_id, "Supplier", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <% supplier_list = credential.persisted? ? @all_suppliers : @available_suppliers %>
    <%= form.collection_select :supplier_id, supplier_list, :id, :name,
        { prompt: "Select a supplier..." },
        class: "block w-full rounded-lg border-gray-300 bg-white text-sm shadow-sm focus:border-brand-green focus:ring-brand-green py-2.5 px-3",
        data: { action: "change->credential-form#supplierChanged", credential_form_target: "supplierSelect" } %>
  </div>

  <%# All fields below are hidden until a supplier is selected (shown for edit) %>
  <div data-credential-form-target="fieldsContainer" class="<%= 'hidden' unless credential.persisted? || credential.supplier_id.present? %> space-y-5">

    <% if owner? && current_location %>
      <div>
        <%= form.label :location_id, "Restaurant", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.hidden_field :location_id, value: current_location.id %>
        <p class="text-sm text-gray-900 py-2"><%= current_location.name %></p>
      </div>
    <% end %>

    <%# 2FA-only notice %>
    <div data-credential-form-target="twoFaNotice" class="<%= 'hidden' unless credential.supplier&.two_fa_only? %> bg-blue-50 border border-blue-200 rounded-lg p-4">
      <div class="flex items-start gap-2.5">
        <svg class="h-5 w-5 text-blue-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
        </svg>
        <p class="text-sm text-blue-700">
          This supplier uses <strong>2FA verification only</strong> (no password required). You'll receive a verification code via email or text when logging in.
        </p>
      </div>
    </div>

    <%# Welcome URL notice %>
    <div data-credential-form-target="welcomeUrlNotice" class="<%= 'hidden' unless credential.supplier&.welcome_url_auth? %> bg-blue-50 border border-blue-200 rounded-lg p-4">
      <div class="flex items-start gap-2.5">
        <svg class="h-5 w-5 text-blue-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
        </svg>
        <p class="text-sm text-blue-700">
          Paste the <strong>Welcome URL</strong> from your supplier email. This is the long link that logs you in directly — no username or password needed.
        </p>
      </div>
    </div>

    <%# Username / Email field %>
    <div data-credential-form-target="usernameField">
      <label data-credential-form-target="usernameLabel" for="supplier_credential_username" class="block text-sm font-medium text-gray-700 mb-1">
        <%= if credential.supplier&.welcome_url_auth?
              "Welcome URL"
            elsif credential.supplier&.code == 'usfoods'
              "User ID"
            else
              "Email Address"
            end %>
      </label>
      <%= form.text_field :username, value: credential.safe_username,
          class: "block w-full rounded-lg border-gray-300 bg-white text-sm shadow-sm focus:border-brand-green focus:ring-brand-green py-2.5 px-3",
          required: true,
          autocomplete: "supplier-username",
          placeholder: if credential.supplier&.welcome_url_auth?
                          "https://www.whatchefswant.com/welcome/..."
                        elsif credential.supplier&.code == 'usfoods'
                          "Enter your User ID"
                        else
                          "you@restaurant.com"
                        end,
          data: { credential_form_target: "usernameInput" } %>
    </div>

    <%# Password field %>
    <div data-controller="password-toggle" data-credential-form-target="passwordField" class="<%= 'hidden' if credential.supplier&.no_password_required? %>">
      <%= form.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <div class="relative">
        <%= form.password_field :password,
            class: "block w-full rounded-lg border-gray-300 bg-white text-sm shadow-sm focus:border-brand-green focus:ring-brand-green py-2.5 px-3 pr-10",
            required: credential.new_record? && credential.supplier&.password_auth?,
            placeholder: credential.persisted? ? "Leave blank to keep current" : "Enter your password",
            autocomplete: "new-password",
            data: { password_toggle_target: "input", credential_form_target: "passwordInput" } %>
        <button type="button" class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 transition-colors" data-action="click->password-toggle#toggle">
          <svg data-password-toggle-target="showIcon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.64 0 8.577 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.64 0-8.577-3.007-9.963-7.178z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <svg data-password-toggle-target="hideIcon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12c1.292 4.338 5.31 7.5 10.066 7.5.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
          </svg>
        </button>
      </div>
    </div>

    <%# Order Requirements (edit only) %>
    <% if credential.persisted? %>
      <div class="border-t border-gray-100 pt-5 mt-2">
        <h3 class="text-sm font-semibold text-gray-900 mb-1">Order Requirements</h3>
        <p class="text-xs text-gray-500 mb-4">Set minimum order requirements for this supplier. Leave blank for no minimum.</p>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="order_minimum" class="block text-sm font-medium text-gray-700 mb-1">Order Minimum ($)</label>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400 text-sm">$</span>
              <input type="number" name="order_minimum" id="order_minimum"
                     value="<%= @order_minimum ? number_with_precision(@order_minimum, precision: 2, strip_insignificant_zeros: true) : '' %>"
                     step="0.01" min="0"
                     placeholder="0.00"
                     class="block w-full rounded-lg border-gray-300 bg-white text-sm shadow-sm focus:border-brand-green focus:ring-brand-green py-2.5 pl-7 pr-3">
            </div>
            <p class="text-xs text-gray-400 mt-1">Minimum dollar amount per order</p>
          </div>
          <div>
            <label for="case_minimum" class="block text-sm font-medium text-gray-700 mb-1">Case Minimum</label>
            <input type="number" name="case_minimum" id="case_minimum"
                   value="<%= @case_minimum %>"
                   step="1" min="0"
                   placeholder="0"
                   class="block w-full rounded-lg border-gray-300 bg-white text-sm shadow-sm focus:border-brand-green focus:ring-brand-green py-2.5 px-3">
            <p class="text-xs text-gray-400 mt-1">Minimum cases or pieces per order</p>
          </div>
        </div>
      </div>
    <% end %>

    <%# Delivery Schedule — only shown for suppliers whose API provides delivery dates.
        Read-only card: we fetch dates automatically on credential creation and refresh
        them whenever the chef visits the order builder. No manual configuration needed. %>
    <% if credential.persisted? && credential.supplier.api_delivery_dates? %>
      <div class="border-t border-gray-100 pt-5 mt-2">
        <h3 class="text-sm font-semibold text-gray-900 mb-1">Delivery Schedule</h3>
        <p class="text-xs text-gray-500 mb-4">
          <%= credential.supplier.name %> tells us which days they can deliver to your location.
          This updates automatically — no setup required.
        </p>

        <% if @api_delivery_dates&.any? %>
          <% parsed_dates = @api_delivery_dates.map { |d| Date.parse(d) rescue nil }.compact.sort %>
          <% upcoming = parsed_dates.select { |d| d >= Date.current }.first(8) %>
          <div class="bg-brand-green/5 border border-brand-green/20 rounded-lg p-3">
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-brand-green flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900">
                  Delivery dates auto-updated from <%= credential.supplier.name %>
                </p>
                <% if @api_delivery_dates_fetched_at %>
                  <p class="text-xs text-gray-500 mt-0.5">
                    Last synced <%= time_ago_in_words(@api_delivery_dates_fetched_at) %> ago
                  </p>
                <% end %>
                <% if upcoming.any? %>
                  <p class="text-xs text-gray-500 mt-2 mb-1.5">Upcoming available delivery dates:</p>
                  <div class="flex flex-wrap gap-1.5">
                    <% upcoming.each do |d| %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-white border border-brand-green/30 text-gray-700">
                        <%= d.strftime("%a %b %-d") %>
                      </span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% else %>
          <div class="bg-gray-50 border border-gray-200 rounded-lg p-3 text-sm text-gray-500">
            Delivery dates will appear here once the first sync completes (usually within 2 minutes of adding the credential).
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Action buttons %>
    <div class="flex flex-col-reverse sm:flex-row sm:justify-end gap-3 pt-2 border-t border-gray-100">
      <%= link_to "Cancel", supplier_credentials_path, class: "px-4 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 text-center transition-colors" %>
      <%= form.submit credential.persisted? ? "Update Credential" : "Add Credential",
          class: "px-4 py-2.5 text-sm font-medium text-white bg-brand-orange rounded-lg hover:bg-brand-orange-dark cursor-pointer transition-colors shadow-sm" %>
    </div>
  </div>
<% end %>
