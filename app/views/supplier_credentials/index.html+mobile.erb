<% content_for :title, "Suppliers" %>

<%# Wired from mockups/mobile/suppliers.html %>

<div class="h-2 bg-brand-green-dark -mx-4 -mt-2"></div>

<!-- Header -->
<header class="bg-brand-green-dark px-4 pb-3 pt-2 -mx-4">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-white text-lg font-heading font-semibold tracking-wide">Suppliers</h1>
      <p class="text-green-200 text-xs"><%= pluralize(@credentials.size, "connected supplier") %></p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to new_supplier_credential_path, class: "bg-white/20 text-white text-[10px] font-semibold px-3 py-1.5 rounded-lg" do %>
        + Add
      <% end %>
      <div class="relative" data-controller="dropdown">
        <button type="button" class="w-8 h-8 bg-brand-orange rounded-full flex items-center justify-center text-white text-sm font-bold"
                data-action="click->dropdown#toggle"><%= current_user.full_name.first.upcase %></button>
        <div class="hidden absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-xl bg-white py-1 shadow-lg ring-1 ring-black/5"
             data-dropdown-target="menu">
          <div class="px-4 py-2 text-sm text-brand-green-dark font-medium border-b border-gray-100"><%= current_user.full_name %></div>
          <%= link_to "Settings", edit_user_registration_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-brand-green-50" %>
          <div class="border-t border-gray-100 mt-1">
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-brand-orange hover:bg-red-50" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Supplier Cards -->
<section class="mt-4 space-y-3">
  <% if @credentials.any? %>
    <% @credentials.each do |credential| %>
      <% pending_2fa = @pending_2fa[credential.id] %>
      <% needs_reconnect = (credential.active? && !credential.session_valid? && credential.supplier.no_password_required?) || credential.failed? %>

      <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden"
           data-controller="credential-validator"
           data-credential-validator-credential-id-value="<%= credential.id %>"
           data-credential-validator-status-url-value="<%= status_supplier_credential_path(credential, format: :json) %>"
           data-credential-validator-validate-url-value="<%= validate_supplier_credential_path(credential, format: :json) %>"
           data-credential-validator-submit-code-url-value="<%= submit_2fa_code_supplier_credential_path(credential, format: :json) %>"
           data-credential-validator-importing-value="<%= credential.importing? %>"
           data-credential-validator-credential-status-value="<%= credential.status %>">
        <div class="p-4">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center border flex-shrink-0
                <%= credential.active? && (credential.session_valid? || credential.supplier.password_auth?) ? 'bg-green-50 border-green-200' : needs_reconnect ? 'bg-red-50 border-red-200' : 'bg-gray-50 border-gray-200' %>">
                <span class="text-sm font-bold <%= credential.active? ? 'text-brand-green' : 'text-gray-400' %>"><%= credential.supplier.name.first(3).upcase %></span>
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-900"><%= credential.supplier.name %></p>
                <p class="text-[10px] text-gray-400"><%= credential.supplier.no_password_required? ? "2FA Authentication" : "Password Authentication" %></p>
              </div>
            </div>
            <% case credential.status %>
            <% when "active" %>
              <span data-credential-validator-target="statusBadge" class="bg-green-50 text-green-700 text-[10px] font-bold px-2.5 py-1 rounded-full">Active</span>
            <% when "invalid", "failed" %>
              <span data-credential-validator-target="statusBadge" class="bg-red-50 text-red-600 text-[10px] font-bold px-2.5 py-1 rounded-full"><%= credential.status.titleize %></span>
            <% else %>
              <span data-credential-validator-target="statusBadge" class="bg-gray-50 text-gray-600 text-[10px] font-bold px-2.5 py-1 rounded-full"><%= credential.status.titleize %></span>
            <% end %>
          </div>

          <%# Stats grid %>
          <% last_catalog_update = @catalog_last_synced[credential.supplier_id] %>
          <div class="grid grid-cols-3 gap-2 text-center">
            <div class="bg-gray-50 rounded-lg p-2">
              <p class="text-sm font-heading font-bold text-brand-navy"><%= @list_counts[credential.supplier_id] || 0 %></p>
              <p class="text-[9px] text-gray-400">Lists</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-2">
              <p class="text-sm font-heading font-bold text-brand-navy"><%= @catalog_product_counts[credential.supplier_id] || 0 %></p>
              <p class="text-[9px] text-gray-400">Products</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-2">
              <p class="text-sm font-heading font-bold text-brand-navy"><%= last_catalog_update ? time_ago_in_words(last_catalog_update).split.first : "—" %></p>
              <p class="text-[9px] text-gray-400"><%= last_catalog_update ? "ago" : "Sync" %></p>
            </div>
          </div>

          <%# Status message block %>
          <div data-credential-validator-target="statusBlock" class="hidden mt-3 p-2.5 bg-blue-50 border border-blue-200 rounded-lg">
            <div class="flex items-start gap-2">
              <svg data-credential-validator-target="statusSpinner" class="animate-spin w-4 h-4 text-blue-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
              <div>
                <p data-credential-validator-target="statusTitle" class="text-xs font-medium text-blue-800"></p>
                <p data-credential-validator-target="statusDetail" class="text-[10px] text-blue-600 mt-0.5"></p>
              </div>
            </div>
          </div>

          <%# Error block %>
          <div data-credential-validator-target="errorBlock" class="mt-3 p-2 bg-red-50 border border-red-200 rounded-lg text-xs text-red-700 <%= 'hidden' unless credential.status == 'failed' && credential.last_error.present? %>">
            <p data-credential-validator-target="errorText" class="text-[10px] break-words"><%= credential.last_error %></p>
          </div>

          <%# Recovery banners %>
          <% if needs_reconnect %>
            <div data-reconnect-banner class="mt-3 p-2 bg-red-50 border border-red-200 rounded-lg">
              <p class="text-[10px] text-red-800">Session expired — tap <strong>Validate</strong> to reconnect.</p>
            </div>
          <% end %>

          <%# Actions %>
          <div class="mt-3 flex gap-2">
            <button type="button"
                    data-credential-validator-target="validateBtn"
                    data-action="click->credential-validator#startValidation"
                    class="<%= (credential.active? && (credential.session_valid? || credential.supplier.password_auth?)) ? 'hidden' : 'block' %> flex-1 text-xs font-semibold py-2 rounded-lg text-center <%= needs_reconnect ? 'bg-red-50 border border-red-400 text-red-700' : 'bg-brand-orange text-white' %>">
              Validate
            </button>
            <%= link_to edit_supplier_credential_path(credential), class: "block flex-1 text-xs font-medium text-gray-600 bg-gray-100 py-2 rounded-lg text-center" do %>
              Credentials
            <% end %>
          </div>
        </div>

        <%# Inline 2FA code entry %>
        <div data-credential-validator-target="tfaBlock"
             class="px-4 pb-4 pt-3 bg-amber-50 border-t border-amber-200 <%= 'hidden' unless pending_2fa&.pending? %>">
          <p class="text-xs font-medium text-amber-800">Verification code required</p>
          <p data-credential-validator-target="tfaPrompt" class="text-[10px] text-amber-600 mt-0.5"><%= pending_2fa&.prompt_message || "A verification code has been sent." %></p>
          <p class="text-[10px] font-semibold text-red-600 mt-1">Codes expire in ~2 minutes!</p>
          <p data-credential-validator-target="tfaMessage" class="text-[10px] text-amber-700 mt-1 font-medium"></p>
          <div class="mt-2 flex items-end gap-2">
            <input type="text" inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code"
                   data-credential-validator-target="tfaInput"
                   data-action="keydown.enter->credential-validator#submitCode"
                   placeholder="Enter code"
                   class="flex-1 rounded-lg border-amber-300 focus:border-brand-orange focus:ring-brand-orange text-sm py-2">
            <button type="button"
                    data-action="click->credential-validator#submitCode"
                    data-credential-validator-target="tfaSubmitBtn"
                    class="rounded-lg bg-brand-orange px-4 py-2 text-sm font-semibold text-white">
              Submit
            </button>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-8 text-center">
      <h3 class="text-sm font-semibold text-gray-900">No suppliers connected</h3>
      <p class="mt-1 text-xs text-gray-500">Add your first supplier credential.</p>
      <%= link_to "Add Credential", new_supplier_credential_path, class: "mt-3 inline-flex bg-brand-orange text-white text-xs font-semibold px-4 py-2 rounded-lg" %>
    </div>
  <% end %>
</section>
