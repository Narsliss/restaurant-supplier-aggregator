<div style="max-width: 600px; margin: 0 auto; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1f2937;">
  <div style="padding: 32px 24px;">
    <h1 style="font-size: 24px; font-weight: 700; margin-bottom: 8px; color: #111827;">
      New Order Placed
    </h1>
    <p style="font-size: 14px; color: #9ca3af; margin-bottom: 24px;">
      <%= @order.created_at.strftime("%B %d, %Y at %l:%M %p") %>
    </p>

    <!-- Order details -->
    <table style="width: 100%; border-collapse: collapse; margin-bottom: 24px;">
      <tr>
        <td style="padding: 8px 0; font-size: 14px; color: #6b7280; width: 120px;">Ordered by</td>
        <td style="padding: 8px 0; font-size: 14px; font-weight: 600; color: #111827;"><%= @chef.full_name %> (<%= @chef.email %>)</td>
      </tr>
      <tr>
        <td style="padding: 8px 0; font-size: 14px; color: #6b7280;">Restaurant</td>
        <td style="padding: 8px 0; font-size: 14px; font-weight: 600; color: #111827;"><%= @location&.name || "N/A" %></td>
      </tr>
      <tr>
        <td style="padding: 8px 0; font-size: 14px; color: #6b7280;">Supplier</td>
        <td style="padding: 8px 0; font-size: 14px; font-weight: 600; color: #111827;"><%= @supplier&.name || @order.supplier_name %></td>
      </tr>
      <tr>
        <td style="padding: 8px 0; font-size: 14px; color: #6b7280;">Delivery date</td>
        <td style="padding: 8px 0; font-size: 14px; font-weight: 600; color: #111827;"><%= @order.delivery_date&.strftime("%A, %B %d, %Y") || "Not specified" %></td>
      </tr>
    </table>

    <!-- Items table -->
    <table style="width: 100%; border-collapse: collapse; margin-bottom: 24px;">
      <thead>
        <tr style="border-bottom: 2px solid #e5e7eb;">
          <th style="padding: 8px 0; font-size: 12px; font-weight: 600; color: #6b7280; text-transform: uppercase; text-align: left;">Item</th>
          <th style="padding: 8px 0; font-size: 12px; font-weight: 600; color: #6b7280; text-transform: uppercase; text-align: right; width: 50px;">Qty</th>
          <th style="padding: 8px 0; font-size: 12px; font-weight: 600; color: #6b7280; text-transform: uppercase; text-align: right; width: 80px;">Price</th>
          <th style="padding: 8px 0; font-size: 12px; font-weight: 600; color: #6b7280; text-transform: uppercase; text-align: right; width: 90px;">Total</th>
        </tr>
      </thead>
      <tbody>
        <% @items.each do |item| %>
          <tr style="border-bottom: 1px solid #f3f4f6;">
            <td style="padding: 10px 0; font-size: 14px; color: #111827;"><%= item.product_name || item.supplier_product&.supplier_name || "Unknown" %></td>
            <td style="padding: 10px 0; font-size: 14px; color: #4b5563; text-align: right;"><%= item.quantity.to_i %></td>
            <td style="padding: 10px 0; font-size: 14px; color: #4b5563; text-align: right;"><%= number_to_currency(item.unit_price) %></td>
            <td style="padding: 10px 0; font-size: 14px; font-weight: 600; color: #111827; text-align: right;"><%= number_to_currency(item.line_total) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <!-- Total -->
    <div style="border-top: 2px solid #111827; padding-top: 12px; margin-bottom: 24px;">
      <table style="width: 100%;">
        <tr>
          <td style="font-size: 16px; font-weight: 700; color: #111827;">Order Total</td>
          <td style="font-size: 16px; font-weight: 700; color: #111827; text-align: right;"><%= number_to_currency(@order.total_amount) %></td>
        </tr>
        <% if @order.savings_amount && @order.savings_amount > 0 %>
          <tr>
            <td style="font-size: 14px; color: #15803d;">Savings vs. highest price</td>
            <td style="font-size: 14px; color: #15803d; text-align: right;"><%= number_to_currency(@order.savings_amount) %></td>
          </tr>
        <% end %>
      </table>
    </div>

    <!-- CTA -->
    <div style="text-align: center; margin-bottom: 24px;">
      <a href="<%= order_url(@order) %>" style="display: inline-block; background-color: #15803d; color: #ffffff; font-weight: 600; padding: 12px 24px; border-radius: 8px; text-decoration: none; font-size: 14px;">
        View Order Details
      </a>
    </div>

    <p style="font-size: 12px; color: #9ca3af; line-height: 1.5; text-align: center;">
      This notification was sent because a team member placed an order in your EnPlace Pro organization.
    </p>
  </div>
</div>
