<!DOCTYPE html>
<html lang="en" class="h-full bg-brand-stone" data-controller="theme">
  <head>
    <title><%= content_for(:title) || "EnPlace Pro — Mise en place for your kitchen orders" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="turbo-cache-control" content="no-preview">
    <script>
      (function() {
        var t = localStorage.getItem('supplierhub-theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches))
          document.documentElement.classList.add('dark');
      })();
    </script>
    <%= favicon_link_tag "logo.svg", type: "image/svg+xml" %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body class="h-full">
    <% if ENV['DEMO_MODE'] == 'true' %>
      <div class="bg-amber-500 text-center text-sm py-1.5 font-semibold text-white tracking-wide">
        Demo Environment &mdash; Sample data resets nightly at midnight
      </div>
    <% end %>
    <div class="min-h-full flex flex-col"
         <% if user_signed_in? && current_user.current_organization && current_location && defined?(operator?) && operator? %>
           data-controller="price-check"
           data-price-check-search-url-value="<%= catalog_search_path %>"
           data-price-check-add-url-value="<%= add_to_list_catalog_search_path %>"
           data-price-check-lists-url-value="<%= for_select_order_lists_path(format: :json) %>"
         <% end %>>
      <% if user_signed_in? %>
        <% if controller.class.module_parent_name == 'Admin' %>
          <%= render "admin/shared/navigation" %>
        <% elsif controller.class.module_parent_name == 'Crm' %>
          <%= render "crm/shared/navigation" %>
        <% else %>
          <%= render "shared/navigation" %>
        <% end %>
      <% end %>

      <main class="<%= user_signed_in? ? 'py-10 flex-1' : 'flex-1' %>">
        <div class="<%= user_signed_in? ? 'mx-auto max-w-7xl px-4 sm:px-6 lg:px-8' : '' %>">
          <%= render "shared/flash_messages" unless devise_controller? %>
          <% if user_signed_in? && impersonating? %>
            <%= render "admin/shared/impersonation_banner" %>
          <% end %>
          <% if user_signed_in? && current_user.current_organization&.subscription_status == 'past_due' && !current_user.super_admin? && defined?(owner?) && owner? %>
            <div class="rounded-lg bg-yellow-50 border border-yellow-200 px-4 py-3 mb-6 flex items-center justify-between">
              <p class="text-sm text-yellow-800">
                <strong>Payment failed.</strong> Please update your payment method to avoid losing access to EnPlace Pro.
              </p>
              <%= button_to "Update Payment Method", subscription_billing_portal_path,
                  method: :post,
                  class: "inline-flex items-center rounded-md bg-yellow-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-yellow-700 transition-colors duration-150 whitespace-nowrap ml-4" %>
            </div>
          <% end %>
          <%= yield %>
        </div>
      </main>

      <% if user_signed_in? %>
        <%= render "shared/footer" %>
      <% end %>

      <% if user_signed_in? && current_user.current_organization && current_location && defined?(operator?) && operator? %>
        <%= render "shared/price_check_modal" %>
      <% end %>
    </div>

    <%= render "shared/two_factor_modal" if user_signed_in? %>
    <%= render "shared/feedback_modal" if user_signed_in? %>

    <%# Loading overlay — visible during Turbo page transitions and form submissions %>
    <div id="turbo-loading-overlay"
         style="position:fixed;inset:0;z-index:45;display:none;align-items:center;justify-content:center;background:rgba(255,255,255,0.6);backdrop-filter:blur(2px);-webkit-backdrop-filter:blur(2px);pointer-events:none;">
      <div style="display:flex;align-items:center;">
        <div class="loading-dot"></div>
        <div class="loading-dot"></div>
        <div class="loading-dot"></div>
      </div>
    </div>
    <script>
      (function() {
        // Always target the current overlay in the DOM (survives Turbo body swaps)
        function getOverlay() { return document.getElementById('turbo-loading-overlay'); }
        var timer, safety;

        function show() {
          clearTimeout(timer);
          clearTimeout(safety);
          timer = setTimeout(function() {
            var o = getOverlay();
            if (o) o.style.display = 'flex';
          }, 150);
          safety = setTimeout(hide, 10000);
        }

        function hide() {
          clearTimeout(timer);
          clearTimeout(safety);
          var o = getOverlay();
          if (o) o.style.display = 'none';
        }

        // Turbo-driven navigation and form submissions — only for full-page visits, not frame loads
        document.addEventListener('turbo:before-fetch-request', function(e) {
          var headers = (e.detail && e.detail.fetchOptions && e.detail.fetchOptions.headers) || {};
          var accept = headers.Accept || '';
          if (accept.indexOf('text/html') === -1) return;
          // Skip Turbo Frame requests (they don't fire turbo:load to hide)
          if (e.target && e.target.tagName === 'TURBO-FRAME') return;
          // Skip Turbo link prefetches triggered by hover (Turbo 8+)
          if (headers['X-Sec-Purpose'] === 'prefetch') return;
          show();
        });
        document.addEventListener('turbo:load', hide);
        document.addEventListener('turbo:before-render', hide);
        document.addEventListener('turbo:render', hide);
        document.addEventListener('turbo:fetch-request-error', hide);

        // Hide before Turbo caches so snapshots never contain the overlay
        document.addEventListener('turbo:before-cache', hide);

        // Hide on bfcache restoration (browser back to a page with overlay visible)
        window.addEventListener('pageshow', function(e) { if (e.persisted) hide(); });

        // Non-Turbo links (data-turbo="false") — show overlay immediately
        // (no 150ms delay, because the browser may suspend JS timers
        //  during full-page navigation before the timeout fires)
        document.addEventListener('click', function(e) {
          var link = e.target.closest('a[href]');
          if (!link) return;
          var href = link.getAttribute('href');
          if (!href || href.charAt(0) === '#' || href.indexOf('javascript:') === 0) return;
          if (link.target === '_blank' || e.metaKey || e.ctrlKey) return;
          if (link.dataset.turbo !== 'false' && !link.closest('[data-turbo="false"]')) return;
          var o = getOverlay();
          if (o) o.style.display = 'flex';
          clearTimeout(safety);
          safety = setTimeout(hide, 10000);
        });
      })();
    </script>
  </body>
</html>
