<!DOCTYPE html>
<html lang="en" class="h-full bg-brand-stone" data-controller="theme">
  <head>
    <title><%= content_for(:title) || "SupplierHub - Restaurant Supplier Aggregator" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="turbo-cache-control" content="no-preview">
    <script>
      (function() {
        var t = localStorage.getItem('supplierhub-theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches))
          document.documentElement.classList.add('dark');
      })();
    </script>
    <%= favicon_link_tag "logo.svg", type: "image/svg+xml" %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body class="h-full">
    <div class="min-h-full flex flex-col">
      <% if user_signed_in? %>
        <% if controller.class.module_parent_name == 'Admin' %>
          <%= render "admin/shared/navigation" %>
        <% else %>
          <%= render "shared/navigation" %>
        <% end %>
      <% end %>

      <main class="<%= user_signed_in? ? 'py-10 flex-1' : 'flex-1' %>">
        <div class="<%= user_signed_in? ? 'mx-auto max-w-7xl px-4 sm:px-6 lg:px-8' : '' %>">
          <%= render "shared/flash_messages" unless devise_controller? %>
          <% if impersonating? %>
            <%= render "admin/shared/impersonation_banner" %>
          <% end %>
          <% if user_signed_in? && current_user.current_organization&.subscription_status == 'past_due' && !current_user.super_admin? && defined?(owner?) && owner? %>
            <div class="rounded-lg bg-yellow-50 border border-yellow-200 px-4 py-3 mb-6 flex items-center justify-between">
              <p class="text-sm text-yellow-800">
                <strong>Payment failed.</strong> Please update your payment method to avoid losing access to SupplierHub.
              </p>
              <%= button_to "Update Payment Method", subscription_billing_portal_path,
                  method: :post,
                  class: "inline-flex items-center rounded-md bg-yellow-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-yellow-700 transition-colors duration-150 whitespace-nowrap ml-4" %>
            </div>
          <% end %>
          <%= yield %>
        </div>
      </main>

      <% if user_signed_in? %>
        <%= render "shared/footer" %>
      <% end %>
    </div>

    <%= render "shared/two_factor_modal" if user_signed_in? %>
  </body>
</html>
