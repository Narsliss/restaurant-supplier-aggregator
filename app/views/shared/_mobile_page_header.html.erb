<%# Minimal mobile page header with avatar dropdown — used on non-dashboard pages %>
<div class="-mx-4 -mt-2 mb-3 px-4 pt-3 pb-2 flex items-center justify-between">
  <div class="flex items-center gap-2">
    <%= link_to root_path(mobile: mobile? ? "1" : nil) do %>
      <%= image_tag "logo.svg", alt: "EnPlace Pro", class: "h-7 w-7" %>
    <% end %>
  </div>
  <div class="relative" data-controller="dropdown">
    <button type="button" class="flex rounded-full focus:outline-none" data-action="click->dropdown#toggle">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-orange">
        <span class="text-sm font-medium leading-none text-white"><%= current_user.full_name.first.upcase %></span>
      </span>
    </button>
    <div class="hidden absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-xl bg-white py-1 shadow-lg ring-1 ring-black/5"
         data-dropdown-target="menu">
      <div class="px-4 py-2 text-sm text-brand-green-dark font-medium border-b border-gray-100">
        <%= current_user.full_name %>
      </div>
      <%= link_to "Settings", edit_user_registration_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-brand-green-50" %>
      <% if owner? %>
        <%= link_to "Team", organization_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-brand-green-50" %>
        <%= link_to "Billing", subscription_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-brand-green-50" %>
      <% end %>
      <div class="border-t border-gray-100 mt-1">
        <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-brand-orange hover:bg-red-50" %>
      </div>
    </div>
  </div>
</div>
