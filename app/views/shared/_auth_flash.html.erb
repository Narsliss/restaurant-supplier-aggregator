<%# Flash banner for auth and standalone admin views that render outside the main layout.
     Renders only :notice and :alert — ignores internal keys like Devise's :timedout.
     Optional local: class (extra wrapper classes, e.g. "mt-4"). %>
<% wrapper_class = local_assigns.fetch(:class, "") %>
<% if notice.present? %>
  <div class="<%= wrapper_class %> rounded-lg border px-4 py-3 text-sm bg-blue-50 border-blue-200 text-blue-700">
    <%= notice %>
  </div>
<% end %>
<% if alert.present? %>
  <div class="<%= wrapper_class %> rounded-lg border px-4 py-3 text-sm bg-red-50 border-red-200 text-red-700">
    <%= alert %>
  </div>
<% end %>
