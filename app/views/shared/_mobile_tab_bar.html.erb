<% onboarding = onboarding_incomplete? %>
<% ops_disabled = onboarding || (defined?(viewing_all_locations?) && viewing_all_locations?) %>

<nav class="bg-white border-t border-gray-200" style="position: fixed; bottom: 0; left: 0; right: 0; z-index: 50;"
     data-controller="mobile-tab-bar">
  <div class="flex items-center py-2">
    <%# Home %>
    <%= link_to root_path, class: "flex-1 flex flex-col items-center gap-0.5 pb-1 mobile-tab-link",
        data: { mobile_tab_bar_target: "tab", path: "/" } do %>
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
      <span class="text-[11px] font-semibold">Home</span>
    <% end %>

    <%# Orders %>
    <% if ops_disabled %>
      <span class="flex-1 flex flex-col items-center gap-0.5 pb-1 text-gray-300 cursor-not-allowed">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        <span class="text-[11px] font-medium">History</span>
      </span>
    <% else %>
      <%= link_to orders_path, class: "flex-1 flex flex-col items-center gap-0.5 pb-1 mobile-tab-link",
          data: { mobile_tab_bar_target: "tab", path: "/orders" } do %>
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        <span class="text-[11px] font-medium">History</span>
      <% end %>
    <% end %>

    <%# +Order FAB %>
    <% if ops_disabled %>
      <span class="flex-1 flex flex-col items-center gap-0.5 pb-1 cursor-not-allowed" style="margin-top: -1.5rem;">
        <div class="bg-gray-300 rounded-full p-3 shadow-lg">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        </div>
        <span class="text-[10px] font-semibold text-gray-300">Order</span>
      </span>
    <% else %>
      <%= link_to select_list_orders_path, class: "flex-1 flex flex-col items-center gap-0.5 pb-1",
          style: "position: relative; top: -0.75rem;",
          data: { mobile_tab_bar_target: "tab", path: "/orders/select_list" } do %>
        <div class="bg-brand-green rounded-full p-3 shadow-lg" data-mobile-tab-bar-target="fabCircle">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        </div>
        <span class="text-[10px] font-semibold text-brand-green">Order</span>
      <% end %>
    <% end %>

    <%# Suppliers %>
    <% if ops_disabled %>
      <span class="flex-1 flex flex-col items-center gap-0.5 pb-1 text-gray-300 cursor-not-allowed">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
        <span class="text-[11px] font-medium">Suppliers</span>
      </span>
    <% else %>
      <%= link_to supplier_credentials_path, class: "flex-1 flex flex-col items-center gap-0.5 pb-1 mobile-tab-link",
          data: { mobile_tab_bar_target: "tab", path: "/supplier_credentials" } do %>
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
        <span class="text-[11px] font-medium">Suppliers</span>
      <% end %>
    <% end %>

    <%# Search %>
    <% if ops_disabled %>
      <span class="flex-1 flex flex-col items-center gap-0.5 pb-1 text-gray-300 cursor-not-allowed">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <span class="text-[11px] font-medium">Search</span>
      </span>
    <% else %>
      <%= link_to catalog_search_path, class: "flex-1 flex flex-col items-center gap-0.5 pb-1 mobile-tab-link",
          data: { mobile_tab_bar_target: "tab", path: "/catalog_search" } do %>
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <span class="text-[11px] font-medium">Search</span>
      <% end %>
    <% end %>
  </div>
</nav>

<%# Fallback: ensure mobile-tab-bar controller is registered even if importmap cache is stale %>
<script type="module">
  import { Application } from "@hotwired/stimulus"
  const app = window.Stimulus || Application.start()
  if (!app.router.modulesByIdentifier.has("mobile-tab-bar")) {
    const mod = await import("controllers/mobile_tab_bar_controller")
    app.register("mobile-tab-bar", mod.default)
  }
</script>
