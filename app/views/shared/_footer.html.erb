<footer class="bg-brand-green-dark mt-auto">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="md:flex md:items-center md:justify-between">
      <div class="flex items-center space-x-4">
        <%= render "shared/logo", variant: :footer %>
        <span class="text-sm text-gray-400">Restaurant Supplier Aggregator</span>
      </div>
      <div class="mt-4 md:mt-0">
        <p class="text-sm text-gray-400">&copy; <%= Date.current.year %> EnPlace Pro. All rights reserved.</p>
      </div>
    </div>
    <div class="mt-4 border-t border-white/10 pt-4">
      <div class="flex flex-col sm:flex-row sm:items-center sm:space-x-6 text-sm text-gray-400 gap-1 sm:gap-0">
        <span>Powered by EnPlace Pro</span>
        <span class="hidden sm:inline text-brand-green">&#9679;</span>
        <span>Multi-supplier ordering platform</span>
        <span class="hidden sm:inline text-brand-green">&#9679;</span>
        <button type="button" onclick="window.dispatchEvent(new Event('feedback:open'))" class="text-gray-400 hover:text-white transition-colors">Feedback</button>
        <span class="hidden sm:inline text-brand-green">&#9679;</span>
        <%= link_to "Terms of Service", terms_path, class: "text-gray-400 hover:text-white transition-colors" %>
      </div>
    </div>
  </div>
</footer>
