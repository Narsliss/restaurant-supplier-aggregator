<% onboarding = onboarding_incomplete? %>
<% all_locations_mode = viewing_all_locations? %>
<%# Operational pages are disabled during onboarding OR when owner is in "All Locations" mode %>
<% ops_disabled = onboarding || all_locations_mode %>

<nav class="bg-brand-green-dark shadow-lg relative z-50" data-controller="mobile-menu">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 justify-between">
      <div class="flex">
        <div class="flex flex-shrink-0 items-center">
          <%= link_to root_path, class: "flex items-center group" do %>
            <%= render "shared/logo", variant: :nav %>
          <% end %>
        </div>
        <div class="hidden sm:ml-8 sm:flex sm:space-x-6">
          <%# Dashboard — always visible %>
          <%= link_to "Dashboard", root_path,
              class: "inline-flex items-center border-b-2 #{current_page?(root_path) ? 'border-brand-orange text-white' : 'border-transparent text-gray-300 hover:border-gray-400 hover:text-white'} px-1 pt-1 text-sm font-medium transition-colors duration-150" %>

          <%# Consistent link order: New Order (CTA), Supplier Data, Order History %>
          <%# Active state helpers %>
          <% new_order_active = (controller_name == 'orders' && action_name == 'select_list') || (controller_name == 'aggregated_lists' && action_name == 'order_builder') %>
          <% supplier_data_active = %w[supplier_lists supplier_credentials product_matches].include?(controller_name) || (controller_name == 'aggregated_lists' && action_name != 'order_builder') %>
          <% order_history_active = controller_name == 'orders' && action_name != 'select_list' %>

          <%# — Supplier Data Dropdown %>
          <% if ops_disabled %>
            <% unless chef? || current_role == 'manager' %>
              <span class="inline-flex items-center border-b-2 border-transparent px-1 pt-1 text-sm font-medium text-gray-500 cursor-not-allowed" title="<%= onboarding ? 'Complete account setup first' : 'Select a specific restaurant' %>">Supplier Data</span>
            <% end %>
          <% elsif operator? %>
            <div class="inline-flex items-center">
              <div class="relative" data-controller="dropdown">
                <button type="button"
                        class="inline-flex items-center gap-1 border-b-2 <%= supplier_data_active ? 'border-brand-orange text-white' : 'border-transparent text-gray-300 hover:border-gray-400 hover:text-white' %> px-1 pt-1 text-sm font-medium transition-colors duration-150"
                        data-action="click->dropdown#toggle">
                  Supplier Data
                  <svg class="w-3 h-3 ml-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
                </button>
                <div class="hidden absolute left-0 mt-2 z-20 w-48 rounded-md bg-white py-1 shadow-lg ring-1 ring-black/5"
                     data-dropdown-target="menu">
                <%= link_to "Supplier Credentials", supplier_credentials_path,
                    class: "block px-4 py-2 text-sm #{controller_name == 'supplier_credentials' ? 'bg-brand-green-50 text-brand-green-dark font-medium' : 'text-gray-700 hover:bg-brand-green-50 hover:text-brand-green-dark'}" %>
                <%= link_to "Product Matching", aggregated_lists_path,
                    class: "block px-4 py-2 text-sm #{%w[aggregated_lists product_matches supplier_lists].include?(controller_name) && action_name != 'order_builder' ? 'bg-brand-green-50 text-brand-green-dark font-medium' : 'text-gray-700 hover:bg-brand-green-50 hover:text-brand-green-dark'}" %>
                </div>
              </div>
            </div>
          <% end %>

          <%# — Order History %>
          <% if ops_disabled %>
            <% if !onboarding && manager_or_owner? %>
              <%= link_to "Order History", orders_path,
                  class: "inline-flex items-center border-b-2 #{order_history_active ? 'border-brand-orange text-white' : 'border-transparent text-gray-300 hover:border-gray-400 hover:text-white'} px-1 pt-1 text-sm font-medium transition-colors duration-150" %>
            <% else %>
              <span class="inline-flex items-center border-b-2 border-transparent px-1 pt-1 text-sm font-medium text-gray-500 cursor-not-allowed" title="Complete account setup first">Order History</span>
            <% end %>
          <% else %>
            <%= link_to "Order History", orders_path,
                class: "inline-flex items-center border-b-2 #{order_history_active ? 'border-brand-orange text-white' : 'border-transparent text-gray-300 hover:border-gray-400 hover:text-white'} px-1 pt-1 text-sm font-medium transition-colors duration-150" %>
          <% end %>

          <%# — Admin + Products (super_admin only) %>
          <% if current_user.super_admin? %>
            <%= link_to "Admin", admin_root_path,
                class: "inline-flex items-center border-b-2 border-transparent text-gray-300 hover:border-gray-400 hover:text-white px-1 pt-1 text-sm font-medium transition-colors duration-150" %>
            <% unless ops_disabled %>
              <%= link_to "Products", products_path,
                  class: "inline-flex items-center border-b-2 #{controller_name == 'products' ? 'border-brand-orange text-white' : 'border-transparent text-gray-300 hover:border-gray-400 hover:text-white'} px-1 pt-1 text-sm font-medium transition-colors duration-150" %>
            <% end %>
          <% end %>

          <%# Suppliers link removed — now under "Supplier Data" dropdown above %>

          <%# — Menu Planner %>
          <% unless ops_disabled %>
            <%= link_to "Menu Planner", event_plans_path,
                class: "inline-flex items-center border-b-2 #{%w[event_plans event_plan_messages].include?(controller_name) ? 'border-brand-orange text-white' : 'border-transparent text-gray-300 hover:border-gray-400 hover:text-white'} px-1 pt-1 text-sm font-medium transition-colors duration-150" %>
          <% end %>

          <%# Reports — visible to owners and managers (always, not affected by location context) %>
          <% if manager_or_owner? %>
            <%= link_to "Reports", reports_path,
                class: "inline-flex items-center border-b-2 #{controller_name == 'reports' ? 'border-brand-orange text-white' : 'border-transparent text-gray-300 hover:border-gray-400 hover:text-white'} px-1 pt-1 text-sm font-medium transition-colors duration-150" %>
          <% end %>

          <%# — New Order CTA (end of left nav, distinctive button style) %>
          <% if ops_disabled %>
            <% unless chef? || current_role == 'manager' %>
              <span class="inline-flex items-center gap-1 ml-3 px-3 py-1.5 rounded-full text-xs font-semibold tracking-wide uppercase cursor-not-allowed opacity-40" style="background-color: #fff; color: #3a6147; align-self: center;" title="<%= onboarding ? 'Complete account setup first' : 'Select a specific restaurant' %>">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                New Order
              </span>
            <% end %>
          <% elsif operator? %>
            <%= link_to select_list_orders_path,
                class: "inline-flex items-center gap-1 ml-3 px-3 py-1.5 rounded-full text-xs font-semibold tracking-wide uppercase shadow-sm transition-all duration-150 #{new_order_active ? 'ring-2 ring-white/60' : 'hover:shadow-md hover:scale-105'}",
                style: "background-color: #fff; color: #3a6147; align-self: center;" do %>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
              New Order
            <% end %>
          <% end %>
        </div>
      </div>

      <div class="hidden sm:ml-6 sm:flex sm:items-center">
        <% unless onboarding %>
          <% locations = current_user.accessible_locations %>
          <% if locations.any? %>
            <div class="mr-4" data-controller="location-selector">
              <% if chef? %>
                <%# Chefs see their restaurant name (static, no dropdown) %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-brand-green/80 text-white">
                  <%= current_location&.name || "No restaurant" %>
                </span>
              <% else %>
                <%# Owners/managers see dropdown %>
                <select class="rounded-md bg-brand-green/80 border-white/20 text-sm text-white focus:border-brand-green focus:ring-brand-green"
                        data-action="change->location-selector#change">
                  <% if owner? %>
                    <option value="all" <%= 'selected' if viewing_all_locations? %>>All Locations</option>
                  <% end %>
                  <% locations.each do |location| %>
                    <option value="<%= location.id %>" <%= 'selected' if location == current_location %>><%= location.name %></option>
                  <% end %>
                </select>
              <% end %>
            </div>
          <% end %>
        <% end %>

        <%# Avatar dropdown menu %>
        <div class="relative ml-3" data-controller="dropdown">
          <button type="button"
                  class="flex rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-green focus:ring-offset-2 focus:ring-offset-brand-green-dark"
                  data-action="click->dropdown#toggle">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-orange">
              <span class="text-sm font-medium leading-none text-white"><%= current_user.full_name.first.upcase %></span>
            </span>
          </button>
          <div class="hidden absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-md bg-white py-1 shadow-lg ring-1 ring-black/5"
               data-dropdown-target="menu">
            <div class="px-4 py-2 text-sm text-brand-green-dark font-medium border-b border-gray-100">
              <%= current_user.full_name %>
              <span class="block text-xs text-gray-400 font-normal"><%= current_role&.titleize %></span>
            </div>
            <%= link_to "Settings", edit_user_registration_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-brand-green-50 hover:text-brand-green-dark" %>
            <% if onboarding %>
              <span class="block px-4 py-2 text-sm text-gray-400 cursor-not-allowed">Team</span>
              <span class="block px-4 py-2 text-sm text-gray-400 cursor-not-allowed">Billing</span>
              <span class="block px-4 py-2 text-sm text-gray-400 cursor-not-allowed">Restaurants</span>
            <% elsif owner? %>
              <%= link_to "Team", organization_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-brand-green-50 hover:text-brand-green-dark" %>
              <%= link_to "Billing", subscription_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-brand-green-50 hover:text-brand-green-dark" %>
              <%= link_to "Restaurants", locations_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-brand-green-50 hover:text-brand-green-dark" %>
            <% end %>
            <% if current_user.super_admin? %>
              <%= link_to "Admin Dashboard", admin_root_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-brand-green-50 hover:text-brand-green-dark" %>
              <%= link_to "Jobs", mission_control_jobs.root_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-brand-green-50 hover:text-brand-green-dark" %>
            <% end %>
            <div class="border-t border-gray-100 mt-1 pt-1">
              <%= link_to "Terms of Service", terms_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-brand-green-50 hover:text-brand-green-dark" %>
              <button type="button"
                      data-action="click->theme#cycle"
                      class="flex w-full items-center px-4 py-2 text-sm text-gray-700 hover:bg-brand-green-50 hover:text-brand-green-dark">
                <svg data-theme-target="lightIcon" class="w-4 h-4 mr-2 hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
                </svg>
                <svg data-theme-target="darkIcon" class="w-4 h-4 mr-2 hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
                </svg>
                <svg data-theme-target="systemIcon" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z" />
                </svg>
                <span data-theme-target="label">System</span>
              </button>
            </div>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-brand-orange hover:bg-red-50" %>
          </div>
        </div>
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center sm:hidden">
        <button type="button"
                class="inline-flex items-center justify-center rounded-md p-2 text-gray-300 hover:bg-brand-green/80 hover:text-white focus:outline-none focus:ring-2 focus:ring-inset focus:ring-brand-green"
                data-action="click->mobile-menu#toggle">
          <svg data-mobile-menu-target="openIcon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <svg data-mobile-menu-target="closeIcon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div class="hidden sm:hidden" data-mobile-menu-target="menu">
    <div class="space-y-1 px-2 pb-3 pt-2">
      <%= link_to "Dashboard", root_path,
          class: "block rounded-md px-3 py-2 text-base font-medium #{current_page?(root_path) ? 'bg-brand-green/80 text-white border-l-4 border-brand-orange' : 'text-gray-300 hover:bg-brand-green/80 hover:text-white'}" %>
      <%# Mobile: same consistent order as desktop — New Order, Lists & Matching, Order History %>

      <%# — New Order (highlighted CTA) %>
      <% if ops_disabled %>
        <% unless current_role == 'manager' %>
          <span class="block rounded-md px-3 py-2 text-base font-medium text-gray-500 cursor-not-allowed">New Order</span>
        <% end %>
      <% elsif operator? %>
        <%= link_to "New Order", select_list_orders_path,
            class: "block rounded-md px-3 py-2.5 text-base font-semibold #{new_order_active ? 'bg-brand-orange text-white' : 'bg-brand-orange/80 text-white'}" %>
      <% end %>

      <%# — Supplier Data (collapsed section for mobile) %>
      <% if ops_disabled %>
        <% unless current_role == 'manager' %>
          <span class="block rounded-md px-3 py-2 text-base font-medium text-gray-500 cursor-not-allowed">Supplier Data</span>
        <% end %>
      <% elsif operator? %>
        <div class="pl-2 border-l-2 border-white/10 ml-1 space-y-1">
          <span class="block px-3 py-1 text-xs font-semibold uppercase tracking-wider text-gray-400">Supplier Data</span>
          <%= link_to "Supplier Credentials", supplier_credentials_path,
              class: "block rounded-md px-3 py-2 text-base font-medium #{controller_name == 'supplier_credentials' ? 'bg-brand-green/80 text-white border-l-4 border-brand-orange' : 'text-gray-300 hover:bg-brand-green/80 hover:text-white'}" %>
          <%= link_to "Product Matching", aggregated_lists_path,
              class: "block rounded-md px-3 py-2 text-base font-medium #{supplier_data_active && controller_name != 'supplier_credentials' ? 'bg-brand-green/80 text-white border-l-4 border-brand-orange' : 'text-gray-300 hover:bg-brand-green/80 hover:text-white'}" %>
        </div>
      <% end %>

      <%# — Order History %>
      <% if ops_disabled %>
        <% if !onboarding && manager_or_owner? %>
          <%= link_to "Order History", orders_path,
              class: "block rounded-md px-3 py-2 text-base font-medium #{order_history_active ? 'bg-brand-green/80 text-white border-l-4 border-brand-orange' : 'text-gray-300 hover:bg-brand-green/80 hover:text-white'}" %>
        <% else %>
          <span class="block rounded-md px-3 py-2 text-base font-medium text-gray-500 cursor-not-allowed">Order History</span>
        <% end %>
      <% else %>
        <%= link_to "Order History", orders_path,
            class: "block rounded-md px-3 py-2 text-base font-medium #{order_history_active ? 'bg-brand-green/80 text-white border-l-4 border-brand-orange' : 'text-gray-300 hover:bg-brand-green/80 hover:text-white'}" %>
      <% end %>

      <%# Suppliers link removed — now under "Supplier Data" section above %>
      <% unless ops_disabled %>
        <%= link_to "Menu Planner", event_plans_path,
            class: "block rounded-md px-3 py-2 text-base font-medium #{%w[event_plans event_plan_messages].include?(controller_name) ? 'bg-brand-green/80 text-white border-l-4 border-brand-orange' : 'text-gray-300 hover:bg-brand-green/80 hover:text-white'}" %>
      <% end %>
      <% if manager_or_owner? %>
        <%= link_to "Reports", reports_path,
            class: "block rounded-md px-3 py-2 text-base font-medium #{controller_name == 'reports' ? 'bg-brand-green/80 text-white border-l-4 border-brand-orange' : 'text-gray-300 hover:bg-brand-green/80 hover:text-white'}" %>
      <% end %>
    </div>
    <div class="border-t border-white/10 px-4 pb-3 pt-4">
      <% unless onboarding %>
        <% locations = current_user.accessible_locations %>
        <% if locations.any? && !chef? %>
          <div class="mb-3" data-controller="location-selector">
            <select class="w-full rounded-md bg-brand-green/80 border-white/20 text-sm text-white focus:border-brand-green focus:ring-brand-green"
                    data-action="change->location-selector#change">
              <% if owner? %>
                <option value="all" <%= 'selected' if viewing_all_locations? %>>All Locations</option>
              <% end %>
              <% locations.each do |location| %>
                <option value="<%= location.id %>" <%= 'selected' if location == current_location %>><%= location.name %></option>
              <% end %>
            </select>
          </div>
        <% end %>
      <% end %>
      <div class="flex items-center mb-3">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-brand-orange">
          <span class="text-sm font-medium leading-none text-white"><%= current_user.full_name.first.upcase %></span>
        </span>
        <div class="ml-3">
          <p class="text-base font-medium text-white"><%= current_user.full_name %></p>
          <p class="text-sm text-gray-400"><%= current_user.email %></p>
        </div>
      </div>
      <div class="space-y-1">
        <%= link_to "Settings", edit_user_registration_path, class: "block rounded-md px-3 py-2 text-base font-medium text-gray-300 hover:bg-brand-green/80 hover:text-white" %>
        <% if onboarding %>
          <span class="block rounded-md px-3 py-2 text-base font-medium text-gray-500 cursor-not-allowed">Team</span>
          <span class="block rounded-md px-3 py-2 text-base font-medium text-gray-500 cursor-not-allowed">Billing</span>
          <span class="block rounded-md px-3 py-2 text-base font-medium text-gray-500 cursor-not-allowed">Restaurants</span>
        <% elsif owner? %>
          <%= link_to "Team", organization_path, class: "block rounded-md px-3 py-2 text-base font-medium text-gray-300 hover:bg-brand-green/80 hover:text-white" %>
          <%= link_to "Billing", subscription_path, class: "block rounded-md px-3 py-2 text-base font-medium text-gray-300 hover:bg-brand-green/80 hover:text-white" %>
          <%= link_to "Restaurants", locations_path, class: "block rounded-md px-3 py-2 text-base font-medium text-gray-300 hover:bg-brand-green/80 hover:text-white" %>
        <% end %>
        <% if current_user.super_admin? %>
          <%= link_to "Admin Dashboard", admin_root_path, class: "block rounded-md px-3 py-2 text-base font-medium text-gray-300 hover:bg-brand-green/80 hover:text-white" %>
          <%= link_to "Jobs", mission_control_jobs.root_path, class: "block rounded-md px-3 py-2 text-base font-medium text-gray-300 hover:bg-brand-green/80 hover:text-white" %>
        <% end %>
        <%= link_to "Terms of Service", terms_path, class: "block rounded-md px-3 py-2 text-base font-medium text-gray-300 hover:bg-brand-green/80 hover:text-white" %>
        <button type="button"
                data-action="click->theme#cycle"
                class="flex w-full items-center rounded-md px-3 py-2 text-base font-medium text-gray-300 hover:bg-brand-green/80 hover:text-white">
          <svg data-theme-target="lightIcon" class="w-5 h-5 mr-2 hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
          </svg>
          <svg data-theme-target="darkIcon" class="w-5 h-5 mr-2 hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
          </svg>
          <svg data-theme-target="systemIcon" class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z" />
          </svg>
          <span data-theme-target="label">System</span>
        </button>
        <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "block w-full text-left rounded-md px-3 py-2 text-base font-medium text-brand-orange hover:bg-brand-green/80" %>
      </div>
    </div>
  </div>
</nav>
