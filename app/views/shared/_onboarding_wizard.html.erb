<%# Onboarding wizard overlay (spotlight tour).
    Renders only when onboarding_wizard_visible? — see ApplicationController.

    Layout matches the approved mockups: a tall panel anchored to the
    bottom-left, with a phase/step badge + "lives at" breadcrumb in the
    header, the step's content in the middle, and a Back / Skip / Primary
    footer pinned to the bottom.
%>
<% if onboarding_wizard_visible? %>
  <%
    progress         = onboarding_wizard_progress
    current_step     = progress.current_step
    role             = progress.role
    completed_steps  = progress.effective_completed_steps

    image_paths = {
      "product-matching"     => image_path("onboarding/01-product-matching.png"),
      "aggregated-show"      => image_path("onboarding/02-aggregated-show.png"),
      "order-lists"          => image_path("onboarding/03-order-lists.png"),
      "order-builder"        => image_path("onboarding/04-order-builder.png"),
      "order-history"        => image_path("onboarding/05-order-history.png"),
      "reports"              => image_path("onboarding/06-reports.png"),
      "restaurants"          => image_path("onboarding/07-restaurants.png"),
      "team"                 => image_path("onboarding/08-team.png"),
      "supplier-credentials" => image_path("onboarding/09-supplier-credentials.png"),
      "new-order"            => image_path("onboarding/10-new-order.png"),
      "order-review"         => image_path("onboarding/11-order-review.png"),
    }
  %>
  <div data-controller="onboarding-wizard"
       data-onboarding-wizard-role-value="<%= role %>"
       data-onboarding-wizard-current-step-value="<%= current_step %>"
       data-onboarding-wizard-completed-steps-value="<%= completed_steps.to_json %>"
       data-onboarding-wizard-image-paths-value="<%= image_paths.to_json %>"
       data-onboarding-wizard-suppliers-url-value="<%= onboarding_suppliers_path %>"
       data-onboarding-wizard-advance-url-value="<%= advance_onboarding_progress_path %>"
       data-onboarding-wizard-complete-url-value="<%= complete_onboarding_progress_path %>"
       data-onboarding-wizard-skip-url-value="<%= skip_onboarding_progress_path %>"
       data-onboarding-wizard-csrf-value="<%= form_authenticity_token %>"
       class="onboarding-wizard"
       hidden>
    <div class="onboarding-scrim" data-onboarding-wizard-target="scrim"></div>

    <div class="onboarding-panel" data-onboarding-wizard-target="panel" role="dialog" aria-labelledby="onboarding-title" aria-modal="true">
      <%# Close × — dismisses the entire wizard. Restart Tour in the avatar
          menu brings it back. %>
      <button type="button"
              data-action="onboarding-wizard#skip"
              aria-label="Dismiss tour"
              title="Dismiss tour"
              class="onboarding-panel-close">×</button>

      <%# Header: phase + step indicator on the left, "lives at" breadcrumb on the right %>
      <div class="onboarding-panel-header">
        <span class="onboarding-panel-phase"
              data-onboarding-wizard-target="stepIndicator"></span>
        <span class="onboarding-panel-livesat"
              data-onboarding-wizard-target="livesAt"
              hidden></span>
      </div>

      <h2 id="onboarding-title"
          class="onboarding-panel-title"
          data-onboarding-wizard-target="title"></h2>

      <%# Optional embedded screenshot — populated by the controller from step.image %>
      <div class="onboarding-panel-image-slot" data-onboarding-wizard-target="image" hidden></div>

      <div class="onboarding-panel-body"
           data-onboarding-wizard-target="body"></div>

      <%# Iterative supplier picker — populated when current step is "suppliers" %>
      <div data-onboarding-wizard-target="picker" hidden></div>

      <%# Inline supplier credential form — Turbo Frame target. After save,
          controller responds with a frame containing the saved marker;
          Stimulus picks it up via turbo:frame-load and re-renders the picker. %>
      <turbo-frame id="onboarding-supplier-form"
                   data-onboarding-wizard-target="supplierForm"
                   class="onboarding-supplier-form-frame"
                   hidden></turbo-frame>

      <%# Spacer pushes the footer to the bottom of the (tall) panel %>
      <div class="onboarding-panel-spacer"></div>

      <%# Footer: Back · Primary CTA. Dismiss lives in the corner × button. %>
      <div class="onboarding-panel-footer" data-onboarding-wizard-target="footer">
        <button type="button"
                data-action="onboarding-wizard#back"
                data-onboarding-wizard-target="backCta"
                class="onboarding-panel-back">
          ← Back
        </button>
        <button type="button"
                data-action="onboarding-wizard#advance"
                data-onboarding-wizard-target="primaryCta"
                class="onboarding-panel-primary">
        </button>
      </div>
    </div>
  </div>
<% end %>
