<% if notice.present? %>
  <div class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-full max-w-lg animate-slide-down"
       data-controller="flash" data-flash-dismiss-after-value="6000">
    <div class="rounded-lg bg-green-600 shadow-xl ring-1 ring-green-700 overflow-hidden">
      <div class="px-5 py-4">
        <div class="flex items-center gap-3">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-white" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
          </div>
          <p class="text-sm font-semibold text-white flex-1"><%= notice %></p>
          <button type="button" class="flex-shrink-0 rounded-md p-1 text-green-200 hover:text-white hover:bg-green-500 transition-colors" data-action="click->flash#dismiss">
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
            </svg>
          </button>
        </div>
      </div>
      <!-- Countdown progress bar -->
      <div class="h-1 bg-green-700">
        <div class="h-full bg-green-300 rounded-r-full" data-flash-target="progress"></div>
      </div>
    </div>
  </div>
<% end %>

<% if alert.present? %>
