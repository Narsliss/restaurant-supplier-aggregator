<% content_for :title, "Search Products" %>

<%# Mobile search page — standalone version of the desktop price-check modal %>

<div class="h-2 bg-brand-green-dark -mx-4 -mt-2"></div>

<header class="bg-brand-green-dark px-4 pb-4 pt-2 -mx-4">
  <h1 class="text-white text-lg font-heading font-semibold tracking-wide">Search Products</h1>
  <p class="text-green-200 text-xs">Find items across all your suppliers</p>
</header>

<!-- Search Input -->
<div class="mt-4" data-controller="mobile-search"
     data-mobile-search-url-value="<%= catalog_search_path(format: :json) %>">
  <div class="relative">
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
    <input type="text" placeholder="Search by product name..."
           autofocus
           class="w-full pr-4 py-3 bg-white border border-gray-200 rounded-xl text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-brand-green/30 focus:border-brand-green"
           style="padding-left: 2.75rem;"
           data-mobile-search-target="input"
           data-action="input->mobile-search#search">
  </div>

  <!-- Results -->
  <div data-mobile-search-target="results" class="mt-4 space-y-2"></div>

  <!-- Empty state -->
  <div data-mobile-search-target="empty" class="mt-12 text-center hidden">
    <svg class="mx-auto h-10 w-10 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
    </svg>
    <p class="mt-2 text-sm text-gray-500">No products found</p>
  </div>

  <!-- Initial state -->
  <div data-mobile-search-target="placeholder" class="mt-12 text-center">
    <svg class="mx-auto h-10 w-10 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
    </svg>
    <p class="mt-2 text-sm text-gray-500">Type at least 2 characters to search</p>
    <p class="text-xs text-gray-400 mt-1">Searches across all connected suppliers</p>
  </div>
</div>

<%# Fallback: ensure mobile-search controller is registered even if importmap cache is stale %>
<script type="module">
  import { Application } from "@hotwired/stimulus"
  const app = window.Stimulus || Application.start()
  if (!app.router.modulesByIdentifier.has("mobile-search")) {
    const mod = await import("controllers/mobile_search_controller")
    app.register("mobile-search", mod.default)
  }
</script>
