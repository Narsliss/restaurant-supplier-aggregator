<%# Matching modal body, loaded into the #match_modal Turbo Frame on row click.
    This is the sole editor for a match: canonical name + canonical image +
    per-supplier matching. Locals: match, aggregated_list %>
<% suppliers = aggregated_list.supplier_lists.map(&:supplier).uniq %>
<% search_url = supplier_items_search_aggregated_list_path(aggregated_list) %>
<% cheapest = match.cheapest_supplier&.dig(:supplier) %>
<% readonly = aggregated_list.promoted? %>
<turbo-frame id="match_modal">
  <div data-controller="match-modal image-poll"
       data-action="click->match-modal#backdrop"
       class="fixed inset-0 z-50 flex items-start justify-center pt-[6vh] px-4 bg-black/50">
    <div class="relative bg-white rounded-xl shadow-2xl border border-gray-200 w-full max-w-5xl max-h-[88vh] overflow-y-auto">
      <%# Header %>
      <div class="flex items-start justify-between gap-3 p-4 border-b border-gray-100 sticky top-0 bg-white z-10">
        <div class="flex items-center gap-3 min-w-0">
          <img id="match_thumb_modal_<%= match.id %>"
               src="<%= product_thumb_url(match.canonical_image_source, mirror: true) %>"
               data-product-thumb-id="<%= match.canonical_image_source&.id %>"
               class="w-12 h-12 rounded object-cover border border-gray-200 bg-gray-50 shrink-0">
          <div class="min-w-0">
            <h2 id="match_title_<%= match.id %>" class="text-base font-semibold text-gray-900 truncate"><%= match.display_name %></h2>
            <p class="text-xs text-gray-500"><%= pluralize(match.product_match_items.size, "matched supplier") %></p>
          </div>
        </div>
        <button type="button" data-action="match-modal#close"
                class="p-1 rounded text-gray-400 hover:text-gray-700 hover:bg-gray-100 shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <div class="p-5 space-y-5">
        <%# Canonical name + canonical image, side by side on wider screens %>
        <div class="grid lg:grid-cols-2 gap-5">
          <% unless readonly %>
            <div>
              <label class="block text-xs font-medium text-gray-500 mb-1">Canonical name</label>
              <%= form_with url: rename_aggregated_list_product_match_path(aggregated_list, match), method: :patch, class: "flex gap-2" do %>
                <input type="text" name="canonical_name" value="<%= match.display_name %>"
                       class="flex-1 text-sm border border-gray-200 rounded px-2.5 py-1.5 focus:outline-none focus:ring-1 focus:ring-brand-green">
                <button type="submit" class="text-sm font-medium text-white bg-brand-green rounded px-3 py-1.5 hover:bg-brand-green-dark">Save</button>
              <% end %>
            </div>
          <% end %>

          <%# Canonical image picker (the swap) %>
          <%= render "product_matches/canonical_picker", match: match, aggregated_list: aggregated_list %>
        </div>

        <%# Per-supplier matching — wide grid, each cell houses the product image %>
        <div>
          <p class="text-xs font-medium text-gray-500 mb-2">Suppliers</p>
          <div class="grid gap-3" style="grid-template-columns: repeat(<%= [suppliers.size, 1].max %>, minmax(0, 1fr));">
            <% suppliers.each do |supplier| %>
              <% pmi = match.product_match_items.detect { |p| p.supplier_id == supplier.id } %>
              <% item = pmi&.supplier_list_item %>
              <%= render "aggregated_lists/supplier_cell_card",
                         product_match: match, supplier: supplier, item: item, pmi: pmi,
                         search_url: search_url, supplier_id: supplier.id,
                         is_cheapest: (item && cheapest == supplier), is_most_expensive: false,
                         readonly: readonly, show_image: true %>
            <% end %>
          </div>
        </div>

        <%# Remove this product from the list %>
        <% unless readonly %>
          <div class="pt-3 border-t border-gray-100">
            <button type="button"
                    class="inline-flex items-center gap-1.5 text-sm font-medium text-red-600 hover:text-red-700 hover:bg-red-50 rounded px-2 py-1.5 transition-colors"
                    data-dismiss-url="<%= reject_aggregated_list_product_match_path(aggregated_list, match) %>"
                    data-match-row="<%= dom_id(match) %>"
                    data-match-name="<%= match.display_name %>"
                    onclick="dismissMatch(this)">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/>
              </svg>
              Remove from list
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</turbo-frame>
