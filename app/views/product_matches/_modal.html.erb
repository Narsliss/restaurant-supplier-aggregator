<%# Matching modal body, loaded into the #match_modal Turbo Frame on row click.
    Locals: match, aggregated_list %>
<turbo-frame id="match_modal">
  <div data-controller="match-modal"
       data-action="click->match-modal#backdrop"
       class="fixed inset-0 z-50 flex items-start justify-center pt-[10vh] px-4 bg-black/50">
    <div class="relative bg-white rounded-xl shadow-2xl border border-gray-200 w-full max-w-lg max-h-[80vh] overflow-y-auto">
      <%# Header %>
      <div class="flex items-start justify-between gap-3 p-4 border-b border-gray-100 sticky top-0 bg-white">
        <div class="flex items-center gap-3 min-w-0">
          <img id="match_thumb_modal_<%= match.id %>"
               src="<%= product_thumb_url(match.canonical_image_source) %>"
               class="w-12 h-12 rounded object-cover border border-gray-200 bg-gray-50 shrink-0">
          <div class="min-w-0">
            <h2 class="text-base font-semibold text-gray-900 truncate"><%= match.display_name %></h2>
            <p class="text-xs text-gray-500"><%= pluralize(match.product_match_items.size, "matched supplier") %></p>
          </div>
        </div>
        <button type="button" data-action="match-modal#close"
                class="p-1 rounded text-gray-400 hover:text-gray-700 hover:bg-gray-100 shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <div class="p-4 space-y-5">
        <%# Canonical image picker (the swap) %>
        <%= render "product_matches/canonical_picker", match: match, aggregated_list: aggregated_list %>

        <%# Matched items, each with its own supplier thumbnail %>
        <div>
          <p class="text-xs font-medium text-gray-500 mb-2">Matched items</p>
          <ul class="space-y-2">
            <% match.product_match_items.each do |pmi| %>
              <% sp = pmi.supplier_list_item&.supplier_product %>
              <li class="flex items-center gap-3">
                <img src="<%= product_thumb_url(sp) %>" alt=""
                     class="w-10 h-10 rounded object-cover border border-gray-200 bg-gray-50 shrink-0">
                <div class="min-w-0">
                  <p class="text-sm text-gray-900 truncate"><%= pmi.supplier_list_item&.name %></p>
                  <p class="text-xs text-gray-500"><%= pmi.supplier&.try(:short_name) || pmi.supplier&.name %></p>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</turbo-frame>
