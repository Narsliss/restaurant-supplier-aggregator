<%# Canonical-image picker (modal). Click a supplier's thumbnail to make it the
    canonical image. Locals: match, aggregated_list %>
<div id="canonical_picker_<%= match.id %>">
  <div class="flex items-center gap-4">
    <img src="<%= product_thumb_url(match.canonical_image_source, mirror: true) %>"
         alt="canonical"
         class="w-20 h-20 rounded-lg object-cover border border-gray-200 bg-gray-50 shrink-0">
    <div class="min-w-0">
      <p class="text-sm font-medium text-gray-900">Canonical image</p>
      <p class="text-xs text-gray-500 leading-snug">
        Pick which supplier’s photo represents this item in order lists &amp; the cart.
      </p>
    </div>
  </div>

  <% choices = match.canonical_image_choices %>
  <% if choices.any? %>
    <div class="mt-3 flex flex-wrap gap-2">
      <% current = match.canonical_image_source&.id %>
      <% choices.each do |sp| %>
        <% selected = current == sp.id %>
        <%= button_to set_canonical_image_aggregated_list_product_match_path(aggregated_list, match),
              params: { supplier_product_id: sp.id }, method: :post,
              class: "block rounded-lg border-2 p-0.5 transition-colors #{selected ? 'border-brand-orange ring-2 ring-brand-orange/30' : 'border-gray-200 hover:border-gray-400'}",
              title: sp.supplier_name.to_s do %>
          <img src="<%= product_thumb_url(sp, mirror: true) %>" alt="<%= sp.supplier_name %>"
               class="w-14 h-14 rounded object-cover bg-gray-50">
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="mt-2 text-xs text-gray-400">No supplier images available for this match yet.</p>
  <% end %>
</div>
