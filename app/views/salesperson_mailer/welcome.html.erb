<div style="max-width: 600px; margin: 0 auto; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1f2937;">
  <div style="padding: 32px 24px;">
    <h1 style="font-size: 24px; font-weight: 700; margin-bottom: 16px; color: #111827;">
      Welcome to EnPlace Pro CRM
    </h1>

    <p style="font-size: 16px; line-height: 1.6; color: #4b5563; margin-bottom: 16px;">
      Hi <%= @user.first_name %>,
    </p>

    <p style="font-size: 16px; line-height: 1.6; color: #4b5563; margin-bottom: 16px;">
      You've been added as a salesperson on EnPlace Pro. Here are your login details:
    </p>

    <div style="background-color: #f3f4f6; border-radius: 8px; padding: 16px 20px; margin-bottom: 24px;">
      <p style="font-size: 14px; color: #6b7280; margin: 0 0 8px 0;">
        <strong style="color: #374151;">Email:</strong> <%= @user.email %>
      </p>
      <p style="font-size: 14px; color: #6b7280; margin: 0;">
        <strong style="color: #374151;">Password:</strong> <%= @password %>
      </p>
    </div>

    <div style="text-align: center; margin-bottom: 24px;">
      <a href="<%= @sign_in_url %>" style="display: inline-block; background-color: #15803d; color: #ffffff; font-weight: 600; padding: 12px 24px; border-radius: 8px; text-decoration: none; font-size: 16px;">
        Sign In to CRM
      </a>
    </div>

    <p style="font-size: 14px; color: #9ca3af; line-height: 1.5;">
      We recommend changing your password after your first login. You can do this from Settings once you're signed in.
    </p>
  </div>
</div>
