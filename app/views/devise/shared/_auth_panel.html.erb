<%# Left panel with branding — shared across all auth pages %>
<div class="hidden lg:flex lg:w-1/2 relative overflow-hidden" style="background-color: #3A6147;">
  <!-- Subtle accent glows -->
  <div class="absolute -bottom-24 -left-24 w-80 h-80 rounded-full blur-3xl" style="background-color: rgba(212,148,58,0.08);"></div>
  <div class="absolute -top-24 -right-24 w-80 h-80 rounded-full blur-3xl" style="background-color: rgba(74,124,89,0.1);"></div>

  <div class="relative z-10 flex flex-col justify-between p-12 w-full">
    <div>
      <%= render "shared/logo", variant: :login %>
      <p class="mt-3 text-lg" style="color: #9ca3af;">Mise en place for your kitchen orders</p>
    </div>

    <%# TODO: REMOVE — temporary VORTEX easter egg, remove before long-term use %>
    <div class="flex-1 flex items-center justify-center">
      <div class="flex flex-col items-center">
        <div style="font-family: Impact, 'Arial Black', sans-serif; font-size: 8rem; font-weight: 900; letter-spacing: 0.1em; color: #ff00ff; text-shadow: 0 0 20px #ff00ff, 0 0 40px #00ffff, 0 0 60px #ffff00; animation: vortex-flash 0.5s infinite alternate; transform: rotate(-5deg);">
          VORTEX
        </div>
        <img src="https://upload.wikimedia.org/wikipedia/commons/6/60/Galea_musteloides1.jpg"
             alt="Cuis (Galea musteloides)"
             style="margin-top: 1.5rem; max-width: 320px; border-radius: 0.75rem; box-shadow: 0 0 30px rgba(255,0,255,0.6);">
      </div>
    </div>
    <style>
      @keyframes vortex-flash {
        0%   { opacity: 1; color: #ff00ff; text-shadow: 0 0 20px #ff00ff, 0 0 40px #00ffff, 0 0 60px #ffff00; transform: rotate(-5deg) scale(1); }
        50%  { opacity: 0.7; color: #00ffff; text-shadow: 0 0 20px #ffff00, 0 0 40px #ff00ff, 0 0 60px #00ffff; transform: rotate(-3deg) scale(1.05); }
        100% { opacity: 1; color: #ffff00; text-shadow: 0 0 20px #00ffff, 0 0 40px #ffff00, 0 0 60px #ff00ff; transform: rotate(-7deg) scale(1.1); }
      }
    </style>

    <div class="space-y-8">
      <h2 class="text-2xl text-white font-heading leading-relaxed">
        Streamline your procurement across multiple suppliers.
      </h2>
      <p style="color: #9ca3af;" class="leading-relaxed">
        Compare prices, manage orders, and save time &mdash; all from one dashboard.
      </p>
      <div class="flex flex-col space-y-3 text-sm">
        <div class="flex items-center space-x-3">
          <div class="flex-shrink-0 h-8 w-8 rounded-lg flex items-center justify-center" style="background-color: rgba(74,124,89,0.25);">
            <svg class="h-4 w-4" style="color: #5A9469;" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
            </svg>
          </div>
          <span style="color: #d1d5db;">Order from multiple suppliers at once</span>
        </div>
        <div class="flex items-center space-x-3">
          <div class="flex-shrink-0 h-8 w-8 rounded-lg flex items-center justify-center" style="background-color: rgba(74,124,89,0.25);">
            <svg class="h-4 w-4" style="color: #5A9469;" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
            </svg>
          </div>
          <span style="color: #d1d5db;">Compare prices across your vendors</span>
        </div>
        <div class="flex items-center space-x-3">
          <div class="flex-shrink-0 h-8 w-8 rounded-lg flex items-center justify-center" style="background-color: rgba(74,124,89,0.25);">
            <svg class="h-4 w-4" style="color: #5A9469;" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
            </svg>
          </div>
          <span style="color: #d1d5db;">Track every order in one place</span>
        </div>
      </div>
    </div>

    <p class="text-xs" style="color: #6b7280;">&copy; <%= Date.current.year %> EnPlace Pro</p>
  </div>
</div>
