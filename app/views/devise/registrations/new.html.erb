<% content_for :title, (@invitation ? "Join " + @invitation.organization.name : "Sign Up") %>

<div class="flex min-h-screen">
  <% if @invitation %>
    <%# ====== Left panel: Invitation-specific branding ====== %>
    <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden" style="background-color: #3A6147;">
      <div class="absolute -bottom-24 -left-24 w-80 h-80 rounded-full blur-3xl" style="background-color: rgba(212,148,58,0.08);"></div>
      <div class="absolute -top-24 -right-24 w-80 h-80 rounded-full blur-3xl" style="background-color: rgba(74,124,89,0.1);"></div>

      <div class="relative z-10 flex flex-col justify-between p-12 w-full">
        <div>
          <%= render "shared/logo", variant: :login %>
          <p class="mt-3 text-lg" style="color: #9ca3af;">Restaurant Supplier Aggregator</p>
        </div>

        <div class="space-y-8">
          <h2 class="text-2xl text-white font-heading leading-relaxed">
            You've been invited to join<br>
            <span class="text-3xl font-bold"><%= @invitation.organization.name %></span>
          </h2>
          <div class="rounded-xl p-5" style="background-color: rgba(255,255,255,0.08);">
            <p style="color: #d1d5db;" class="text-sm mb-3">
              <strong class="text-white"><%= @invitation.invited_by.first_name || @invitation.invited_by.email %></strong>
              invited you as a <strong class="text-white"><%= @invitation.role.capitalize %></strong>
            </p>
            <% if @invitation.role == 'chef' && @invitation.location.present? %>
              <div class="flex items-center gap-2 text-sm" style="color: #9ca3af;">
                <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
                <span>Assigned to <strong class="text-white"><%= @invitation.location.name %></strong></span>
              </div>
            <% end %>
          </div>
          <p style="color: #9ca3af;" class="leading-relaxed">
            Create your account to start comparing prices and placing orders.
          </p>
        </div>

        <p class="text-xs" style="color: #6b7280;">&copy; <%= Date.current.year %> EnPlace Pro</p>
      </div>
    </div>
  <% else %>
    <%# ====== Standard auth panel for regular sign-ups ====== %>
    <%= render "devise/shared/auth_panel" %>
  <% end %>

  <!-- Right: Registration form -->
  <div class="flex flex-1 flex-col justify-center px-6 py-12 lg:flex-none lg:w-1/2 lg:px-20 xl:px-24">
    <div class="mx-auto w-full max-w-sm lg:w-96">
      <!-- Mobile logo -->
      <div class="lg:hidden mb-10 text-center">
        <%= render "shared/logo", variant: :login_mobile %>
      </div>

      <% if @invitation %>
        <%# ====== Invitation header ====== %>
        <div>
          <h2 class="text-3xl font-heading font-bold tracking-tight text-gray-900">
            Join <%= @invitation.organization.name %>
          </h2>
          <p class="mt-2 text-sm text-gray-500">
            Create your account to get started
          </p>
        </div>

        <%# Mobile-only invitation context (desktop shows it on the left panel) %>
        <div class="lg:hidden mt-4 p-4 bg-green-50 rounded-lg border border-green-200">
          <p class="text-sm text-green-900">
            <strong><%= @invitation.invited_by.first_name || @invitation.invited_by.email %></strong>
            invited you as a <strong><%= @invitation.role.capitalize %></strong>
            <% if @invitation.role == 'chef' && @invitation.location.present? %>
              at <strong><%= @invitation.location.name %></strong>
            <% end %>
          </p>
        </div>
      <% else %>
        <%# ====== Standard sign-up header ====== %>
        <div>
          <h2 class="text-3xl font-heading font-bold tracking-tight text-gray-900">
            Create your account
          </h2>
          <p class="mt-2 text-sm text-gray-500">
            Start your 14-day free trial — no credit card required
          </p>
        </div>

        <!-- Pricing highlight (only for direct sign-ups, not invitations) -->
        <div class="mt-4 p-4 bg-blue-50 rounded-lg border border-blue-200">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-blue-900">EnPlace Pro</p>
              <p class="text-xs text-blue-700">Unlimited suppliers & orders</p>
            </div>
            <div class="text-right">
              <span class="text-lg font-bold text-blue-900">$99</span>
              <span class="text-sm text-blue-700">/mo</span>
            </div>
          </div>
        </div>
      <% end %>

      <%= render "devise/shared/error_messages" %>

      <div class="mt-8">
        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>

          <%# Name fields — required for all sign-ups %>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= f.label :first_name, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1.5">
                <%= f.text_field :first_name, autofocus: true, required: true, autocomplete: "given-name",
                    class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm py-2.5 px-3",
                    placeholder: "First name" %>
              </div>
            </div>
            <div>
              <%= f.label :last_name, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1.5">
                <%= f.text_field :last_name, required: true, autocomplete: "family-name",
                    class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm py-2.5 px-3",
                    placeholder: "Last name" %>
              </div>
            </div>
          </div>

          <% if @invitation %>
            <%# Email pre-filled and read-only for invited users %>
            <div>
              <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1.5">
                <%= f.email_field :email, readonly: true, autocomplete: "email",
                    class: "block w-full rounded-lg border-gray-200 bg-gray-50 text-gray-500 shadow-sm text-sm py-2.5 px-3 cursor-not-allowed" %>
              </div>
              <p class="mt-1 text-xs text-gray-400">This is the email your invitation was sent to</p>
            </div>
          <% else %>
            <%# Standard email field %>
            <div>
              <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1.5">
                <%= f.email_field :email, autocomplete: "email",
                    class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm py-2.5 px-3",
                    placeholder: "you@restaurant.com" %>
              </div>
            </div>
          <% end %>

          <div>
            <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1.5">
              <%= f.password_field :password, autocomplete: "new-password", autofocus: !!@invitation,
                  class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm py-2.5 px-3",
                  placeholder: "At least 6 characters" %>
            </div>
            <p class="mt-1 text-xs text-gray-400"><%= @minimum_password_length %> characters minimum</p>
          </div>

          <div>
            <%= f.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1.5">
              <%= f.password_field :password_confirmation, autocomplete: "new-password",
                  class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm py-2.5 px-3" %>
            </div>
          </div>

          <% submit_label = @invitation ? "Join " + @invitation.organization.name : "Create account" %>
          <div class="pt-1">
            <%= f.submit submit_label,
                class: "flex w-full justify-center rounded-lg bg-brand-orange px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-orange-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-orange transition-colors cursor-pointer" %>
          </div>
        <% end %>

        <% unless @invitation %>
          <p class="mt-8 text-center text-sm text-gray-500">
            Already have an account?
            <%= link_to "Sign in", new_session_path(resource_name),
                class: "font-semibold text-brand-orange hover:text-brand-orange-dark transition-colors" %>
          </p>
        <% end %>
      </div>

      <% unless @invitation %>
        <!-- Supplier logos (only for direct sign-ups) -->
        <div class="mt-10 pt-6 border-t border-gray-200">
          <p class="text-xs text-gray-400 text-center mb-4 uppercase tracking-wider">Supported Suppliers</p>
          <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-sm text-gray-400">
            <span class="font-medium">US Foods</span>
            <span class="text-brand-green text-xs">&#9679;</span>
            <span class="font-medium">Chef's Warehouse</span>
            <span class="text-brand-green text-xs">&#9679;</span>
            <span class="font-medium">What Chefs Want</span>
            <span class="text-brand-green text-xs">&#9679;</span>
            <span class="font-medium">Premiere Produce</span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
