<%# Left column of a product match card row.
    Locals:
      match           — the ProductMatch
      aggregated_list — the AggregatedList (for routes + promoted? check)
%>
<div class="sm:w-48 md:w-56 shrink-0 p-4 border-b sm:border-b-0 sm:border-r border-gray-100">
  <div class="flex items-start gap-1.5">
    <div class="flex-1 min-w-0">
      <% if aggregated_list.promoted? %>
        <h3 class="text-sm font-semibold text-gray-900 leading-tight"><%= match.display_name %></h3>
      <% else %>
        <div data-controller="inline-edit"
             data-inline-edit-url-value="<%= rename_aggregated_list_product_match_path(aggregated_list, match) %>"
             data-inline-edit-field-value="canonical_name"
             class="group">
          <h3 class="text-sm font-semibold text-gray-900 leading-tight cursor-pointer hover:text-brand-orange transition-colors underline decoration-dashed decoration-gray-300 decoration-1 underline-offset-2 inline-flex items-start gap-1"
              data-inline-edit-target="display"
              data-action="click->inline-edit#edit"
              title="Click to rename">
            <span><%= match.display_name %></span>
            <svg class="w-3 h-3 shrink-0 mt-0.5 text-gray-300 group-hover:text-brand-orange transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
            </svg>
          </h3>
          <input type="text"
                 data-inline-edit-target="input"
                 data-action="blur->inline-edit#save keydown->inline-edit#keydown"
                 class="hidden text-sm font-semibold text-gray-900 bg-white border border-brand-green rounded px-1.5 py-0.5 focus:outline-none focus:ring-1 focus:ring-brand-green w-full mt-1">
        </div>
      <% end %>
    </div>
    <% unless aggregated_list.promoted? %>
      <button type="button"
              class="shrink-0 p-1 rounded text-gray-300 hover:text-red-500 hover:bg-red-50 transition-colors"
              title="Remove from list"
              data-dismiss-url="<%= reject_aggregated_list_product_match_path(aggregated_list, match) %>"
              data-match-row="<%= dom_id(match) %>"
              data-match-name="<%= match.display_name %>"
              onclick="dismissMatch(this)">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    <% end %>
  </div>

  <div class="mt-1.5 flex items-center gap-2 flex-wrap">
    <% if match.unmatched? %>
      <span class="inline-flex items-center rounded-full bg-amber-100 px-2 py-0.5 text-[10px] font-medium text-amber-700">Unmatched</span>
    <% end %>
    <% if match.confidence_score && match.confidence_score > 0 %>
      <span class="text-xs <%= match.confidence_score >= 0.8 ? 'text-green-600' : 'text-amber-600' %>">
        <%= (match.confidence_score * 100).round %>%
      </span>
    <% end %>
  </div>
</div>
