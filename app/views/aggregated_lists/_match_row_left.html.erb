<%# Left column of a product match card row. The whole cell is the trigger that
    opens the matching modal (name + image + per-supplier matching). Locals:
      match           — the ProductMatch
      aggregated_list — the AggregatedList (for routes + promoted? check)
%>
<% editable = !aggregated_list.promoted? %>
<% attrs = { id: "match_left_#{match.id}",
             class: "sm:w-48 md:w-56 shrink-0 p-4 border-b sm:border-b-0 sm:border-r border-gray-100" } %>
<% if editable %>
  <% attrs[:class] += " cursor-pointer hover:bg-brand-orange/5 transition-colors group" %>
  <% attrs[:title] = "Click to edit match & image" %>
  <% attrs[:data] = { controller: "open-match-modal",
                      open_match_modal_url_value: edit_aggregated_list_product_match_path(aggregated_list, match),
                      action: "click->open-match-modal#open" } %>
<% end %>

<%= tag.div(**attrs) do %>
  <div class="flex items-start gap-2">
    <%= render "product_matches/match_thumb", match: match %>

    <div class="flex-1 min-w-0">
      <h3 class="text-sm font-semibold text-gray-900 leading-tight"><%= match.display_name %></h3>
      <div class="mt-1.5 flex items-center gap-2 flex-wrap">
        <% if match.unmatched? %>
          <span class="inline-flex items-center rounded-full bg-amber-100 px-2 py-0.5 text-[10px] font-medium text-amber-700">Unmatched</span>
        <% end %>
        <% if match.confidence_score && match.confidence_score > 0 %>
          <span class="text-xs <%= match.confidence_score >= 0.8 ? 'text-green-600' : 'text-amber-600' %>">
            <%= (match.confidence_score * 100).round %>%
          </span>
        <% end %>
      </div>
    </div>

    <% if editable %>
      <%# Edit affordance — makes it clear the row is clickable (opens the modal,
          where name/image/matching/remove all live) %>
      <span class="shrink-0 inline-flex items-center gap-0.5 text-[10px] font-medium text-gray-300 group-hover:text-brand-orange transition-colors" aria-hidden="true">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10"/>
        </svg>
      </span>
    <% end %>
  </div>
<% end %>
