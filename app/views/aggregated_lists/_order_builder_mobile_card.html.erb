<%# Wired from mockups/mobile/order-builder-a.html product card design %>
<% cheapest = match.cheapest_supplier %>
<% cheapest_price = cheapest&.dig(:price) || 0 %>
<% cheapest_supplier_id = cheapest&.dig(:supplier)&.id %>
<% current_qty = quantities[match.id.to_s] || 0 %>
<% has_quantity = current_qty.to_i > 0 %>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm mb-3 overflow-hidden <%= has_quantity ? '' : '' %>"
     data-order-builder-row data-product-name="<%= match.display_name.downcase %>">
  <div class="p-3">
    <%# Product name + line total %>
    <div class="flex items-start justify-between mb-2">
      <div class="flex-1 min-w-0 pr-2">
        <div class="flex items-center gap-1.5">
          <button type="button"
                  class="flex-shrink-0 focus:outline-none"
                  data-action="click->order-builder#toggleFavorite"
                  data-supplier-product-id="<%= match_sp_id %>"
                  data-favorited="<%= user_favorited ? 'true' : 'false' %>">
            <% if frequently_ordered || user_favorited %>
              <svg class="w-4 h-4 text-brand-orange" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <% else %>
              <svg class="w-4 h-4 text-gray-300" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <% end %>
          </button>
          <p class="text-sm font-semibold text-gray-900 truncate"><%= match.display_name %></p>
        </div>
      </div>
      <% if has_quantity %>
        <p class="text-sm font-bold text-brand-navy whitespace-nowrap" data-order-builder-target="lineTotal"><%= number_to_currency(cheapest_price * current_qty.to_i) %></p>
      <% else %>
        <span data-order-builder-target="lineTotal"></span>
      <% end %>
    </div>

    <%# Supplier price pills (horizontal scroll — the core comparison UI) %>
    <div class="flex gap-1.5 overflow-x-auto hide-scrollbar mb-3">
      <% suppliers.each do |supplier| %>
        <% item = match.item_for_supplier(supplier) %>
        <% if item %>
          <% sp = item.supplier_product %>
          <% effective_price = item.price || sp&.current_price %>
          <% effective_pack_size = item.pack_size || sp&.pack_size %>
          <% in_stock = sp ? sp.in_stock : item.in_stock %>
          <% if effective_price %>
            <% is_cheapest = cheapest && cheapest[:supplier] == supplier && match.price_spread && match.price_spread > 0 %>
            <% is_default = cheapest && cheapest[:supplier] == supplier %>
            <div class="flex-shrink-0 rounded-lg px-2 py-1.5 cursor-pointer transition-all
                        <%= is_default ? 'bg-green-50 border border-green-200' : 'bg-gray-50 border border-gray-200' %>
                        <%= is_cheapest ? 'best-price' : '' %>
                        <%= in_stock == false ? 'opacity-50' : '' %>"
                 data-action="click->order-builder#selectSupplier"
                 data-supplier-price="<%= item.price_unit.present? ? item.estimated_total_price : effective_price %>"
                 data-supplier-id-value="<%= supplier.id %>"
                 data-match-id="<%= match.id %>"
                 data-order-builder-target="supplierCell"
                 data-default="<%= is_default %>">
              <p class="text-[9px] font-bold uppercase <%= is_default ? 'text-brand-green' : 'text-gray-400' %>"><%= supplier.name.first(3).upcase %></p>
              <p class="text-xs font-bold text-gray-900">
                <%= item.formatted_price %><%= render "aggregated_lists/price_direction_arrow", direction: item.price_direction %>
                <% if item.formatted_per_unit_price %>
                  <span class="text-[9px] text-gray-400 font-normal"><%= item.formatted_per_unit_price %></span>
                <% end %>
              </p>
              <% if effective_pack_size.present? %>
                <p class="text-[9px] text-gray-500"><%= effective_pack_size %></p>
              <% end %>
              <% unless in_stock %>
                <p class="text-[9px] text-red-500 font-bold">Out of stock</p>
              <% end %>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <%# Quantity controls %>
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-0">
        <button type="button"
                data-action="order-builder#decrement"
                class="w-8 h-8 bg-gray-100 rounded-l-lg flex items-center justify-center text-gray-600 font-bold active:bg-gray-200">−</button>
        <input type="number"
               value="<%= current_qty %>"
               min="0"
               class="w-12 h-8 border-y border-gray-200 text-center text-sm font-semibold focus:outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none <%= has_quantity ? '' : 'text-gray-400' %>"
               data-order-builder-target="quantityInput"
               data-action="input->order-builder#updateTotals"
               data-price="<%= cheapest_price %>"
               data-supplier-id="<%= cheapest_supplier_id %>"
               data-match-id="<%= match.id %>"
               data-mobile="true">
        <button type="button"
                data-action="order-builder#increment"
                class="w-8 h-8 bg-gray-100 rounded-r-lg flex items-center justify-center text-gray-600 font-bold active:bg-gray-200">+</button>
      </div>
      <% if has_quantity %>
        <button type="button"
                data-action="order-builder#clearQuantity"
                class="text-[10px] text-red-400 font-medium px-2 py-1">Clear</button>
      <% end %>
    </div>
  </div>
</div>
