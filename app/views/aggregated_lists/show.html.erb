<div class="py-6">
  <div class="mb-6">
    <%= link_to "&larr; Supplier Lists".html_safe, supplier_lists_path, class: "text-sm text-brand-orange hover:text-brand-orange-light" %>
  </div>

  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-heading font-bold text-gray-900"><%= @aggregated_list.name %></h1>
      <p class="mt-1 text-sm text-gray-500">
        <%= @suppliers.map(&:name).join(" vs ") %>
        <span class="mx-1">&middot;</span>
        <%= pluralize(@stats[:total], "product") %>
      </p>
    </div>
    <div class="flex gap-3">
      <% if @aggregated_list.matching? || @aggregated_list.searching_catalog? %>
        <span class="inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium rounded-md bg-gray-100 text-gray-400 cursor-not-allowed">
          <svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Processing...
        </span>
      <% else %>
        <%= link_to "Edit", edit_aggregated_list_path(@aggregated_list),
            class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors" %>
        <%= button_to "Re-match", run_matching_aggregated_list_path(@aggregated_list),
            method: :post,
            class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md border border-brand-orange text-brand-orange hover:bg-brand-orange hover:text-white transition-colors" %>
        <% if @aggregated_list.matched? %>
          <%= link_to supplier_lists_path(notice: "#{@aggregated_list.name} matching approved."),
              class: "inline-flex items-center px-4 py-1.5 text-sm font-semibold rounded-md bg-brand-green text-white hover:bg-brand-green-dark transition-colors shadow-sm" do %>
            ✓ Approve Matching
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="grid grid-cols-3 gap-4 mb-6">
    <div class="bg-white shadow rounded-lg p-4 text-center">
      <p class="text-2xl font-heading font-bold text-gray-900"><%= @stats[:total] %></p>
      <p class="text-sm text-gray-500">Total Products</p>
    </div>
    <div class="bg-white shadow rounded-lg p-4 text-center">
      <p class="text-2xl font-heading font-bold text-green-600"><%= @stats[:matched] %></p>
      <p class="text-sm text-gray-500">Matched</p>
    </div>
    <div class="bg-white shadow rounded-lg p-4 text-center">
      <p class="text-2xl font-heading font-bold text-amber-600"><%= @stats[:unmatched] %></p>
      <p class="text-sm text-gray-500">Unmatched</p>
    </div>
  </div>

  <% if @aggregated_list.matching? %>
    <div class="relative overflow-hidden rounded-lg bg-brand-orange/10 border-2 border-brand-orange p-5 mb-6 shadow-md"
         data-controller="auto-refresh"
         data-auto-refresh-interval-value="10000">
      <div class="absolute top-0 left-0 h-1 w-full bg-brand-orange/20">
        <div class="h-full w-1/3 bg-brand-orange rounded-r animate-progress-bar"></div>
      </div>
      <div class="flex items-center gap-4">
        <div class="shrink-0">
          <svg class="h-8 w-8 animate-spin text-brand-orange" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>
        <div>
          <p class="text-base font-semibold text-gray-900">Processing — please wait</p>
          <p class="text-sm text-gray-600 mt-0.5">Matching products and searching catalog. This can take 2-5 minutes. The page will refresh automatically when complete.</p>
        </div>
      </div>
    </div>
  <% end %>

  <% if @aggregated_list.searching_catalog? %>
    <div class="relative overflow-hidden rounded-lg bg-blue-50 border-2 border-blue-200 p-5 mb-6 shadow-md"
         data-controller="auto-refresh"
         data-auto-refresh-interval-value="10000">
      <div class="absolute top-0 left-0 h-1 w-full bg-blue-200">
        <div class="h-full w-1/3 bg-blue-500 rounded-r animate-progress-bar"></div>
      </div>
      <div class="flex items-center gap-4">
        <div class="shrink-0">
          <svg class="h-8 w-8 animate-spin text-blue-600" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>
        <div>
          <p class="text-base font-semibold text-blue-800">Searching full catalog — please wait</p>
          <p class="text-sm text-blue-600 mt-0.5">Searching supplier products for matches to unmatched items. This can take 1-2 minutes. The page will refresh automatically when complete.</p>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Match comparison table -->
  <% if @product_matches.any? %>
    <div class="bg-white shadow rounded-lg overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50 sticky top-0 z-20">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider sticky left-0 bg-gray-50 z-30">Product</th>
            <% @suppliers.each do |supplier| %>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider min-w-[200px] bg-gray-50"><%= supplier.name %></th>
            <% end %>
            <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-32 bg-gray-50">Status</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @product_matches.each do |match| %>
            <tr id="<%= dom_id(match) %>" class="<%= match.unmatched? ? 'bg-amber-50/50' : '' %> hover:bg-gray-50">
              <!-- Canonical name column -->
              <td class="px-4 py-3 sticky left-0 bg-inherit z-10">
                <div class="text-sm font-medium text-gray-900"><%= match.display_name %></div>
                <div class="text-xs text-gray-500">
                  <% if match.confidence_score && match.confidence_score > 0 %>
                    <span class="<%= match.confidence_score >= 0.8 ? 'text-green-600' : 'text-amber-600' %>">
                      <%= (match.confidence_score * 100).round %>% confidence
                    </span>
                  <% end %>
                </div>
              </td>

              <!-- Supplier columns -->
              <% price_info = @price_data[match.id] %>
              <% @suppliers.each do |supplier| %>
                <td class="px-4 py-3" id="match_<%= match.id %>_supplier_<%= supplier.id %>">
                  <% lookup = @match_supplier_map.dig(match.id, supplier.id) %>
                  <% item = lookup&.dig(:item) %>
                  <% pmi = lookup&.dig(:pmi) %>
                  <% available_items = @items_by_supplier[supplier.id] || [] %>
                  <% if item %>
                    <% is_cheapest = price_info[:cheapest_supplier] == supplier && price_info[:spread] && price_info[:spread] > 0 %>
                    <% is_most_expensive = price_info[:most_expensive_supplier] == supplier && price_info[:spread] && price_info[:spread] > 0 %>

                    <div class="text-sm text-gray-900"><%= item.name.truncate(60) %></div>
                    <div class="text-xs text-gray-500">
                      <%= item.pack_size %>
                      <% if item.catalog_search? %>
                        <span class="ml-1 inline-flex items-center rounded px-1 py-0.5 text-[10px] font-medium bg-indigo-100 text-indigo-700">catalog</span>
                      <% end %>
                    </div>
                    <div class="mt-1">
                      <span class="text-sm font-semibold <%= is_cheapest ? 'text-green-700' : is_most_expensive ? 'text-red-600' : 'text-gray-900' %>">
                        <%= item.formatted_price %><%= render "aggregated_lists/price_direction_arrow", direction: item.price_direction %>
                      </span>
                      <% unless item.in_stock %>
                        <span class="ml-1 text-xs text-red-500">Out of stock</span>
                      <% end %>
                    </div>
                    <% if pmi && available_items.any? %>
                      <details class="mt-1">
                        <summary class="text-xs text-brand-orange cursor-pointer hover:text-brand-orange-light">Change</summary>
                        <div class="mt-1">
                          <%= form_with url: product_match_item_path(pmi), method: :patch, data: { turbo_frame: "_top" } do |f| %>
                            <%= render "aggregated_lists/searchable_select",
                                       field_name: "product_match_item[supplier_list_item_id]",
                                       items: available_items,
                                       selected_id: item.id,
                                       show_no_match: true %>
                          <% end %>
                        </div>
                      </details>
                    <% end %>
                  <% else %>
                    <%# No match — allow assigning one if a product_match_item exists for this supplier, or show add option %>
                    <% if pmi %>
                      <span class="text-sm text-gray-400 italic">No match</span>
                      <% if available_items.any? %>
                        <details class="mt-1">
                          <summary class="text-xs text-brand-orange cursor-pointer hover:text-brand-orange-light">Assign</summary>
                          <div class="mt-1">
                            <%= form_with url: product_match_item_path(pmi), method: :patch, data: { turbo_frame: "_top" } do |f| %>
                              <%= render "aggregated_lists/searchable_select",
                                         field_name: "product_match_item[supplier_list_item_id]",
                                         items: available_items,
                                         selected_id: nil %>
                            <% end %>
                          </div>
                        </details>
                      <% end %>
                    <% else %>
                      <span class="text-sm text-gray-400 italic">No match</span>
                      <% if available_items.any? %>
                        <details class="mt-1">
                          <summary class="text-xs text-brand-orange cursor-pointer hover:text-brand-orange-light">Assign</summary>
                          <div class="mt-1">
                            <%= form_with url: product_match_items_path, method: :post, data: { turbo_frame: "_top" } do |f| %>
                              <%= hidden_field_tag "product_match_item[product_match_id]", match.id %>
                              <%= hidden_field_tag "product_match_item[supplier_id]", supplier.id %>
                              <%= render "aggregated_lists/searchable_select",
                                         field_name: "product_match_item[supplier_list_item_id]",
                                         items: available_items,
                                         selected_id: nil %>
                            <% end %>
                          </div>
                        </details>
                      <% end %>
                    <% end %>
                  <% end %>
                </td>
              <% end %>

              <!-- Status column -->
              <td class="px-4 py-3 text-center whitespace-nowrap">
                <% if match.unmatched? %>
                  <span class="inline-flex items-center rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-700">Unmatched</span>
                <% else %>
                  <span class="text-green-600">
                    <svg class="h-5 w-5 mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white shadow rounded-lg p-8 text-center">
      <p class="text-gray-500">No product matches yet. Add supplier lists and run matching.</p>
    </div>
  <% end %>

  <!-- Approve / Next Steps bar -->
  <% if @product_matches.any? && !@aggregated_list.matching? && !@aggregated_list.searching_catalog? %>
    <div class="mt-8 bg-white shadow rounded-lg p-6">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <h3 class="text-lg font-heading font-semibold text-gray-900">Ready to continue?</h3>
          <p class="text-sm text-gray-500 mt-1">
            <%= @stats[:matched] %> matched products across <%= @suppliers.size %> suppliers
          </p>
        </div>
        <div class="flex gap-3 w-full sm:w-auto">
          <% if @aggregated_list.matched? %>
            <%= link_to order_builder_aggregated_list_path(@aggregated_list),
                data: { turbo: false },
                class: "flex-1 sm:flex-initial text-center rounded-md bg-brand-green px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-brand-green-dark transition-colors" do %>
              Create Order →
            <% end %>
          <% end %>
          <%= link_to supplier_lists_path,
              class: "flex-1 sm:flex-initial text-center rounded-md border border-gray-300 bg-white px-6 py-3 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-50 transition-colors" do %>
            ← Back to Lists
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
