<div class="py-6">
  <div class="mb-6">
    <%= link_to "&larr; #{@aggregated_list.matched_list? ? 'Product Matching' : 'Compare Lists'}".html_safe, aggregated_lists_path, class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-full border border-brand-orange/30 text-brand-orange bg-brand-orange/5 hover:bg-brand-orange/10 transition-colors" %>
  </div>

  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-heading font-bold text-gray-900">
        <%= @aggregated_list.name %>
        <% if @aggregated_list.promoted? %>
          <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-purple-100 text-purple-800 ml-2 align-middle">🌐 Org-Wide</span>
        <% end %>
      </h1>
      <p class="mt-1 text-sm text-gray-500">
        <%= @suppliers.map(&:name).join(" vs ") %>
        <span class="mx-1">&middot;</span>
        <%= pluralize(@stats[:total], "product") %>
        <% if @aggregated_list.promoted? %>
          <span class="mx-1">&middot;</span>
          <span class="text-purple-600 font-medium">Read-only (promoted)</span>
        <% end %>
      </p>
    </div>
    <div class="flex gap-3">
      <%# Promote / Demote buttons (owner only) %>
      <% if owner? && @aggregated_list.matched_list? %>
        <% if @aggregated_list.promoted? %>
          <%= button_to "Demote from Org-Wide", demote_aggregated_list_path(@aggregated_list),
              method: :post,
              class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md border border-purple-300 text-purple-700 hover:bg-purple-50 transition-colors" %>
        <% else %>
          <%= button_to "Promote to Org-Wide", promote_aggregated_list_path(@aggregated_list),
              method: :post,
              class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md border border-purple-300 text-purple-700 hover:bg-purple-50 transition-colors" %>
        <% end %>
      <% end %>

      <% if @aggregated_list.matching? || @aggregated_list.searching_catalog? %>
        <span class="inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium rounded-md bg-gray-100 text-gray-400 cursor-not-allowed">
          <svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Processing...
        </span>
      <% elsif @aggregated_list.promoted? %>
        <%# No edit/rematch controls when promoted — read-only %>
      <% else %>
        <% unless @aggregated_list.matched_list? %>
          <%= link_to "&larr; Modify List Settings".html_safe, edit_aggregated_list_path(@aggregated_list),
              class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors" %>
        <% end %>
        <%= button_to "Sync New Products", sync_new_products_aggregated_list_path(@aggregated_list),
            method: :post,
            class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md border border-brand-green text-brand-green hover:bg-brand-green hover:text-white transition-colors" %>
        <%= button_to "Re-match All", run_matching_aggregated_list_path(@aggregated_list),
            method: :post,
            form: { data: { turbo_confirm: "⚠️ This will DELETE all existing matches — including ones you manually confirmed — and re-run AI matching from scratch.\n\nThis cannot be undone. Are you sure?" } },
            class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md border border-red-300 text-red-600 hover:bg-red-50 transition-colors" %>
        <% if @aggregated_list.matched? %>
          <%= link_to aggregated_lists_path(notice: "#{@aggregated_list.name} matching approved."),
              class: "inline-flex items-center px-4 py-1.5 text-sm font-semibold rounded-md bg-brand-green text-white hover:bg-brand-green-dark transition-colors shadow-sm" do %>
            ✓ Approve Matching
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="grid grid-cols-3 gap-4 mb-6">
    <div class="bg-white shadow rounded-lg p-4 text-center">
      <p class="text-2xl font-heading font-bold text-gray-900"><%= @stats[:total] %></p>
      <p class="text-sm text-gray-500">Total Products</p>
    </div>
    <div class="bg-white shadow rounded-lg p-4 text-center">
      <p class="text-2xl font-heading font-bold text-green-600"><%= @stats[:matched] %></p>
      <p class="text-sm text-gray-500">Matched</p>
    </div>
    <div class="bg-white shadow rounded-lg p-4 text-center">
      <p class="text-2xl font-heading font-bold text-amber-600"><%= @stats[:unmatched] %></p>
      <p class="text-sm text-gray-500">Unmatched</p>
    </div>
  </div>

  <%# Add Supplier Guide section — only for non-matched (comparison) lists %>
  <% if !@aggregated_list.matched_list? && @available_guides&.any? && !@aggregated_list.promoted? %>
    <div class="bg-white shadow rounded-lg p-4 mb-6 border border-dashed border-gray-300">
      <details class="group">
        <summary class="flex items-center justify-between cursor-pointer list-none">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
            <span class="text-sm font-medium text-gray-900">Add Supplier Guide</span>
            <span class="text-xs text-gray-500">(<%= @available_guides.size %> available)</span>
          </div>
          <svg class="w-4 h-4 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 20 20"><path fill="currentColor" fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
        </summary>
        <div class="mt-4 pt-4 border-t border-gray-200">
          <p class="text-sm text-gray-500 mb-3">Select guides to add. Existing matches will be preserved — only new items will be matched.</p>
          <%= form_with url: add_supplier_guide_aggregated_list_path(@aggregated_list), method: :post, class: "space-y-3" do %>
            <% @available_guides.group_by(&:supplier).each do |supplier, lists| %>
              <div class="border border-gray-200 rounded-lg p-3">
                <span class="block text-sm font-medium text-gray-900 mb-2"><%= supplier.name %></span>
                <div class="space-y-1.5">
                  <% lists.each do |list| %>
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="checkbox" name="supplier_list_ids[]" value="<%= list.id %>"
                             class="rounded border-gray-300 text-brand-green focus:ring-brand-green">
                      <span class="text-sm text-gray-700"><%= list.name %> (<%= pluralize(list.product_count, "item") %>)</span>
                    </label>
                  <% end %>
                </div>
              </div>
            <% end %>
            <div class="flex justify-end">
              <button type="submit" class="rounded-md bg-brand-green px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-green-dark transition-colors">
                Add & Match New Items
              </button>
            </div>
          <% end %>
        </div>
      </details>
    </div>
  <% end %>

  <% if @aggregated_list.matching? %>
    <div class="relative overflow-hidden rounded-lg bg-brand-orange/10 border-2 border-brand-orange p-5 mb-6 shadow-md"
         data-controller="auto-refresh"
         data-auto-refresh-interval-value="10000">
      <div class="absolute top-0 left-0 h-1 w-full bg-brand-orange/20">
        <div class="h-full w-1/3 bg-brand-orange rounded-r animate-progress-bar"></div>
      </div>
      <div class="flex items-center gap-4">
        <div class="shrink-0">
          <svg class="h-8 w-8 animate-spin text-brand-orange" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>
        <div>
          <p class="text-base font-semibold text-gray-900">Processing — please wait</p>
          <p class="text-sm text-gray-600 mt-0.5">Matching products and searching catalog. This can take 2-5 minutes. The page will refresh automatically when complete.</p>
        </div>
      </div>
    </div>
  <% end %>

  <% if @aggregated_list.searching_catalog? %>
    <div class="relative overflow-hidden rounded-lg bg-blue-50 border-2 border-blue-200 p-5 mb-6 shadow-md"
         data-controller="auto-refresh"
         data-auto-refresh-interval-value="10000">
      <div class="absolute top-0 left-0 h-1 w-full bg-blue-200">
        <div class="h-full w-1/3 bg-blue-500 rounded-r animate-progress-bar"></div>
      </div>
      <div class="flex items-center gap-4">
        <div class="shrink-0">
          <svg class="h-8 w-8 animate-spin text-blue-600" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>
        <div>
          <p class="text-base font-semibold text-blue-800">Searching full catalog — please wait</p>
          <p class="text-sm text-blue-600 mt-0.5">Searching supplier products for matches to unmatched items. This can take 1-2 minutes. The page will refresh automatically when complete.</p>
        </div>
      </div>
    </div>
  <% end %>

  <% if @unconnected_suppliers.any? %>
    <div class="mb-4 flex items-start gap-3 rounded-lg border border-brand-orange/30 bg-brand-orange/5 px-4 py-3">
      <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
      </svg>
      <p class="text-sm text-gray-700">
        <span class="font-medium">Prices from <%= @unconnected_suppliers.map(&:name).to_sentence %> are shown as a preview.</span>
        Connect these suppliers to unlock ordering and full comparison.
      </p>
    </div>
  <% end %>

  <!-- Match comparison table -->
  <% if @product_matches.any? %>
    <div id="match-table-scroll" class="bg-white shadow rounded-lg overflow-x-auto">
      <table id="match-comparison-table" class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider sticky left-0 bg-gray-50 z-30">Product</th>
            <% @suppliers.each do |supplier| %>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider min-w-[200px] bg-gray-50"><%= supplier.name %></th>
            <% end %>
            <% @unconnected_suppliers.each do |supplier| %>
              <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider min-w-[200px] bg-gray-100/80 text-gray-400">
                <div class="flex items-center gap-1.5">
                  <svg class="h-3.5 w-3.5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                  </svg>
                  <%= supplier.name %>
                </div>
              </th>
            <% end %>
            <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-32 bg-gray-50">Status</th>
          </tr>
        </thead>
        <tbody id="match-table-body" class="bg-white divide-y divide-gray-200">
          <% @product_matches.each do |match| %>
            <tr id="<%= dom_id(match) %>" class="<%= match.unmatched? ? 'bg-amber-50/50' : '' %> hover:bg-gray-50">
              <!-- Canonical name column (click pencil to rename) -->
              <td class="px-4 py-3 sticky left-0 bg-inherit z-10">
                <% if @aggregated_list.promoted? %>
                  <div class="flex items-start gap-1">
                    <span class="text-sm font-medium text-gray-900"><%= match.display_name %></span>
                  </div>
                <% else %>
                  <div data-controller="inline-edit"
                       data-inline-edit-url-value="<%= rename_aggregated_list_product_match_path(@aggregated_list, match) %>"
                       data-inline-edit-field-value="canonical_name"
                       class="group flex items-start gap-1">
                    <span class="text-sm font-medium text-gray-900 cursor-pointer hover:text-brand-orange transition-colors underline decoration-dashed decoration-gray-300 decoration-1 underline-offset-2 hover:decoration-brand-orange"
                          data-inline-edit-target="display"
                          data-action="click->inline-edit#edit"
                          title="Click to rename"><%= match.display_name %></span>
                    <button data-inline-edit-target="icon"
                            data-action="click->inline-edit#edit"
                            class="opacity-40 group-hover:opacity-100 transition-opacity mt-0.5 text-gray-400 hover:text-brand-orange flex-shrink-0"
                            title="Rename product">
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487z"/>
                      </svg>
                    </button>
                    <input type="text"
                           data-inline-edit-target="input"
                           data-action="blur->inline-edit#save keydown->inline-edit#keydown"
                           class="hidden text-sm font-medium text-gray-900 bg-white border border-brand-green rounded px-1.5 py-0.5 focus:outline-none focus:ring-1 focus:ring-brand-green w-full">
                  </div>
                <% end %>
                <div class="text-xs text-gray-500">
                  <% if match.confidence_score && match.confidence_score > 0 %>
                    <span class="<%= match.confidence_score >= 0.8 ? 'text-green-600' : 'text-amber-600' %>">
                      <%= (match.confidence_score * 100).round %>% confidence
                    </span>
                  <% end %>
                </div>
              </td>

              <!-- Supplier columns -->
              <% price_info = @price_data[match.id] %>
              <% @suppliers.each do |supplier| %>
                <td class="px-4 py-3" id="match_<%= match.id %>_supplier_<%= supplier.id %>">
                  <% lookup = @match_supplier_map.dig(match.id, supplier.id) %>
                  <% item = lookup&.dig(:item) %>
                  <% pmi = lookup&.dig(:pmi) %>
                  <% is_cheapest = item && price_info[:cheapest_supplier] == supplier && price_info[:spread] && price_info[:spread] > 0 %>
                  <% is_most_expensive = item && price_info[:most_expensive_supplier] == supplier && price_info[:spread] && price_info[:spread] > 0 %>
                  <%= render "aggregated_lists/supplier_cell",
                             product_match: match,
                             supplier: supplier,
                             item: item,
                             pmi: pmi,
                             search_url: supplier_items_search_aggregated_list_path(@aggregated_list),
                             supplier_id: supplier.id,
                             is_cheapest: is_cheapest,
                             is_most_expensive: is_most_expensive,
                             readonly: @aggregated_list.promoted? %>
                </td>
              <% end %>

              <%# Teaser columns for unconnected suppliers %>
              <% @unconnected_suppliers.each do |supplier| %>
                <td class="px-4 py-3 bg-gray-50/60">
                  <% teaser_product = @teaser_map.dig(match.id, supplier.id) %>
                  <%= render "aggregated_lists/teaser_supplier_cell",
                             supplier: supplier,
                             teaser_product: teaser_product %>
                </td>
              <% end %>

              <!-- Status column -->
              <td class="px-4 py-3 text-center whitespace-nowrap">
                <div class="group/status flex items-center justify-center gap-1.5">
                  <% if match.unmatched? %>
                    <span class="inline-flex items-center rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-700">Unmatched</span>
                  <% else %>
                    <span class="text-green-600">
                      <svg class="h-5 w-5 mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    </span>
                  <% end %>
                  <% unless @aggregated_list.promoted? %>
                    <button type="button"
                            class="p-1 rounded text-red-400 hover:text-red-600 hover:bg-red-50 transition-colors flex-shrink-0"
                            title="Remove from list"
                            data-dismiss-url="<%= reject_aggregated_list_product_match_path(@aggregated_list, match) %>"
                            data-match-row="<%= dom_id(match) %>"
                            data-match-name="<%= match.display_name %>"
                            onclick="dismissMatch(this)">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                      </svg>
                    </button>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white shadow rounded-lg p-8 text-center">
      <p class="text-gray-500">No product matches yet. Add supplier lists and run matching.</p>
    </div>
  <% end %>

  <!-- Approve / Next Steps bar -->
  <% if @product_matches.any? && !@aggregated_list.matching? && !@aggregated_list.searching_catalog? %>
    <div class="mt-8 bg-white shadow rounded-lg p-6">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <h3 class="text-lg font-heading font-semibold text-gray-900">Ready to continue?</h3>
          <p class="text-sm text-gray-500 mt-1">
            <%= @stats[:matched] %> matched products across <%= @suppliers.size %> suppliers
          </p>
        </div>
        <div class="flex gap-3 w-full sm:w-auto">
          <% if @aggregated_list.matched? %>
            <%= link_to order_builder_aggregated_list_path(@aggregated_list),
                data: { turbo: false },
                class: "flex-1 sm:flex-initial text-center rounded-md bg-brand-green px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-brand-green-dark transition-colors" do %>
              Create Order →
            <% end %>
          <% end %>
          <%= link_to supplier_lists_path,
              class: "flex-1 sm:flex-initial text-center rounded-md border border-gray-300 bg-white px-6 py-3 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-50 transition-colors" do %>
            ← Back to Lists
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<script>
  function dismissMatch(btn) {
    const name = btn.dataset.matchName || "this product"
    showConfirmModal(
      "Remove product?",
      `"${name}" will be removed from this list and won't appear in the order builder. You can restore it by re-running matching.`,
      "Remove",
      function () { executeDismiss(btn) }
    )
  }

  function executeDismiss(btn) {
    const url = btn.dataset.dismissUrl
    const rowId = btn.dataset.matchRow
    const row = document.getElementById(rowId)
    if (!row) return

    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content
    btn.disabled = true

    fetch(url, {
      method: "POST",
      headers: {
        "X-CSRF-Token": csrfToken,
        "Accept": "application/json"
      }
    }).then(response => {
      if (response.ok) {
        row.style.transition = "opacity 0.3s ease"
        row.style.opacity = "0"
        setTimeout(() => row.remove(), 300)
      } else {
        btn.disabled = false
      }
    }).catch(() => {
      btn.disabled = false
    })
  }

  function showConfirmModal(title, message, confirmLabel, onConfirm) {
    // Remove any existing modal
    const existing = document.getElementById("confirm-modal-backdrop")
    if (existing) existing.remove()

    const backdrop = document.createElement("div")
    backdrop.id = "confirm-modal-backdrop"
    backdrop.className = "fixed inset-0 z-50 flex items-center justify-center"
    backdrop.innerHTML = `
      <div class="absolute inset-0 bg-gray-900/50 transition-opacity" data-dismiss="backdrop"></div>
      <div class="relative bg-white rounded-lg shadow-xl max-w-sm w-full mx-4 p-6 transform transition-all">
        <div class="flex items-start gap-3">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-red-100 flex items-center justify-center">
            <svg class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="text-base font-semibold text-gray-900">${title}</h3>
            <p class="mt-1 text-sm text-gray-500">${message}</p>
          </div>
        </div>
        <div class="mt-5 flex justify-end gap-2">
          <button type="button" data-dismiss="cancel"
                  class="px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors">
            Cancel
          </button>
          <button type="button" data-dismiss="confirm"
                  class="px-3 py-1.5 text-sm font-semibold text-white bg-red-600 rounded-md hover:bg-red-700 transition-colors">
            ${confirmLabel}
          </button>
        </div>
      </div>
    `

    document.body.appendChild(backdrop)

    // Wire up dismiss handlers
    backdrop.querySelector('[data-dismiss="backdrop"]').addEventListener("click", () => backdrop.remove())
    backdrop.querySelector('[data-dismiss="cancel"]').addEventListener("click", () => backdrop.remove())
    backdrop.querySelector('[data-dismiss="confirm"]').addEventListener("click", () => {
      backdrop.remove()
      onConfirm()
    })

    // Close on Escape
    const escHandler = (e) => {
      if (e.key === "Escape") {
        backdrop.remove()
        document.removeEventListener("keydown", escHandler)
      }
    }
    document.addEventListener("keydown", escHandler)
  }

  // Floating sticky header — pins the thead to the top of the viewport
  // when the user scrolls past it, and syncs horizontal scroll.
  (function() {
    const table = document.getElementById("match-comparison-table")
    const scrollContainer = document.getElementById("match-table-scroll")
    if (!table || !scrollContainer) return

    const thead = table.querySelector("thead")
    if (!thead) return

    let floating = null

    function create() {
      if (floating) return

      floating = document.createElement("div")
      floating.id = "floating-match-thead"
      floating.style.cssText = "position:fixed;top:0;z-index:40;overflow:hidden;pointer-events:auto;"

      const inner = document.createElement("div")
      inner.style.cssText = "overflow:hidden;"

      const clonedTable = document.createElement("table")
      clonedTable.className = table.className

      const clonedHead = thead.cloneNode(true)
      clonedHead.classList.add("shadow-[0_2px_4px_rgba(0,0,0,0.1)]")
      clonedTable.appendChild(clonedHead)

      // Match column widths from the real header
      const origCells = thead.querySelectorAll("th")
      const clonedCells = clonedHead.querySelectorAll("th")
      origCells.forEach(function(cell, i) {
        const w = cell.getBoundingClientRect().width + "px"
        clonedCells[i].style.width = w
        clonedCells[i].style.minWidth = w
      })

      inner.appendChild(clonedTable)
      floating.appendChild(inner)
      document.body.appendChild(floating)
      sync()
    }

    function destroy() {
      if (floating) { floating.remove(); floating = null }
    }

    function sync() {
      if (!floating) return
      var rect = scrollContainer.getBoundingClientRect()
      floating.style.left = rect.left + "px"
      floating.style.width = rect.width + "px"
      floating.firstElementChild.scrollLeft = scrollContainer.scrollLeft
    }

    function onScroll() {
      var tRect = table.getBoundingClientRect()
      var hHeight = thead.getBoundingClientRect().height
      if (tRect.top < 0 && tRect.bottom > hHeight + 20) {
        create()
        sync()
      } else {
        destroy()
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true })
    scrollContainer.addEventListener("scroll", sync, { passive: true })
    window.addEventListener("resize", function() { destroy(); onScroll() })

    // Clean up on Turbo navigation
    document.addEventListener("turbo:before-render", destroy)
  })()
</script>
