<%# Compact supplier cell card for product matching grid.
    Styled to match Option A mockup: 9px supplier name, 11px product name,
    14px price, 10px per-unit, absolute-positioned Best badge.
    Locals:
      product_match    — the ProductMatch row
      supplier         — the Supplier for this cell
      item             — the SupplierListItem (or nil if unmatched)
      pmi              — the ProductMatchItem (or nil)
      search_url       — AJAX search endpoint URL
      supplier_id      — supplier ID for search scoping
      is_cheapest      — boolean
      is_most_expensive — boolean
      readonly         — boolean
%>
<% is_cheapest = local_assigns.fetch(:is_cheapest, false) %>
<% is_most_expensive = local_assigns.fetch(:is_most_expensive, false) %>
<% readonly = local_assigns.fetch(:readonly, false) %>

<div id="match_<%= product_match.id %>_supplier_<%= supplier.id %>"
     class="rounded-lg border relative min-w-0"
     style="padding: 10px; <%= is_cheapest ? 'border: 2px solid rgba(34,197,94,0.5); background: rgba(20,83,45,0.08);' : 'border-color: #334155; background: #0f172a;' %>">
  <% if is_cheapest %>
    <span style="position:absolute; top:-8px; right:-8px; padding:2px 7px; background:#16a34a; color:white; font-size:9px; font-weight:700; border-radius:20px;">BEST</span>
  <% end %>

  <%# Supplier name — 9px bold uppercase colored %>
  <div style="font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"
       class="<%= is_cheapest ? 'text-green-400' : supplier.brand_color_class %>">
    <%= supplier.short_name %>
  </div>

  <% if item %>
    <%# Product name — 11px, 2-line clamp %>
    <div style="font-size:11px; color:#cbd5e1; line-height:1.3; margin-bottom:3px; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">
      <%= item.name.truncate(80) %>
    </div>

    <%# Pack size — 10px %>
    <div style="font-size:10px; color:#475569;">
      <%= item.pack_size %>
      <% if item.catalog_search? %>
        <span style="margin-left:4px; padding:1px 4px; border-radius:3px; font-size:9px; font-weight:500; background:rgba(99,102,241,0.15); color:#818cf8;">catalog</span>
      <% end %>
    </div>

    <%# Price — 14px bold %>
    <div style="font-size:14px; font-weight:700; margin-top:4px;"
         class="<%= is_cheapest ? 'text-green-400' : '' %>"
         <%= 'style="font-size:14px; font-weight:700; margin-top:4px; color:#f8fafc;"'.html_safe unless is_cheapest %>>
      <%= item.formatted_price %><%= render "aggregated_lists/price_direction_arrow", direction: item.price_direction %>
    </div>
    <% if item.price_unit.present? && item.estimated_total_price != item.price %>
      <span style="font-size:10px; color:#64748b;">~$<%= '%.2f' % item.estimated_total_price %></span>
    <% end %>

    <%# Per-unit price — 10px %>
    <% if item.formatted_per_unit_price %>
      <div style="font-size:10px; margin-top:1px;"
           class="<%= is_cheapest ? 'text-green-400' : '' %>"
           <%= 'style="font-size:10px; margin-top:1px; color:#475569;"'.html_safe unless is_cheapest %>>
        <%= item.formatted_per_unit_price %>
      </div>
    <% end %>

    <% unless item.in_stock %>
      <span style="font-size:10px; color:#ef4444; font-weight:500; margin-top:2px; display:block;">Out of stock</span>
    <% end %>

    <%# Change control — 10px %>
    <% if pmi && !readonly %>
      <details style="margin-top:6px;">
        <summary style="font-size:10px; color:#f97316; cursor:pointer;">Change</summary>
        <div style="margin-top:4px;">
          <%= form_with url: product_match_item_path(pmi), method: :patch do |f| %>
            <%= render "aggregated_lists/searchable_select",
                       field_name: "product_match_item[supplier_list_item_id]",
                       search_url: search_url,
                       supplier_id: supplier_id,
                       selected_id: item.id,
                       show_no_match: true %>
          <% end %>
        </div>
      </details>
    <% end %>
  <% else %>
    <%# No match %>
    <div style="font-size:11px; color:#475569; font-style:italic; margin-top:4px;">No match</div>
    <% unless readonly %>
      <% if pmi %>
        <details style="margin-top:6px;">
          <summary style="font-size:10px; color:#f97316; cursor:pointer;">Assign</summary>
          <div style="margin-top:4px;">
            <%= form_with url: product_match_item_path(pmi), method: :patch do |f| %>
              <%= render "aggregated_lists/searchable_select",
                         field_name: "product_match_item[supplier_list_item_id]",
                         search_url: search_url,
                         supplier_id: supplier_id,
                         selected_id: nil %>
            <% end %>
          </div>
        </details>
      <% else %>
        <details style="margin-top:6px;">
          <summary style="font-size:10px; color:#f97316; cursor:pointer;">Assign</summary>
          <div style="margin-top:4px;">
            <%= form_with url: product_match_items_path, method: :post do |f| %>
              <%= hidden_field_tag "product_match_item[product_match_id]", product_match.id %>
              <%= hidden_field_tag "product_match_item[supplier_id]", supplier.id %>
              <%= render "aggregated_lists/searchable_select",
                         field_name: "product_match_item[supplier_list_item_id]",
                         search_url: search_url,
                         supplier_id: supplier_id,
                         selected_id: nil %>
            <% end %>
          </div>
        </details>
      <% end %>
    <% end %>
  <% end %>
</div>
