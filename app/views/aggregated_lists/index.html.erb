<div class="py-6">
  <%# ===== MATCHED LISTS (Primary Section) ===== %>
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-heading font-bold text-gray-900">Product Matching</h1>
      <p class="mt-1 text-sm text-gray-500">Match products across suppliers. Confirm matches once — they're preserved forever, even when you add new suppliers.</p>
    </div>
    <% unless @location_has_matched_list || @promoted_list %>
      <%= link_to new_aggregated_list_path(list_type: 'matched'),
          class: "rounded-md bg-brand-orange px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-orange-light transition-colors" do %>
        <span class="inline-flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          Set Up Matched List
        </span>
      <% end %>
    <% end %>
  </div>

  <% if @matched_lists.empty? %>
    <div class="bg-white shadow rounded-lg p-12 text-center mb-12">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No matched list yet</h3>
      <p class="mt-1 text-sm text-gray-500 max-w-md mx-auto">
        Set up your matched list by selecting your supplier order guides. AI will propose matches across suppliers, then you review and confirm each one. Once confirmed, matches are permanent.
      </p>
      <%= link_to "Set up matched list", new_aggregated_list_path(list_type: 'matched'),
          class: "mt-4 inline-block text-brand-orange hover:text-brand-orange-light font-medium text-sm" %>
    </div>
  <% elsif @promoted_list %>
    <%# === PROMOTED ORG-WIDE LIST (primary — this is THE matched list) === %>
    <div class="mb-8">
      <div class="bg-white shadow-md rounded-lg border-2 border-purple-200 hover:shadow-lg transition-shadow">
        <%= link_to aggregated_list_path(@promoted_list), class: "block p-6" do %>
          <div class="flex justify-between items-start">
            <h3 class="text-xl font-heading font-semibold text-gray-900"><%= @promoted_list.name %></h3>
            <div class="flex items-center gap-2">
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-purple-100 text-purple-800">Organization Default</span>
              <% case @promoted_list.match_status %>
              <% when "matched" %>
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-green-100 text-green-800">Matched</span>
              <% when "matching" %>
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-blue-100 text-blue-800">Matching...</span>
              <% when "failed" %>
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-red-100 text-red-800">Failed</span>
              <% else %>
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-gray-100 text-gray-800">Pending</span>
              <% end %>
            </div>
          </div>
          <% if @promoted_list.description.present? %>
            <p class="mt-1 text-sm text-gray-500"><%= @promoted_list.description %></p>
          <% end %>
          <div class="mt-4 flex flex-wrap gap-2">
            <% @promoted_list.supplier_lists.map(&:supplier).uniq.each do |supplier| %>
              <span class="inline-flex items-center rounded-full bg-brand-green-50 px-2.5 py-0.5 text-xs font-medium text-brand-green-dark">
                <%= supplier.name %>
              </span>
            <% end %>
          </div>
          <div class="mt-4 grid grid-cols-3 gap-4 text-center text-sm">
            <div>
              <p class="font-semibold text-gray-900"><%= @promoted_list.total_match_count %></p>
              <p class="text-gray-500">Products</p>
            </div>
            <div>
              <p class="font-semibold text-green-600"><%= @promoted_list.confirmed_count %></p>
              <p class="text-gray-500">Confirmed</p>
            </div>
            <div>
              <p class="font-semibold text-amber-600"><%= @promoted_list.auto_matched_count %></p>
              <p class="text-gray-500">To Review</p>
            </div>
          </div>
        <% end %>

        <% if owner? %>
          <div class="px-6 pb-4">
            <%= button_to "Demote from Org-Wide", demote_aggregated_list_path(@promoted_list),
                method: :post,
                class: "w-full text-center rounded-md border border-purple-300 px-3 py-1.5 text-xs font-medium text-purple-700 hover:bg-purple-50 transition-colors" %>
          </div>
        <% end %>
      </div>
    </div>

    <%# === LOCATION LISTS (secondary — only visible to owners for management) === %>
    <% if owner? && @location_lists.any? %>
      <div class="border-t border-gray-200 pt-6 mb-12">
        <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-3">Location Lists</h3>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <% @location_lists.each do |list| %>
            <div class="bg-white shadow rounded-lg hover:shadow-md transition-shadow opacity-75">
              <%= link_to aggregated_list_path(list), class: "block p-4" do %>
                <div class="flex justify-between items-start">
                  <h3 class="text-sm font-heading font-medium text-gray-900"><%= list.name %></h3>
                  <% case list.match_status %>
                  <% when "matched" %>
                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-green-100 text-green-800">Matched</span>
                  <% when "matching" %>
                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-blue-100 text-blue-800">Matching...</span>
                  <% else %>
                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-800">Pending</span>
                  <% end %>
                </div>
                <div class="mt-2 flex flex-wrap gap-1">
                  <% list.supplier_lists.map(&:supplier).uniq.each do |supplier| %>
                    <span class="inline-flex items-center rounded-full bg-brand-green-50 px-2 py-0.5 text-xs text-brand-green-dark"><%= supplier.name %></span>
                  <% end %>
                </div>
                <p class="mt-2 text-xs text-gray-400"><%= pluralize(list.total_match_count, "product") %></p>
              <% end %>

              <div class="px-4 pb-3">
                <%= button_to "Promote to Org-Wide", promote_aggregated_list_path(list),
                    method: :post,
                    class: "w-full text-center rounded-md border border-purple-300 px-3 py-1.5 text-xs font-medium text-purple-700 hover:bg-purple-50 transition-colors" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <%# === NO PROMOTED LIST — show all location lists as cards === %>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-12">
      <% @matched_lists.each do |list| %>
        <div class="bg-white shadow rounded-lg hover:shadow-md transition-shadow">
          <%= link_to aggregated_list_path(list), class: "block p-6" do %>
            <div class="flex justify-between items-start">
              <h3 class="text-lg font-heading font-medium text-gray-900"><%= list.name %></h3>
              <% case list.match_status %>
              <% when "matched" %>
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-green-100 text-green-800">Matched</span>
              <% when "matching" %>
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-blue-100 text-blue-800">Matching...</span>
              <% when "failed" %>
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-red-100 text-red-800">Failed</span>
              <% else %>
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-gray-100 text-gray-800">Pending</span>
              <% end %>
            </div>
            <% if list.description.present? %>
              <p class="mt-1 text-sm text-gray-500"><%= list.description %></p>
            <% end %>
            <div class="mt-4 flex flex-wrap gap-2">
              <% list.supplier_lists.map(&:supplier).uniq.each do |supplier| %>
                <span class="inline-flex items-center rounded-full bg-brand-green-50 px-2.5 py-0.5 text-xs font-medium text-brand-green-dark">
                  <%= supplier.name %>
                </span>
              <% end %>
            </div>
            <div class="mt-4 grid grid-cols-3 gap-4 text-center text-sm">
              <div>
                <p class="font-semibold text-gray-900"><%= list.total_match_count %></p>
                <p class="text-gray-500">Products</p>
              </div>
              <div>
                <p class="font-semibold text-green-600"><%= list.confirmed_count %></p>
                <p class="text-gray-500">Confirmed</p>
              </div>
              <div>
                <p class="font-semibold text-amber-600"><%= list.auto_matched_count %></p>
                <p class="text-gray-500">To Review</p>
              </div>
            </div>
          <% end %>

          <% if owner? %>
            <div class="px-6 pb-4">
              <%= button_to "Promote to Org-Wide", promote_aggregated_list_path(list),
                  method: :post,
                  class: "w-full text-center rounded-md border border-purple-300 px-3 py-1.5 text-xs font-medium text-purple-700 hover:bg-purple-50 transition-colors" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# ===== AD-HOC COMPARISONS (Secondary Section) ===== %>
  <% if @custom_lists.any? %>
    <div class="mt-8 pt-8 border-t-2 border-gray-200">
      <div class="flex justify-between items-center mb-4">
        <div>
          <h2 class="text-lg font-heading font-semibold text-gray-900">Ad-Hoc Comparisons</h2>
          <p class="mt-0.5 text-sm text-gray-500">One-time comparison lists for quick price checks.</p>
        </div>
        <%= link_to "New Comparison", new_aggregated_list_path,
            class: "text-sm text-brand-orange hover:text-brand-orange-light font-medium" %>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <% @custom_lists.each do |list| %>
          <%= link_to aggregated_list_path(list), class: "bg-white shadow rounded-lg p-4 hover:shadow-md transition-shadow" do %>
            <div class="flex justify-between items-start">
              <h3 class="text-sm font-medium text-gray-900"><%= list.name %></h3>
              <% case list.match_status %>
              <% when "matched" %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-green-100 text-green-800">Matched</span>
              <% when "matching" %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-blue-100 text-blue-800">Matching...</span>
              <% else %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-800">Pending</span>
              <% end %>
            </div>
            <div class="mt-2 flex flex-wrap gap-1">
              <% list.supplier_lists.each do |sl| %>
                <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-600"><%= sl.supplier.name %></span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
