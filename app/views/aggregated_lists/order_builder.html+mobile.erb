<%# ============================================================================ %>
<%# MOBILE ORDER BUILDER — Comp A ("Cards") from mockups/mobile-first/order-a.html %>
<%# Matches the approved comp: tap a price cell → the cell becomes a stepper      %>
<%# (CASE/PIECE chooser when a piece price exists), "In this order" section below  %>
<%# results, floating ribbon with per-supplier minimums + bottom-sheet calendar,   %>
<%# savings fly-up + confetti on best-price adds.                                  %>
<%# Posts the SAME fields to the SAME endpoint as the desktop builder —            %>
<%# quantities / supplier_overrides / uom_overrides / delivery_date —              %>
<%# so the ordering pipeline is untouched.                                          %>
<%# ============================================================================ %>

<%
  supplier_count = @suppliers.size
  categories = @match_category.values.compact.uniq.sort
  minimums_json = @supplier_minimums.transform_values { |m| m[:minimum] }.to_json
%>

<div data-controller="mobile-order-builder"
     data-mobile-order-builder-minimums-value="<%= minimums_json %>"
     data-mobile-order-builder-list-id-value="<%= @aggregated_list.id %>"
     data-mobile-order-builder-has-batch-value="<%= @batch_id.present? %>"
     class="-mx-4 -mt-2 min-h-screen bg-brand-cream pb-56">

  <%= form_with(url: create_from_aggregated_list_orders_path, method: :post, id: "mobile-order-form",
                data: { mobile_order_builder_target: "form" }) do %>
    <input type="hidden" name="aggregated_list_id" value="<%= @aggregated_list.id %>">
    <% if @order_list %><input type="hidden" name="order_list_id" value="<%= @order_list.id %>"><% end %>
    <% if @batch_id %><input type="hidden" name="previous_batch_id" value="<%= @batch_id %>"><% end %>
    <input type="hidden" name="delivery_date" value="<%= @delivery_date %>" data-mobile-order-builder-target="deliveryDate">
    <div data-mobile-order-builder-target="hiddenFields"></div>

    <%# --- Sticky search header --- %>
    <header class="sticky top-0 z-30 bg-brand-cream/95 backdrop-blur border-b border-gray-200/60 px-3 pt-3 pb-2">
      <div class="flex items-center gap-2 mb-2">
        <h1 class="font-heading text-xl font-semibold text-brand-navy tracking-wide flex-1">Order</h1>
        <span class="text-[11px] text-gray-400 font-medium truncate max-w-[45%]"><%= @aggregated_list.name %></span>
      </div>
      <div class="relative">
        <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="M20 20l-3.5-3.5"/></svg>
        <input type="search" placeholder="Search all suppliers…" autocomplete="off" inputmode="search"
               data-mobile-order-builder-target="search"
               data-action="input->mobile-order-builder#filter"
               class="w-full bg-white border border-gray-200 rounded-xl pl-10 pr-4 py-3 text-[15px] focus:outline-none focus:ring-2 focus:ring-brand-green/40 focus:border-brand-green shadow-sm">
      </div>
      <div class="flex gap-2 overflow-x-auto hide-scrollbar pt-2 pb-1 -mx-3 px-3">
        <button type="button" data-action="mobile-order-builder#setCategory" data-category="all"
                data-mobile-order-builder-target="categoryChip"
                class="shrink-0 text-xs font-bold rounded-full px-3.5 py-1.5 border bg-brand-green text-white border-brand-green">All</button>
        <button type="button" data-action="mobile-order-builder#setCategory" data-category="__frequent__"
                data-mobile-order-builder-target="categoryChip"
                class="shrink-0 text-xs font-bold rounded-full px-3.5 py-1.5 border bg-white text-gray-600 border-gray-200">⭐ Frequent</button>
        <% categories.each do |cat| %>
          <button type="button" data-action="mobile-order-builder#setCategory" data-category="<%= cat %>"
                  data-mobile-order-builder-target="categoryChip"
                  class="shrink-0 text-xs font-bold rounded-full px-3.5 py-1.5 border bg-white text-gray-600 border-gray-200"><%= cat %></button>
        <% end %>
      </div>
    </header>

    <%# --- Empty state (blank search, nothing in order) --- %>
    <div data-mobile-order-builder-target="emptyState" class="text-center pt-14 pb-6 px-8 hidden">
      <svg class="mx-auto mb-3 text-gray-300" width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="M20 20l-3.5-3.5"/></svg>
      <p class="font-heading text-lg font-semibold text-brand-navy">Search every supplier at once</p>
      <p class="text-sm text-gray-500 mt-1">Type an item — chicken, cream, limes — or pick a category above.</p>
    </div>
    <p data-mobile-order-builder-target="noResults" class="text-center text-sm text-gray-400 py-10 hidden">No items match your search</p>

    <%# --- Product cards --- %>
    <main class="px-2 pt-3 space-y-2.5">
      <% @product_matches.each do |match| %>
        <%
          cheapest = match.cheapest_supplier
          cheapest_id = cheapest&.dig(:supplier)&.id
          current_qty = (@quantities[match.id.to_s] || 0).to_i
          category = @match_category[match.id] || "Other"
          thumb = product_thumb_url(match.canonical_image_source)
        %>
        <div class="bg-white rounded-2xl border border-gray-200 p-2.5 hidden"
             data-mobile-order-builder-target="card"
             data-match-id="<%= match.id %>"
             data-name="<%= match.display_name.downcase %>"
             data-display-name="<%= match.display_name %>"
             data-thumb="<%= thumb %>"
             data-category="<%= category %>"
             data-frequent="<%= @frequently_ordered[match.id] ? 'true' : 'false' %>"
             data-cheapest-supplier-id="<%= cheapest_id %>"
             data-initial-qty="<%= current_qty %>"
             data-initial-supplier-id="<%= @prefill_suppliers[match.id.to_s] %>"
             data-initial-uom="<%= @prefill_uoms[match.id.to_s] %>">
          <div class="flex gap-3 mb-2.5 items-center">
            <img src="<%= thumb %>" alt="" loading="lazy" decoding="async"
                 class="w-20 h-20 rounded-xl object-cover border border-gray-100 bg-brand-stone shrink-0">
            <div class="min-w-0 flex-1">
              <p class="font-bold text-brand-navy text-lg leading-snug"><%= match.display_name %></p>
              <p class="text-sm text-gray-500 mt-0.5"><%= category %></p>
            </div>
            <% if @frequently_ordered[match.id] %>
              <svg class="w-4 h-4 text-brand-orange shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <% end %>
          </div>

          <%# Supplier price cells — fixed order, N/A when not carried. JS swaps a %>
          <%# cell between price / CASE-PIECE chooser / stepper (comp behavior).   %>
          <div class="grid gap-1.5" style="grid-template-columns: repeat(<%= supplier_count %>, minmax(0, 1fr));">
            <% @suppliers.each do |supplier| %>
              <% item = match.item_for_supplier(supplier) %>
              <% if item.nil? || (item.price || item.supplier_product&.current_price).blank? %>
                <div class="rounded-lg border border-dashed border-gray-200 py-1.5 text-center select-none flex flex-col justify-center">
                  <div class="text-[9px] font-bold text-gray-300 truncate px-0.5"><%= supplier.short_name %></div>
                  <div class="text-[12px] font-bold text-gray-300">N/A</div>
                </div>
              <% else %>
                <%
                  sp = item.supplier_product
                  case_price = item.price_unit.present? ? item.estimated_total_price : (item.price || sp&.current_price)
                  estimated = item.price_unit.present?
                  in_stock = sp ? sp.in_stock : item.in_stock
                  pack = item.pack_size || sp&.pack_size
                  is_best = cheapest_id == supplier.id
                  piece = item.piece_price if item.piece_price.present? && item.piece_price.positive?
                %>
                <div data-mobile-order-builder-target="cell"
                     data-match-id="<%= match.id %>"
                     data-supplier-id="<%= supplier.id %>"
                     data-short="<%= supplier.short_name %>"
                     data-price="<%= case_price %>"
                     data-price-display="<%= estimated ? '~' : '' %><%= number_to_currency(case_price) %>"
                     data-per-unit="<%= item.formatted_per_unit_price %>"
                     data-pack="<%= pack %>"
                     data-piece-price="<%= piece %>"
                     data-piece-display="<%= number_to_currency(piece) if piece %>"
                     data-best="<%= is_best %>"
                     data-in-stock="<%= in_stock %>"></div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </main>

    <%# --- In this order (comp: separate section below results) --- %>
    <section class="px-2 pt-5 hidden" data-mobile-order-builder-target="orderSection">
      <div class="flex items-center gap-2 mb-2">
        <div class="h-px bg-gray-300 flex-1"></div>
        <h2 class="font-heading text-sm font-semibold text-gray-500 tracking-widest uppercase">In this order · <span data-mobile-order-builder-target="orderCount">0</span></h2>
        <div class="h-px bg-gray-300 flex-1"></div>
      </div>
      <div class="space-y-2" data-mobile-order-builder-target="orderLines"></div>
    </section>

    <%# --- Floating ribbon --- %>
    <div class="fixed inset-x-0 z-40 hidden" style="bottom: 76px;" data-mobile-order-builder-target="ribbon">
      <div class="px-2">
        <div class="bg-brand-navy text-white rounded-2xl shadow-2xl shadow-black/30 p-3">
          <div class="flex gap-1.5 overflow-x-auto hide-scrollbar mb-2.5" data-mobile-order-builder-target="ribbonPills"></div>
          <div class="flex items-center gap-2">
            <button type="button" data-action="mobile-order-builder#openDatePicker"
                    class="flex-1 min-w-0 flex items-center gap-1.5 text-white/90 border border-white/25 rounded-xl px-3 py-2.5 text-left">
              <svg class="shrink-0" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4M16 3v4M3 10h18"/></svg>
              <span class="text-xs font-bold truncate" data-mobile-order-builder-target="dateLabel"></span>
            </button>
            <button type="submit" data-mobile-order-builder-target="submitButton"
                    class="shrink-0 bg-brand-green active:bg-brand-green-dark disabled:opacity-40 text-white font-bold text-sm rounded-xl px-4 py-2.5 flex items-center gap-1.5">
              Review <span data-mobile-order-builder-target="ribbonTotal" class="font-extrabold"></span>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M9 6l6 6-6 6"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<%# Fallback: ensure controller is registered even if importmap cache is stale %>
<script type="module">
  import { Application } from "@hotwired/stimulus"
  const app = window.Stimulus || Application.start()
  if (!app.router.modulesByIdentifier.has("mobile-order-builder")) {
    const mod = await import("controllers/mobile_order_builder_controller")
    app.register("mobile-order-builder", mod.default)
  }
</script>
