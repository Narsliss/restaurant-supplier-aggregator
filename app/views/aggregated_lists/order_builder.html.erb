<div class="max-w-6xl mx-auto pb-6" data-controller="order-builder"
     data-order-builder-supplier-minimums-value="<%= @supplier_minimums.to_json %>">
  <div class="mb-6">
    <%= link_to "&larr; New Order".html_safe, select_list_orders_path, class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-full border border-brand-orange/30 text-brand-orange bg-brand-orange/5 hover:bg-brand-orange/10 transition-colors" %>
  </div>

  <div class="mb-6">
    <h1 class="text-2xl font-heading font-bold text-gray-900">Build Order</h1>
    <p class="mt-1 text-sm text-gray-500">
      <% if @order_list %>
        <%= @order_list.name %> &middot; <%= @aggregated_list.name %>
      <% else %>
        <%= @aggregated_list.name %>
      <% end %>
    </p>
    <div class="mt-2 flex flex-wrap gap-1.5">
      <% @suppliers.each do |supplier| %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">
          <%= supplier.name %>
        </span>
      <% end %>
    </div>
  </div>

  <%= form_with(url: create_from_aggregated_list_orders_path, method: :post, id: "order-form") do |form| %>
    <%= hidden_field_tag :aggregated_list_id, @aggregated_list.id %>
    <% if @order_list %>
      <%= hidden_field_tag :order_list_id, @order_list.id %>
    <% end %>
    <%# Supplier overrides are populated by JS when user clicks a non-default supplier %>
    <div id="supplier-overrides"></div>

    <%# Fixed command bar — two rows on mobile, single row on sm+ (JS clones to body for fixed positioning) %>
    <div id="order-builder-command-bar" class="bg-gray-50 py-2">
      <%# Mobile: stacked layout with collapsible supplier breakdown %>
      <div class="flex flex-col gap-2 sm:hidden">
        <div class="flex items-center justify-between gap-2">
          <div class="bg-white shadow rounded-lg px-3 py-1.5 flex items-center gap-1 flex-1 justify-center">
            <span class="text-xs font-medium text-gray-500 uppercase">Items</span>
            <span class="text-lg font-bold text-gray-900" data-order-builder-target="itemCount">0</span>
          </div>
          <div class="bg-white shadow rounded-lg px-3 py-1.5 flex items-center gap-1 flex-1 justify-center">
            <span class="text-xs font-medium text-gray-500 uppercase">Total</span>
            <span class="text-lg font-bold text-gray-900" data-order-builder-target="runningTotal">$0.00</span>
          </div>
          <div class="bg-white shadow rounded-lg px-3 py-1.5 flex items-center gap-1 flex-1 justify-center cursor-pointer"
               data-action="click->order-builder#toggleMobileSupplierDetail">
            <span class="text-xs font-medium text-gray-500 uppercase">Suppliers</span>
            <span class="text-lg font-bold text-gray-900" data-order-builder-target="supplierCount">0</span>
            <svg class="w-3 h-3 text-gray-400 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
        </div>
        <%# Per-supplier breakdown panel (mobile, initially hidden) %>
        <div class="hidden" data-order-builder-target="mobileSupplierDetail">
          <div class="flex flex-col gap-1.5">
            <% @suppliers.each do |supplier| %>
              <% min_info = @supplier_minimums[supplier.id] %>
              <div class="bg-white shadow rounded-lg px-3 py-1.5 hidden" data-supplier-breakdown-id="<%= supplier.id %>">
                <div class="flex items-center justify-between gap-2">
                  <span class="text-xs font-medium text-gray-600 truncate max-w-[100px]"><%= supplier.name %></span>
                  <span class="text-sm font-bold text-gray-900" data-supplier-subtotal="<%= supplier.id %>">$0</span>
                </div>
                <% if min_info[:minimum] && min_info[:minimum] > 0 %>
                  <div class="mt-1 flex items-center gap-1.5">
                    <div class="flex-1 h-1.5 bg-gray-200 rounded-full overflow-hidden">
                      <div class="h-full rounded-full bg-gray-300 transition-all duration-300"
                           data-supplier-progress-bar="<%= supplier.id %>"
                           style="width: 0%"></div>
                    </div>
                    <span class="text-[10px] text-gray-400 whitespace-nowrap" data-supplier-minimum-label="<%= supplier.id %>">
                      / $<%= min_info[:minimum].to_i %>
                    </span>
                  </div>
                <% else %>
                  <span class="text-[10px] text-gray-400 mt-1">No minimum</span>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <div class="bg-white shadow rounded-lg px-2 py-1.5 flex items-center gap-1">
            <%= date_field_tag :delivery_date, @delivery_date, min: Date.tomorrow, max: Date.today + 30.days, required: true, class: "w-32 rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm", data: { order_builder_target: "deliveryDate" } %>
          </div>
          <%= link_to "Cancel", select_list_orders_path, class: "text-sm font-medium text-gray-700 hover:text-gray-900" %>
          <button type="submit"
                  disabled
                  data-order-builder-target="submitButton"
                  class="ml-auto flex-1 px-4 py-2 rounded-md text-sm font-semibold text-white shadow-sm transition-colors bg-gray-300 cursor-not-allowed">
            Create Orders
          </button>
        </div>
      </div>
      <%# Desktop: single row layout with per-supplier mini-cards %>
      <div class="hidden sm:flex items-center gap-2">
        <div class="bg-white shadow rounded-lg px-3 py-1.5 flex items-center gap-1 shrink-0">
          <span class="text-xs font-medium text-gray-500 uppercase">Items</span>
          <span class="text-lg font-bold text-gray-900" data-order-builder-target="itemCount">0</span>
        </div>
        <div class="bg-white shadow rounded-lg px-3 py-1.5 flex items-center gap-1 shrink-0">
          <span class="text-xs font-medium text-gray-500 uppercase">Total</span>
          <span class="text-lg font-bold text-gray-900" data-order-builder-target="runningTotal">$0.00</span>
        </div>
        <%# Per-supplier mini-cards %>
        <% @suppliers.each do |supplier| %>
          <% min_info = @supplier_minimums[supplier.id] %>
          <div class="bg-white shadow rounded-lg px-2 py-1 flex flex-col hidden" data-supplier-breakdown-id="<%= supplier.id %>">
            <div class="flex items-center justify-between gap-1">
              <span class="text-[10px] font-medium text-gray-500 uppercase truncate max-w-[80px]"><%= supplier.name %></span>
              <span class="text-xs font-bold text-gray-900 whitespace-nowrap" data-supplier-subtotal="<%= supplier.id %>">$0</span>
            </div>
            <% if min_info[:minimum] && min_info[:minimum] > 0 %>
              <div class="mt-0.5 flex items-center gap-1">
                <div class="flex-1 h-1 bg-gray-200 rounded-full overflow-hidden">
                  <div class="h-full rounded-full bg-gray-300 transition-all duration-300"
                       data-supplier-progress-bar="<%= supplier.id %>"
                       style="width: 0%"></div>
                </div>
                <span class="text-[10px] text-gray-400 whitespace-nowrap" data-supplier-minimum-label="<%= supplier.id %>">
                  / $<%= min_info[:minimum].to_i %>
                </span>
              </div>
            <% else %>
              <span class="text-[10px] text-gray-400 mt-0.5">No minimum</span>
            <% end %>
          </div>
        <% end %>
        <div class="bg-white shadow rounded-lg px-3 py-1.5 flex items-center gap-1 shrink-0">
          <span class="text-xs font-medium text-gray-500 uppercase">Delivery</span>
          <%= date_field_tag :delivery_date, @delivery_date, min: Date.tomorrow, max: Date.today + 30.days, required: true, class: "w-32 rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm", data: { order_builder_target: "deliveryDate" } %>
        </div>
        <div class="ml-auto shrink-0 bg-white shadow rounded-lg px-3 py-1.5 flex items-center gap-3">
          <%= link_to "Cancel", select_list_orders_path, class: "text-sm font-medium text-gray-700 hover:text-gray-900" %>
          <button type="submit"
                  disabled
                  data-order-builder-target="submitButton"
                  class="px-5 py-1.5 rounded-md text-sm font-semibold text-white shadow-sm transition-colors bg-gray-300 cursor-not-allowed">
            Create Orders
          </button>
        </div>
      </div>
    </div>

    <% if @product_matches.any? %>
      <%# Search filter %>
      <div class="mb-4">
        <div class="relative">
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input type="text"
                 placeholder="Search products..."
                 class="w-full pl-4 pr-10 py-2 rounded-lg border border-gray-300 focus:border-brand-green focus:ring-brand-green text-sm"
                 data-order-builder-target="searchInput"
                 data-action="input->order-builder#filterProducts">
        </div>
      </div>

      <%# Product table — flows naturally with the page, no inner scroll container %>
      <div class="bg-white shadow rounded-lg mb-20">
        <%# Desktop: single continuous table with category header rows %>
        <div class="hidden sm:block">
          <table class="min-w-full divide-y divide-gray-200" id="order-builder-table">
            <thead id="order-builder-thead">
              <tr>
                <th class="px-4 py-2 text-left text-xs font-medium text-white uppercase tracking-wider bg-brand-green-dark">Product</th>
                <% @suppliers.each do |supplier| %>
                  <th class="px-4 py-2 text-left text-xs font-medium text-white uppercase tracking-wider bg-brand-green-dark"><%= supplier.name %></th>
                <% end %>
                <th class="px-4 py-2 text-center text-xs font-medium text-white uppercase tracking-wider bg-brand-green-dark">Qty</th>
                <th class="px-4 py-2 text-right text-xs font-medium text-white uppercase tracking-wider bg-brand-green-dark">Line Total</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white">
              <% @sorted_categories.each do |category| %>
                <% matches = @grouped_matches[category] %>
                <% is_order_list_section = @order_list_category && category == @order_list_category %>
                <%# Category header row %>
                <% display_category = is_order_list_section ? @order_list.name : category %>
                <tr data-order-builder-target="categorySection" data-category="<%= display_category %>">
                  <% if is_order_list_section %>
                    <td colspan="<%= @suppliers.size + 3 %>" class="px-4 py-3 border-t-4 border-brand-green bg-brand-green/15">
                      <div class="flex items-center gap-2">
                        <span class="inline-flex items-center px-2 py-0.5 rounded bg-brand-green text-white text-[10px] font-bold uppercase tracking-wider">Order List</span>
                        <span class="text-sm font-bold uppercase tracking-wider text-brand-green-dark"><%= display_category %></span>
                        <span class="text-xs text-brand-green-dark/60">(<%= matches.size %> items)</span>
                      </div>
                    </td>
                  <% else %>
                    <td colspan="<%= @suppliers.size + 3 %>" class="px-4 py-2 border-t-2 bg-gray-50 border-gray-200">
                      <span class="text-xs font-semibold uppercase tracking-wider text-gray-500"><%= display_category %></span>
                      <span class="ml-1.5 text-xs text-gray-400">(<%= matches.size %>)</span>
                    </td>
                  <% end %>
                </tr>
                <% matches.each_with_index do |match, idx| %>
                  <%= render "aggregated_lists/order_builder_desktop_row",
                             match: match, idx: idx, suppliers: @suppliers,
                             quantities: @quantities,
                             frequently_ordered: @frequently_ordered[match.id],
                             user_favorited: @user_favorited[match.id],
                             match_sp_id: @match_sp_ids[match.id],
                             category: category,
                             order_list_item: is_order_list_section %>
                <% end %>
                <% if is_order_list_section %>
                  <tr><td colspan="<%= @suppliers.size + 3 %>" class="h-8 bg-transparent border-none"></td></tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>

        <%# Mobile: flat card list with subtle category dividers %>
        <div class="sm:hidden p-2 space-y-2">
          <% @sorted_categories.each_with_index do |category, cat_idx| %>
            <% matches = @grouped_matches[category] %>
            <% is_order_list_section = @order_list_category && category == @order_list_category %>
            <% mobile_display_category = is_order_list_section ? @order_list.name : category %>
            <div data-order-builder-target="categorySection" data-category="<%= mobile_display_category %>">
              <% if is_order_list_section %>
                <div class="<%= cat_idx > 0 ? 'mt-3' : '' %> px-1 pb-2 sticky top-16 z-10 bg-brand-green/15 border-t-4 border-brand-green rounded-t-lg pt-2">
                  <div class="flex items-center gap-2">
                    <span class="inline-flex items-center px-2 py-0.5 rounded bg-brand-green text-white text-[10px] font-bold uppercase tracking-wider">Order List</span>
                    <span class="text-sm font-bold uppercase tracking-wider text-brand-green-dark"><%= mobile_display_category %></span>
                    <span class="text-xs text-brand-green-dark/60">(<%= matches.size %>)</span>
                  </div>
                </div>
              <% else %>
                <div class="<%= cat_idx > 0 ? 'border-t border-gray-200 mt-3 pt-3' : '' %> px-1 pb-2 sticky top-16 z-10 bg-white">
                  <span class="text-xs font-semibold uppercase tracking-wider text-gray-500"><%= mobile_display_category %></span>
                  <span class="ml-1 text-xs text-gray-400">(<%= matches.size %>)</span>
                </div>
              <% end %>
              <div class="space-y-3">
                <% matches.each_with_index do |match, idx| %>
                  <%= render "aggregated_lists/order_builder_mobile_card",
                             match: match, idx: idx, suppliers: @suppliers,
                             quantities: @quantities,
                             frequently_ordered: @frequently_ordered[match.id],
                             user_favorited: @user_favorited[match.id],
                             match_sp_id: @match_sp_ids[match.id] %>
                <% end %>
              </div>
              <% if is_order_list_section %>
                <div class="h-8"></div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

    <% else %>
      <div class="bg-white shadow rounded-lg p-8 text-center">
        <p class="text-gray-500">No matched products found. Go back and review product matching first.</p>
        <p class="mt-3">
          <%= link_to "Edit Matches", aggregated_list_path(@aggregated_list), class: "text-brand-orange hover:text-brand-orange-dark font-medium" %>
        </p>
      </div>
    <% end %>
  <% end %>
</div>
