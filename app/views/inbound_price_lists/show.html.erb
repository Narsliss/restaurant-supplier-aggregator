<div class="max-w-2xl mx-auto">
  <div class="bg-white shadow rounded-lg p-6">
    <h1 class="text-xl font-bold text-gray-900 mb-2">
      <% if @price_list.status == 'imported' %>
        Products Imported
      <% elsif @price_list.status == 'needs_review' %>
        Review Required
      <% elsif @price_list.parsed? %>
        Price List Ready
      <% elsif @price_list.failed? %>
        Parsing Failed
      <% else %>
        Parsing Price List
      <% end %>
    </h1>

    <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
      <span><%= @price_list.pdf_file_name || "Uploaded PDF" %></span>
      <span class="text-gray-300">·</span>
      <span>Uploaded <%= time_ago_in_words(@price_list.received_at) %> ago</span>
    </div>

    <% if @price_list.status == 'imported' %>
      <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-4">
        <p class="text-sm text-green-800">
          <strong><%= @price_list.product_count %> products</strong> imported successfully.
        </p>
      </div>
      <div class="flex justify-end gap-3">
        <%= link_to "← Back", supplier_credentials_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
        <% matched_list = AggregatedList.find_by(location_id: current_location&.id, organization_id: current_user.current_organization&.id, list_type: %w[master matched]) %>
        <% if matched_list %>
          <%= link_to "Review Product Matches →", aggregated_list_product_matches_path(matched_list),
                      class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-brand-orange rounded-md hover:bg-brand-orange-dark" %>
        <% end %>
      </div>

    <% elsif @price_list.status == 'needs_review' %>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-4">
        <div class="flex items-start gap-2">
          <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.168 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 6a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 6zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" /></svg>
          <div>
            <p class="text-sm font-medium text-amber-800">This parse needs a sanity check</p>
            <p class="text-sm text-amber-600 mt-0.5">The AI extraction had issues — please review the products before importing.</p>
          </div>
        </div>
      </div>
      <div class="flex justify-end">
        <%= link_to "Review Products", review_email_supplier_price_list_path(@email_supplier, @price_list),
                    class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-brand-orange rounded-md hover:bg-brand-orange-dark" %>
      </div>

    <% elsif @price_list.parsed? %>
      <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-4">
        <p class="text-sm text-green-800">
          <strong><%= @price_list.product_count %> products</strong> extracted successfully.
        </p>
      </div>
      <div class="flex justify-end">
        <%= link_to "Review Products", review_email_supplier_price_list_path(@email_supplier, @price_list),
                    class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-brand-orange rounded-md hover:bg-brand-orange-dark" %>
      </div>

    <% elsif @price_list.failed? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-4">
        <p class="text-sm font-medium text-red-800">Failed to parse this PDF</p>
        <p class="text-sm text-red-600 mt-1"><%= @price_list.error_message %></p>
      </div>
      <div class="flex justify-end gap-3">
        <%= link_to "Back", supplier_credentials_path, class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50" %>
      </div>

    <% else %>
      <%# Pending / Parsing — show spinner and poll %>
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4"
           data-controller="price-list-status"
           data-price-list-status-url-value="<%= status_email_supplier_price_list_path(@email_supplier, @price_list, format: :json) %>">
        <div class="flex items-start gap-3">
          <svg class="animate-spin w-5 h-5 text-blue-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <div>
            <p class="text-sm font-medium text-blue-800" data-price-list-status-target="title">Processing your price list...</p>
            <p class="text-sm text-blue-600 mt-0.5">Extracting products, prices, and categories from your PDF. This usually takes 15-30 seconds.</p>
          </div>
        </div>
      </div>
    <% end %>

    <div class="mt-4">
      <%= link_to "← Back to Supplier Credentials", supplier_credentials_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    </div>
  </div>
</div>
