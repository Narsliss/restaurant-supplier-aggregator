<div style="max-width: 600px; margin: 0 auto; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1f2937;">
  <div style="padding: 32px 24px;">
    <h1 style="font-size: 24px; font-weight: 700; margin-bottom: 16px; color: #111827;">
      Your trial ends in <%= @days_remaining %> <%= @days_remaining == 1 ? 'day' : 'days' %>
    </h1>

    <p style="font-size: 16px; line-height: 1.6; color: #4b5563; margin-bottom: 16px;">
      Hi <%= @owner.first_name.presence || "there" %>,
    </p>

    <p style="font-size: 16px; line-height: 1.6; color: #4b5563; margin-bottom: 16px;">
      Your EnPlace Pro trial for <strong><%= @org&.name %></strong> ends on
      <strong><%= @trial_end&.strftime("%B %-d, %Y") %></strong>.
    </p>

    <p style="font-size: 16px; line-height: 1.6; color: #4b5563; margin-bottom: 24px;">
      To keep comparing prices, managing orders, and saving money across your suppliers,
      make sure you have a payment method on file. Your subscription is $99/month.
    </p>

    <div style="text-align: center; margin-bottom: 24px;">
      <a href="<%= subscription_url %>" style="display: inline-block; background-color: #15803d; color: #ffffff; font-weight: 600; padding: 12px 24px; border-radius: 8px; text-decoration: none; font-size: 16px;">
        Manage Subscription
      </a>
    </div>

    <p style="font-size: 14px; color: #9ca3af; line-height: 1.5;">
      If you have any questions, just reply to this email. We're here to help.
    </p>
  </div>
</div>
