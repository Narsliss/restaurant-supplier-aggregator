<div style="max-width: 600px; margin: 0 auto; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1f2937;">
  <div style="padding: 32px 24px;">
    <h1 style="font-size: 24px; font-weight: 700; margin-bottom: 16px; color: #111827;">
      Action required to complete your payment
    </h1>

    <p style="font-size: 16px; line-height: 1.6; color: #4b5563; margin-bottom: 16px;">
      Hi <%= @owner.first_name.presence || "there" %>,
    </p>

    <p style="font-size: 16px; line-height: 1.6; color: #4b5563; margin-bottom: 16px;">
      Your bank requires additional authentication to complete the
      <strong><%= @amount %></strong> charge for <strong><%= @org&.name %></strong>'s
      EnPlace Pro subscription.
    </p>

    <p style="font-size: 16px; line-height: 1.6; color: #4b5563; margin-bottom: 24px;">
      Please click the button below to confirm the payment with your bank. This usually
      takes less than a minute.
    </p>

    <div style="text-align: center; margin-bottom: 24px;">
      <a href="<%= @hosted_invoice_url %>" style="display: inline-block; background-color: #15803d; color: #ffffff; font-weight: 600; padding: 12px 24px; border-radius: 8px; text-decoration: none; font-size: 16px;">
        Complete Payment
      </a>
    </div>

    <p style="font-size: 14px; color: #9ca3af; line-height: 1.5;">
      Until the payment is confirmed, your subscription may be paused.
      If you need help, just reply to this email.
    </p>
  </div>
</div>
