<div style="max-width: 600px; margin: 0 auto; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1f2937;">
  <div style="padding: 32px 24px;">
    <h1 style="font-size: 22px; font-weight: 700; margin-bottom: 16px; color: #15803d;">
      New paid signup
    </h1>

    <p style="font-size: 16px; line-height: 1.6; color: #4b5563; margin-bottom: 16px;">
      <strong><%= @org&.name.presence || "(unnamed org)" %></strong> just completed Stripe checkout.
    </p>

    <table style="width: 100%; font-size: 14px; line-height: 1.6; color: #4b5563; margin-bottom: 24px; border-collapse: collapse;">
      <tr>
        <td style="padding: 6px 0; color: #6b7280; width: 140px;">Organization</td>
        <td style="padding: 6px 0;"><%= @org&.name || "—" %><% if @org %> (id <code><%= @org.id %></code>)<% end %></td>
      </tr>
      <tr>
        <td style="padding: 6px 0; color: #6b7280;">Owner</td>
        <td style="padding: 6px 0;">
          <%= [@owner&.first_name, @owner&.last_name].compact.join(" ").presence || "—" %>
          <% if @owner&.email %>&lt;<%= @owner.email %>&gt;<% end %>
        </td>
      </tr>
      <tr>
        <td style="padding: 6px 0; color: #6b7280;">Plan</td>
        <td style="padding: 6px 0;">
          <code><%= @subscription.stripe_price_id %></code>
          <% if @subscription.amount_cents.present? %>
            — <%= number_to_currency(@subscription.amount_cents / 100.0, unit: (@subscription.currency || "usd").upcase + " ") %>
            <% if @subscription.interval.present? %>/ <%= @subscription.interval %><% end %>
          <% end %>
        </td>
      </tr>
      <tr>
        <td style="padding: 6px 0; color: #6b7280;">Status</td>
        <td style="padding: 6px 0;">
          <%= @subscription.status %>
          <% if @subscription.trialing? && @subscription.trial_end %>
            (trial ends <%= @subscription.trial_end.to_date.iso8601 %>)
          <% end %>
        </td>
      </tr>
      <tr>
        <td style="padding: 6px 0; color: #6b7280;">Stripe subscription</td>
        <td style="padding: 6px 0;"><code><%= @subscription.stripe_subscription_id %></code></td>
      </tr>
    </table>
  </div>
</div>
