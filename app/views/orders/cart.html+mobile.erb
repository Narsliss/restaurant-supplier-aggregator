  <div class="pt-24">
    <div class="w-20 h-20 mx-auto rounded-full bg-white border border-gray-200 flex items-center justify-center mb-4">
      <svg class="text-gray-300" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h2l2.4 12.2a2 2 0 002 1.8h7.9a2 2 0 002-1.6L21 7H6"/></svg>
    </div>
    <h1 class="font-heading text-xl font-semibold text-brand-navy">Cart is empty</h1>
