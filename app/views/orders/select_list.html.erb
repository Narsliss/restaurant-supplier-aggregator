<div class="py-6">
  <div class="max-w-3xl mx-auto">
    <div class="mb-8">
      <h1 class="text-2xl font-heading font-bold text-gray-900">New Order</h1>
      <p class="mt-1 text-sm text-gray-500">Choose what to order from.</p>
    </div>

    <% if @empty %>
      <div class="bg-white shadow rounded-lg p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
        </svg>
        <h3 class="mt-3 text-sm font-semibold text-gray-900">No lists available</h3>
        <p class="mt-1 text-sm text-gray-500">Set up your matched list first, then create order lists to start ordering.</p>
        <div class="mt-6">
          <%= link_to aggregated_lists_path,
              class: "inline-flex items-center rounded-md bg-brand-orange px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-orange-light transition-colors" do %>
            Go to Product Matching &rarr;
          <% end %>
        </div>
      </div>
    <% else %>

      <%# === ORDER LISTS SECTION === %>
      <% if @order_lists.any? %>
        <div class="mb-8">
          <div class="flex justify-between items-center mb-4">
            <h2 class="text-lg font-heading font-semibold text-gray-900">Your Order Lists</h2>
            <%= link_to "Manage Lists", order_lists_path, class: "text-sm text-brand-orange hover:text-brand-orange-light font-medium" %>
          </div>
          <div class="space-y-3">
            <% @order_lists.each do |list| %>
              <div class="bg-white shadow rounded-lg p-4 hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <h3 class="text-lg font-heading font-semibold text-gray-900 truncate">
                      <%= list.name %>
                      <% if list.is_favorite %>
                        <span class="ml-1 text-yellow-500">&#9733;</span>
                      <% end %>
                    </h3>
                    <p class="mt-1 text-sm text-gray-500">
                      <%= pluralize(list.order_list_items.size, "item") %>
                      <% if list.last_used_at %>
                        <span class="mx-1">&middot;</span>
                        Last used <%= time_ago_in_words(list.last_used_at) %> ago
                      <% end %>
                      <% if list.description.present? %>
                        <span class="mx-1">&middot;</span>
                        <%= list.description.truncate(60) %>
                      <% end %>
                    </p>
                  </div>
                  <div class="flex-shrink-0">
                    <%= link_to order_builder_order_list_path(list),
                        class: "inline-flex items-center rounded-md bg-brand-green px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-green-dark transition-colors" do %>
                      Build Order &rarr;
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# === FULL MATCHED LIST SECTION === %>
      <div class="mb-8">
        <h2 class="text-lg font-heading font-semibold text-gray-900 mb-4">Order from Full Matched List</h2>
        <% if @promoted_list %>
          <div class="bg-white shadow rounded-lg p-5 border-2 border-purple-200 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-heading font-semibold text-gray-900"><%= @promoted_list.name %></h3>
                <div class="mt-1 flex flex-wrap items-center gap-2">
                  <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-purple-100 text-purple-800">Org Default</span>
                  <% @promoted_list.supplier_lists.map(&:supplier).uniq.each do |supplier| %>
                    <span class="inline-flex items-center rounded-full bg-brand-green-50 px-2.5 py-0.5 text-xs font-medium text-brand-green-dark">
                      <%= supplier.name %>
                    </span>
                  <% end %>
                </div>
                <p class="mt-2 text-sm text-gray-500"><%= pluralize(@promoted_list.total_match_count, "product") %></p>
              </div>
              <div class="flex-shrink-0">
                <%= link_to order_builder_aggregated_list_path(@promoted_list),
                    data: { turbo: false },
                    class: "inline-flex items-center rounded-md bg-brand-green px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-green-dark transition-colors" do %>
                  Build Order &rarr;
                <% end %>
              </div>
            </div>
          </div>
        <% elsif @aggregated_lists.any? %>
          <div class="space-y-3">
            <% @aggregated_lists.each do |list| %>
              <div class="bg-white shadow rounded-lg p-5 hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <h3 class="text-lg font-heading font-semibold text-gray-900 truncate"><%= list.name %></h3>
                    <div class="mt-2 flex flex-wrap gap-1.5">
                      <% list.supplier_lists.map(&:supplier).uniq.each do |supplier| %>
                        <span class="inline-flex items-center rounded-full bg-brand-green-50 px-2.5 py-0.5 text-xs font-medium text-brand-green-dark">
                          <%= supplier.name %>
                        </span>
                      <% end %>
                    </div>
                    <p class="mt-2 text-sm text-gray-500"><%= pluralize(list.total_match_count, "product") %></p>
                  </div>
                  <div class="flex-shrink-0">
                    <%= link_to order_builder_aggregated_list_path(list),
                        data: { turbo: false },
                        class: "inline-flex items-center rounded-md bg-brand-green px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-green-dark transition-colors" do %>
                      Build Order &rarr;
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="bg-white shadow rounded-lg p-8 text-center">
            <p class="text-sm text-gray-500">No matched list yet. Set up your matched list to order from the full catalog.</p>
            <%= link_to "Go to Product Matching &rarr;".html_safe, aggregated_lists_path,
                class: "mt-2 inline-block text-brand-orange hover:text-brand-orange-light font-medium text-sm" %>
          </div>
        <% end %>
      </div>

    <% end %>
  </div>
</div>
