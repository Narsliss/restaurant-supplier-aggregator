<div class="py-6">
  <div class="max-w-3xl mx-auto">
    <div class="mb-8">
      <h1 class="text-2xl font-heading font-bold text-gray-900">New Order</h1>
      <p class="mt-1 text-sm text-gray-500">Select a list to start your order.</p>
    </div>

    <% if @empty %>
      <div class="bg-white shadow rounded-lg p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
        </svg>
        <h3 class="mt-3 text-sm font-semibold text-gray-900">No matched lists yet</h3>
        <p class="mt-1 text-sm text-gray-500">Create a list and match products across suppliers first.</p>
        <div class="mt-6">
          <%= link_to supplier_lists_path,
              class: "inline-flex items-center rounded-md bg-brand-orange px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-orange-light transition-colors" do %>
            Go to Lists & Matching &rarr;
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="space-y-4">
        <% @aggregated_lists.each do |list| %>
          <div class="bg-white shadow rounded-lg p-5 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-heading font-semibold text-gray-900 truncate"><%= list.name %></h3>
                <div class="mt-2 flex flex-wrap gap-1.5">
                  <% list.supplier_lists.map(&:supplier).uniq.each do |supplier| %>
                    <span class="inline-flex items-center rounded-full bg-brand-green-50 px-2.5 py-0.5 text-xs font-medium text-brand-green-dark">
                      <%= supplier.name %>
                    </span>
                  <% end %>
                </div>
                <p class="mt-2 text-sm text-gray-500">
                  <%= pluralize(list.total_match_count, "product") %>
                  <% if list.description.present? %>
                    <span class="mx-1">&middot;</span>
                    <%= list.description.truncate(60) %>
                  <% end %>
                </p>
              </div>
              <div class="flex-shrink-0">
                <%= link_to order_builder_aggregated_list_path(list),
                    data: { turbo: false },
                    class: "inline-flex items-center rounded-md bg-brand-green px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-green-dark transition-colors" do %>
                  Build Order &rarr;
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
