<% content_for :title, "New Order" %>

<%# Wired from mockups/mobile/select-list.html %>

<div class="h-2 bg-brand-green-dark -mx-4 -mt-2"></div>

<!-- Header -->
<header class="bg-brand-green-dark px-4 pb-3 pt-2 -mx-4">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-white text-lg font-heading font-semibold tracking-wide">New Order</h1>
      <p class="text-green-200 text-xs">Choose a list to start building</p>
    </div>
    <%= link_to root_path, class: "text-white/80" do %>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    <% end %>
  </div>
</header>

<% if @empty %>
  <div class="mt-8 text-center px-4">
    <svg class="mx-auto h-10 w-10 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
    </svg>
    <h3 class="mt-2 text-sm font-semibold text-gray-900">No lists available</h3>
    <p class="mt-1 text-xs text-gray-500">Set up product matching first.</p>
    <%= link_to "Go to Product Matching", aggregated_lists_path,
        class: "mt-4 inline-flex items-center bg-brand-orange text-white text-xs font-semibold px-4 py-2 rounded-lg" %>
  </div>
<% else %>

  <%# Order Lists %>
  <% if @order_lists.any? %>
    <section class="mt-5">
      <h2 class="font-heading text-sm font-semibold text-brand-navy uppercase tracking-wider mb-3">Your Order Lists</h2>
      <div class="space-y-2">
        <% @order_lists.each do |list| %>
          <% matched_list = @promoted_list || @aggregated_lists.first %>
          <% if matched_list %>
            <%= link_to order_builder_aggregated_list_path(matched_list, order_list_id: list.id),
                data: { turbo: false },
                class: "block bg-white rounded-xl border border-gray-200 shadow-sm p-4 active:border-brand-green active:bg-green-50/30 transition-colors" do %>
              <div class="flex items-center justify-between mb-1.5">
                <div class="flex items-center gap-2">
                  <% if list.is_favorite %>
                    <svg class="w-4 h-4 text-brand-orange" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  <% end %>
                  <p class="text-sm font-semibold text-gray-900"><%= list.name %></p>
                </div>
                <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </div>
              <% if list.description.present? %>
                <p class="text-xs text-gray-500 mb-2"><%= list.description.truncate(60) %></p>
              <% end %>
              <div class="flex items-center gap-3">
                <span class="text-[10px] text-gray-400"><%= pluralize(list.order_list_items.size, "product") %></span>
                <% if list.last_used_at %>
                  <span class="text-[10px] text-gray-400">Last used <%= time_ago_in_words(list.last_used_at) %> ago</span>
                <% end %>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>

  <%# Full Matched List %>
  <section class="mt-6">
    <h2 class="font-heading text-sm font-semibold text-brand-navy uppercase tracking-wider mb-3">Full Matched List</h2>

    <% if @promoted_list %>
      <%= link_to order_builder_aggregated_list_path(@promoted_list),
          data: { turbo: false },
          class: "block bg-white rounded-xl border-2 border-purple-200 shadow-sm p-4 mb-2 relative overflow-hidden active:bg-purple-50/30 transition-colors" do %>
        <div class="absolute top-0 right-0 bg-purple-500 text-white text-[8px] font-bold px-3 py-0.5 rounded-bl-lg uppercase tracking-wider">Org-Wide</div>
        <div class="flex items-center justify-between mb-1.5">
          <p class="text-sm font-semibold text-gray-900"><%= @promoted_list.name %></p>
          <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-[10px] text-gray-400"><%= pluralize(@promoted_list.total_match_count, "product") %></span>
        </div>
        <div class="flex gap-1.5 mt-2">
          <% @promoted_list.supplier_lists.map(&:supplier).uniq.each do |supplier| %>
            <span class="bg-green-50 text-brand-green text-[9px] font-bold px-2 py-0.5 rounded-full"><%= supplier.name.first(3).upcase %></span>
          <% end %>
        </div>
      <% end %>
    <% elsif @aggregated_lists.any? %>
      <div class="space-y-2">
        <% @aggregated_lists.each do |list| %>
          <%= link_to order_builder_aggregated_list_path(list),
              data: { turbo: false },
              class: "block bg-white rounded-xl border border-gray-200 shadow-sm p-4 active:border-brand-green transition-colors" do %>
            <div class="flex items-center justify-between mb-1.5">
              <p class="text-sm font-semibold text-gray-900"><%= list.name %></p>
              <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-[10px] text-gray-400"><%= pluralize(list.total_match_count, "product") %></span>
            </div>
            <div class="flex gap-1.5 mt-2">
              <% list.supplier_lists.map(&:supplier).uniq.each do |supplier| %>
                <span class="bg-green-50 text-brand-green text-[9px] font-bold px-2 py-0.5 rounded-full"><%= supplier.name.first(3).upcase %></span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 text-center">
        <p class="text-xs text-gray-500">No matched list yet.</p>
        <%= link_to "Go to Product Matching", aggregated_lists_path, class: "mt-1 inline-block text-brand-orange text-xs font-semibold" %>
      </div>
    <% end %>
  </section>

<% end %>
