<div class="max-w-6xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
  <%# ====== Persistent status banners (no flash messages) ====== %>
  <% if params[:invited].present? %>
    <div class="mb-6 rounded-xl bg-green-50 border border-green-200 p-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <svg class="h-5 w-5 text-green-600 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
        </svg>
        <p class="text-sm font-medium text-green-900">Invitation sent to <strong><%= params[:invited] %></strong></p>
      </div>
      <% if onboarding_incomplete? %>
        <span class="text-sm text-green-700 ml-4">Invite more, or</span>
      <% end %>
      <%= link_to root_path, class: "flex-shrink-0 inline-flex items-center gap-1.5 rounded-md bg-brand-orange px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-brand-orange-light transition-colors ml-3" do %>
        Done Inviting
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
        </svg>
      <% end %>
    </div>
  <% elsif params[:resent].present? %>
    <div class="mb-6 rounded-xl bg-green-50 border border-green-200 p-4 flex items-center gap-3">
      <svg class="h-5 w-5 text-green-600 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
      </svg>
      <p class="text-sm font-medium text-green-900">Invitation resent to <strong><%= params[:resent] %></strong></p>
    </div>
  <% elsif params[:canceled].present? %>
    <div class="mb-6 rounded-xl bg-gray-50 border border-gray-200 p-4 flex items-center gap-3">
      <svg class="h-5 w-5 text-gray-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
      <p class="text-sm font-medium text-gray-700">Invitation to <strong><%= params[:canceled] %></strong> has been canceled.</p>
    </div>
  <% elsif params[:updated].present? %>
    <div class="mb-6 rounded-xl bg-green-50 border border-green-200 p-4 flex items-center gap-3">
      <svg class="h-5 w-5 text-green-600 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
      </svg>
      <p class="text-sm font-medium text-green-900">Invitation for <strong><%= params[:updated] %></strong> has been updated.</p>
    </div>
  <% elsif params[:error].present? %>
    <div class="mb-6 rounded-xl bg-red-50 border border-red-200 p-4 flex items-center gap-3">
      <svg class="h-5 w-5 text-red-500 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0v-4.5A.75.75 0 0110 5zm0 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
      </svg>
      <p class="text-sm font-medium text-red-900">
        <%= params[:error] == "already_member" ? "This person is already a member of your organization." : params[:error] %>
      </p>
    </div>
  <% end %>

  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-900"><%= @organization.name %></h1>
      <p class="text-gray-600 mt-1">Team & Organization Settings</p>
    </div>
    <div class="flex items-center space-x-3">
      <span class="text-sm text-gray-500">
        <%= @seat_count %>/<%= @organization.max_seats %> seats included
        <% extra = [@seat_count - @organization.max_seats, 0].max %>
        <% if extra > 0 %>
          <% seat_cost = Rails.application.config.stripe_config[:seat_amount] / 100 %>
          <span class="text-amber-600">(+<%= extra %> @ $<%= seat_cost %>/mo each)</span>
        <% end %>
      </span>
      <% if owner? %>
        <%= link_to "Edit Organization", edit_organization_path, class: "px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors" %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Team Members -->
    <div class="lg:col-span-2">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200">
        <div class="px-6 py-5 border-b border-gray-200 flex justify-between items-center">
          <h2 class="text-lg font-semibold text-gray-900">Team Members</h2>
          <span class="text-sm text-gray-500"><%= @members.count %> member<%= @members.count == 1 ? '' : 's' %></span>
        </div>

        <ul class="divide-y divide-gray-200">
          <% @members.each do |membership| %>
            <li class="px-6 py-4 flex items-center justify-between">
              <div class="flex items-center">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-brand-green/10">
                  <span class="text-sm font-medium text-brand-green-dark"><%= membership.user.full_name.first.upcase %></span>
                </span>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-900">
                    <%= membership.user.full_name %>
                    <% if membership.user == current_user %>
                      <span class="text-gray-500">(you)</span>
                    <% end %>
                  </p>
                  <p class="text-sm text-gray-500"><%= membership.user.email %></p>
                  <% unless membership.owner? %>
                    <div class="flex flex-wrap gap-1 mt-1">
                      <% assigned = membership.assigned_locations %>
                      <% if assigned.any? %>
                        <% assigned.each do |loc| %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700"><%= loc.name %></span>
                        <% end %>
                      <% else %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700">No restaurant assigned</span>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
              <div class="flex items-center space-x-3">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <%= case membership.role
                      when 'owner' then 'bg-purple-100 text-purple-800'
                      when 'manager' then 'bg-blue-100 text-blue-800'
                      when 'chef' then 'bg-green-100 text-green-800'
                      else 'bg-gray-100 text-gray-800'
                      end %>">
                  <%= membership.role_display %>
                </span>

                <% if owner? && !membership.owner? && membership.user != current_user %>
                  <div class="relative" data-controller="dropdown">
                    <button type="button" class="text-gray-400 hover:text-gray-600" data-action="click->dropdown#toggle">
                      <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z" />
                      </svg>
                    </button>
                    <div class="hidden absolute right-0 z-10 mt-2 w-56 origin-top-right rounded-md bg-white py-1 shadow-lg ring-1 ring-black/5" data-dropdown-target="menu">
                      <% %w[manager chef].each do |role| %>
                        <% unless role == membership.role %>
                          <%= button_to "Make #{role.titleize}", organization_membership_path(membership), method: :patch, params: { role: role }, class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                        <% end %>
                      <% end %>
                      <div class="border-t border-gray-100 my-1"></div>
                      <p class="px-4 py-2 text-xs text-gray-500 font-medium">Assign Restaurants</p>
                      <%= form_with url: update_locations_organization_membership_path(membership), method: :patch, local: true do |f| %>
                        <% @locations.each do |loc| %>
                          <label class="flex items-center px-4 py-1 text-sm text-gray-700 hover:bg-gray-50 cursor-pointer">
                            <input type="checkbox" name="location_ids[]" value="<%= loc.id %>"
                                   <%= 'checked' if membership.assigned_to_location?(loc) %>
                                   class="rounded border-gray-300 text-brand-green-dark focus:ring-primary-500 mr-2">
                            <%= loc.name %>
                          </label>
                        <% end %>
                        <div class="px-4 py-2">
                          <button type="submit" class="w-full text-xs px-3 py-1.5 bg-brand-orange text-white rounded hover:bg-brand-orange-light">
                            Save Assignments
                          </button>
                        </div>
                      <% end %>
                      <div class="border-t border-gray-100 my-1"></div>
                      <%= button_to "Remove", organization_membership_path(membership), method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50", data: { confirm: "Are you sure you want to remove #{membership.user.full_name} from the organization?" } %>
                    </div>
                  </div>
                <% end %>
              </div>
            </li>
          <% end %>
        </ul>
      </div>

      <!-- Pending Invitations -->
      <% if owner? && @pending_invitations.any? %>
        <div class="mt-6 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
          <div class="px-6 py-5 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-900">Pending Invitations</h2>
          </div>

          <ul class="divide-y divide-gray-200">
            <% @pending_invitations.each do |invitation| %>
              <li class="px-6 py-4 flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= invitation.email %></p>
                  <p class="text-sm text-gray-500">
                    Invited as <%= invitation.role.titleize %> ·
                    Expires <%= time_ago_in_words(invitation.expires_at) %> from now
                  </p>
                  <div class="flex flex-wrap gap-1 mt-1">
                    <% if invitation.role == 'chef' && invitation.location.present? %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700"><%= invitation.location.name %></span>
                    <% elsif invitation.role == 'manager' && invitation.location_ids.present? %>
                      <% ids = invitation.location_ids.map(&:to_i) %>
                      <% locs = @locations.select { |l| ids.include?(l.id) } %>
                      <% locs.each do |loc| %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700"><%= loc.name %></span>
                      <% end %>
                    <% end %>
                  </div>
                  <p class="text-xs text-gray-400 mt-1 break-all"><%= accept_invitation_url(token: invitation.token) %></p>
                </div>
                <div class="flex items-center space-x-2">
                  <%= link_to "Edit", edit_organization_invitation_path(invitation), class: "text-sm text-brand-green-dark hover:underline" %>
                  <%= button_to "Resend", resend_organization_invitation_path(invitation), method: :post, class: "text-sm text-brand-green-dark hover:text-brand-green-dark" %>
                  <%= button_to "Cancel", organization_invitation_path(invitation), method: :delete, class: "text-sm text-red-600 hover:text-red-700" %>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Invite Team Member -->
      <% if owner? %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
          <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-4">Invite Team Member</h3>

          <% if !@organization.seats_available? && !@organization.subscribed? %>
            <div class="mb-4 p-3 bg-amber-50 border border-amber-200 rounded-lg">
              <p class="text-sm text-amber-800">
                All <%= @organization.max_seats %> included seats are in use.
                <% seat_cost = Rails.application.config.stripe_config[:seat_amount] / 100 %>
                <%= link_to "Subscribe", new_subscription_path, class: "font-semibold underline" %> to add more seats ($<%= seat_cost %>/mo each).
              </p>
            </div>
          <% elsif @seat_count >= @organization.max_seats && @organization.subscribed? %>
            <div class="mb-4 p-3 bg-blue-50 border border-blue-200 rounded-lg">
              <p class="text-sm text-blue-800">
                <% seat_cost = Rails.application.config.stripe_config[:seat_amount] / 100 %>
                Additional seats beyond <%= @organization.max_seats %> are billed at $<%= seat_cost %>/mo each, prorated automatically.
              </p>
            </div>
          <% end %>

          <%= form_with scope: :organization_invitation, url: organization_invitations_path, method: :post, local: true, class: "space-y-4", data: { controller: "invitation-form" } do |f| %>
            <div>
              <%= f.label :email, "Email Address", class: "block text-sm font-medium text-gray-700" %>
              <%= f.email_field :email, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm", placeholder: "team@example.com", required: true %>
            </div>

            <div>
              <%= f.label :role, "Role", class: "block text-sm font-medium text-gray-700" %>
              <%= f.select :role, [["Chef", "chef"], ["Manager", "manager"]], {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm", data: { action: "change->invitation-form#roleChanged", "invitation-form-target": "roleSelect" } %>
            </div>

            <%# Chef: single restaurant selector %>
            <div data-invitation-form-target="chefLocation">
              <label class="block text-sm font-medium text-gray-700">Restaurant</label>
              <%= f.select :location_id, @locations.map { |l| [l.name, l.id] }, { include_blank: "Select a restaurant..." }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-green focus:ring-brand-green text-sm" %>
            </div>

            <%# Manager: multi restaurant checkboxes %>
            <div data-invitation-form-target="managerLocations" class="hidden">
              <label class="block text-sm font-medium text-gray-700 mb-2">Restaurants</label>
              <div class="space-y-1 mt-1 p-3 border border-gray-200 rounded-lg bg-gray-50">
                <% @locations.each do |loc| %>
                  <label class="flex items-center py-1.5 text-sm text-gray-700 cursor-pointer hover:text-gray-900">
                    <input type="checkbox" name="organization_invitation[location_ids][]" value="<%= loc.id %>"
                           class="rounded border-gray-300 text-brand-green focus:ring-brand-green mr-2.5">
                    <%= loc.name %>
                  </label>
                <% end %>
              </div>
            </div>

            <button type="submit" class="w-full px-4 py-2 bg-brand-orange text-white rounded-lg hover:bg-brand-orange-light transition-colors text-sm font-medium"
                    <%= 'disabled' unless @organization.seats_available? || @organization.subscribed? %>>
              Send Invitation
            </button>
          <% end %>

          <div class="mt-4 pt-4 border-t border-gray-200">
            <p class="text-xs text-gray-500">
              <strong>Chef:</strong> Assigned to 1 restaurant, places orders, manages own supplier credentials<br>
              <strong>Manager:</strong> Assigned to 1+ restaurants, reporting & oversight, read-only on credentials
            </p>
          </div>
        </div>
      <% end %>

      <!-- Organization Details -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-4">Organization Details</h3>
        <dl class="space-y-3 text-sm">
          <div>
            <dt class="text-gray-500">Name</dt>
            <dd class="font-medium text-gray-900"><%= @organization.name %></dd>
          </div>
          <% if @organization.phone.present? %>
            <div>
              <dt class="text-gray-500">Phone</dt>
              <dd class="font-medium text-gray-900"><%= @organization.phone %></dd>
            </div>
          <% end %>
          <% if @organization.city.present? %>
            <div>
              <dt class="text-gray-500">Location</dt>
              <dd class="font-medium text-gray-900">
                <%= [@organization.city, @organization.state].compact.join(", ") %>
                <%= @organization.zip_code %>
              </dd>
            </div>
          <% end %>
          <div>
            <dt class="text-gray-500">Restaurants</dt>
            <dd class="font-medium text-gray-900"><%= @locations.count %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Created</dt>
            <dd class="font-medium text-gray-900"><%= @organization.created_at.strftime("%B %d, %Y") %></dd>
          </div>
        </dl>
      </div>
    </div>
  </div>

  <%# Case Minimums — owner only %>
  <% if owner? && @suppliers&.any? && @locations.any? %>
    <div id="case-minimums" class="mt-8 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Case Minimums by Supplier</h2>
        <p class="text-sm text-gray-500 mt-1">
          Set minimum case counts per supplier per restaurant. Orders below this minimum will show a warning (an extra charge may apply).
        </p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Supplier</th>
              <th class="px-4 py-2 text-center text-xs font-medium text-gray-500 uppercase">Default</th>
              <% @locations.each do |loc| %>
                <th class="px-4 py-2 text-center text-xs font-medium text-gray-500 uppercase"><%= loc.name %></th>
              <% end %>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @suppliers.each do |supplier| %>
              <tr>
                <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= supplier.name %></td>
                <td class="px-4 py-3 text-sm text-center text-gray-500">
                  <% global = @global_case_minimums[supplier.id] %>
                  <%= global ? global.numeric_value.to_i : "&mdash;".html_safe %>
                </td>
                <% @locations.each do |loc| %>
                  <td class="px-4 py-3 text-center">
                    <% existing = @case_minimums[[supplier.id, loc.id]] %>
                    <%= form_with url: update_case_minimum_organization_path,
                                  method: :post,
                                  class: "inline-flex items-center gap-1",
                                  local: true do |f| %>
                      <%= f.hidden_field :supplier_id, value: supplier.id %>
                      <%= f.hidden_field :location_id, value: loc.id %>
                      <%= f.number_field :case_minimum,
                          value: existing&.numeric_value&.to_i,
                          placeholder: @global_case_minimums[supplier.id]&.numeric_value&.to_i || "—",
                          min: 0,
                          class: "w-16 rounded-md border-gray-300 text-sm px-2 py-1 text-center #{existing ? 'border-amber-300 bg-amber-50' : ''}",
                          size: 4 %>
                      <%= f.submit "Set", class: "px-2 py-1 text-xs bg-brand-orange text-white rounded hover:bg-brand-orange-dark cursor-pointer" %>
                    <% end %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>
