<div class="py-6">
  <%# Syncing banner %>
  <% if @syncing %>
    <div class="mb-6 bg-blue-50 border border-blue-200 rounded-lg p-4 flex items-center gap-3"
         data-controller="auto-refresh"
         data-auto-refresh-interval-value="10000">
      <svg class="animate-spin h-5 w-5 text-blue-600 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <div>
        <p class="text-sm font-medium text-blue-800">Updating your supplier lists...</p>
        <p class="text-xs text-blue-600">This page will refresh automatically when complete. This can take 5-10 minutes depending on how many lists you have.</p>
      </div>
    </div>
  <% end %>

  <%# ===== YOUR ORDER LISTS (Primary Section) ===== %>
  <div class="mb-6">
    <h1 class="text-2xl font-heading font-bold text-gray-900">Lists & Matching</h1>
    <p class="mt-1 text-sm text-gray-500">Manage your supplier lists and match products across suppliers.</p>
  </div>

  <div class="flex items-start gap-3 mb-5">
    <div class="mt-0.5 flex-shrink-0 rounded-lg bg-brand-green/10 p-2">
      <svg class="h-5 w-5 text-brand-green" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z" />
      </svg>
    </div>
    <div>
      <h2 class="text-lg font-heading font-semibold text-gray-900">Your Comparison Lists</h2>
      <p class="mt-0.5 text-sm text-gray-500">Lists you've created by combining supplier lists. Products are matched across suppliers so you can compare prices side-by-side.</p>
    </div>
  </div>

  <% unless @lists_by_supplier.empty? %>
    <%= render "supplier_lists/comparison_lists" %>
  <% else %>
    <div class="bg-white shadow rounded-lg p-6 text-center mb-12">
      <p class="text-sm text-gray-500">
        <% if @syncing %>
          Your supplier lists are being imported. They'll appear here shortly.
        <% elsif @credentials.any? %>
          Click "Sync Supplier Lists" below to import your order guides, then create a comparison list.
        <% else %>
          <%= link_to "Connect a supplier", new_supplier_credential_path, class: "text-brand-orange hover:text-brand-orange-light" %> first, then update your lists.
        <% end %>
      </p>
    </div>
  <% end %>

  <%# ===== SUPPLIER LISTS (Reference Section) ===== %>
  <div class="mt-12 pt-8 border-t-2 border-gray-200">
    <div class="flex items-start gap-3 mb-5">
      <div class="mt-0.5 flex-shrink-0 rounded-lg bg-brand-orange/10 p-2">
        <svg class="h-5 w-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
        </svg>
      </div>
      <div class="flex-1">
        <h2 class="text-lg font-heading font-semibold text-gray-900">Supplier Lists</h2>
        <p class="mt-0.5 text-sm text-gray-500">Order guides and saved lists imported directly from your supplier accounts. These are the raw lists that get combined into your comparison lists above.</p>
      </div>
      <div class="flex gap-3 flex-shrink-0">
        <% if @syncing %>
          <button type="button" disabled
                  class="rounded-md bg-gray-300 px-4 py-2.5 text-sm font-semibold text-white shadow-sm cursor-not-allowed flex items-center gap-2">
            <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Updating...
          </button>
        <% else %>
          <%= button_to "Sync Supplier Lists", sync_all_supplier_lists_path,
              method: :post,
              class: "rounded-md bg-brand-orange px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-orange-light transition-colors" %>
        <% end %>
      </div>
    </div>

    <% if @lists_by_supplier.empty? %>
      <div class="bg-white shadow rounded-lg p-12 text-center">
        <% if @syncing %>
          <svg class="animate-spin mx-auto h-12 w-12 text-blue-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <h3 class="mt-4 text-sm font-medium text-gray-900">Importing your supplier lists...</h3>
          <p class="mt-1 text-sm text-gray-500">
            This page will refresh automatically when your lists are ready.
          </p>
        <% else %>
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900">No supplier lists yet</h3>
          <p class="mt-1 text-sm text-gray-500">
            <% if @credentials.any? %>
              Click "Sync Supplier Lists" to import your order guides from connected suppliers.
            <% else %>
              <%= link_to "Connect a supplier", new_supplier_credential_path, class: "text-brand-orange hover:text-brand-orange-light" %> first, then update your lists.
            <% end %>
          </p>
        <% end %>
      </div>
    <% else %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% @lists_by_supplier.each do |supplier, lists| %>
          <div class="bg-white shadow rounded-lg">
            <div class="px-4 py-3 flex justify-between items-center border-b border-gray-700">
              <div>
                <h3 class="text-lg font-heading font-medium leading-6 text-gray-900"><%= supplier.name %></h3>
                <p class="mt-1 text-sm text-gray-500"><%= pluralize(lists.size, "list") %></p>
              </div>
              <% credential = lists.first.supplier_credential %>
              <% if @syncing || @syncing_credential_ids.include?(credential.id) %>
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-blue-700">
                  <svg class="animate-spin h-4 w-4 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                  Updating...
                </span>
              <% else %>
                <%= button_to "Sync", sync_supplier_list_path(lists.first),
                    method: :post,
                    class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md border border-brand-orange text-brand-orange hover:bg-brand-orange hover:text-white transition-colors" %>
              <% end %>
            </div>
            <ul>
              <% lists.each do |list| %>
                <li class="px-4 py-2.5 hover:bg-gray-50 border-t border-gray-200">
                  <%= link_to supplier_list_path(list), class: "flex justify-between items-center" do %>
                    <div>
                      <p class="text-sm font-medium text-gray-900"><%= list.name %></p>
                      <p class="text-sm text-gray-500">
                        <%= pluralize(list.product_count, "product") %>
                        <span class="mx-1">&middot;</span>
                        <span class="text-xs"><%= list.time_since_sync %></span>
                      </p>
                    </div>
                    <div class="flex items-center gap-3">
                      <% case list.sync_status %>
                      <% when "synced" %>
                        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-green-100 text-green-800">Up to Date</span>
                      <% when "syncing" %>
                        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-blue-100 text-blue-800">Updating...</span>
                      <% when "failed" %>
                        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-red-100 text-red-800">Failed</span>
                      <% else %>
                        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-gray-100 text-gray-800">Pending</span>
                      <% end %>
                      <svg class="h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                      </svg>
                    </div>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
